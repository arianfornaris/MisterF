<%- include('partials/app-shell-open') %>

<section class="app-resource-view assignments-page <%= activeTab === 'blocks' ? 'assignment-authoring-blocks-page' : '' %>">
  <div class="resource-page-header resource-page-header-has-close">
    <div>
      <p class="resource-eyebrow">Tarea en edición</p>
      <h1><%= draft.title %></h1>
      <form class="d-inline-block mt-3" method="post" action="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/test-attempts">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn btn-primary" type="submit">
          <i class="bi bi-play-circle me-1" aria-hidden="true"></i>Probar
        </button>
      </form>
    </div>
    <div class="resource-page-header-actions">
      <a
        class="resource-page-close-button"
        href="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>"
        title="Cerrar"
        aria-label="Cerrar"
      >
        <i class="bi bi-x-lg" aria-hidden="true"></i>
      </a>
    </div>
  </div>

  <% if (authoringError) { %>
    <div class="alert alert-danger" role="alert"><%= authoringError %></div>
  <% } %>

  <ul class="nav nav-pills assignment-tabs" role="tablist">
    <li class="nav-item" role="presentation">
      <a
        class="nav-link <%= activeTab === 'general' ? 'active' : '' %>"
        href="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/edit?tab=general"
        role="tab"
        aria-selected="<%= activeTab === 'general' ? 'true' : 'false' %>"
      >
        <i class="bi bi-card-text me-1" aria-hidden="true"></i>General
      </a>
    </li>
    <li class="nav-item" role="presentation">
      <a
        class="nav-link <%= activeTab === 'blocks' ? 'active' : '' %>"
        href="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/edit?tab=blocks"
        role="tab"
        aria-selected="<%= activeTab === 'blocks' ? 'true' : 'false' %>"
      >
        <i class="bi bi-ui-checks-grid me-1" aria-hidden="true"></i>Bloques
      </a>
    </li>
    <li class="nav-item" role="presentation">
      <a
        class="nav-link <%= activeTab === 'chat' ? 'active' : '' %>"
        href="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/edit?tab=chat"
        role="tab"
        aria-selected="<%= activeTab === 'chat' ? 'true' : 'false' %>"
      >
        <i class="bi bi-chat-dots me-1" aria-hidden="true"></i>Chat IA
      </a>
    </li>
  </ul>

  <% if (activeTab === 'general') { %>
    <form class="card resource-form-card" method="post" action="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/edit/save">
      <div class="card-body">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label" for="assignmentTitle">Título</label>
            <input class="form-control" id="assignmentTitle" name="title" value="<%= draft.title %>" required>
          </div>
          <div class="col-12">
            <label class="form-label" for="assignmentDescription">Descripción</label>
            <textarea class="form-control" id="assignmentDescription" name="description" rows="3"><%= draft.description %></textarea>
          </div>
          <div class="col-12 col-md-8">
            <label class="form-label" for="assignmentTopic">Tema</label>
            <input class="form-control" id="assignmentTopic" name="targetTopic" value="<%= draft.targetTopic %>">
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label" for="assignmentLevel">Nivel</label>
            <input class="form-control" id="assignmentLevel" name="level" value="<%= draft.level %>">
          </div>
          <div class="col-12">
            <label class="form-label" for="assignmentInstructions">Instrucciones</label>
            <textarea class="form-control" id="assignmentInstructions" name="instructions" rows="4"><%= draft.instructions %></textarea>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
          <button class="btn btn-primary" type="submit">
            <i class="bi bi-save me-1" aria-hidden="true"></i>Guardar detalles
          </button>
        </div>
      </div>
    </form>
  <% } %>

  <% if (activeTab === 'blocks') { %>
    <div class="assignment-blocks-panel">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <h2 class="h5 mb-0">Bloques</h2>
        <button class="btn btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#assignmentAddBlockModal">
          <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Agregar bloque
        </button>
      </div>
      <div class="assignment-block-list" aria-label="Bloques de la tarea">
        <% draft.blocks.forEach((block, index) => { %>
          <%- include('partials/assignment-item-card', { assignmentItemMode: 'design', block, csrfToken, draft, index, selectedAssignment }) %>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (activeTab === 'chat') { %>
    <div class="assignment-chat-panel">
      <div class="assignment-chat-context">
        <div class="assignment-chat-context-icon" aria-hidden="true">
          <i class="bi bi-stars"></i>
        </div>
        <div>
          <h2 class="assignment-chat-context-title">Modificar la tarea con IA</h2>
          <p class="assignment-chat-context-copy mb-0">
            Usa este chat para pedir cambios concretos a la tarea. Mister F actualizará los detalles o bloques y te responderá qué modificó.
          </p>
        </div>
      </div>
      <div class="assignment-chat-history messages" aria-label="Historial del chat de autoría" data-authoring-chat-history>
        <% if (assignmentAuthoringMessages.length === 0) { %>
          <article class="message-row is-model assignment-chat-message-row">
            <div class="message-bubble assignment-chat-message-bubble">
              <p class="assignment-chat-message-content mb-0">Cuéntame qué quieres ajustar en esta tarea.</p>
            </div>
          </article>
        <% } else { %>
          <% assignmentAuthoringMessages.forEach((message) => { %>
            <article class="message-row <%= message.role === 'user' ? 'is-user' : 'is-model' %> assignment-chat-message-row">
              <div class="message-bubble assignment-chat-message-bubble">
                <p class="assignment-chat-message-content mb-0"><%= message.content %></p>
              </div>
            </article>
          <% }) %>
        <% } %>
      </div>
      <form class="composer assignment-chat-composer" method="post" action="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/edit/revise" data-assignment-generate-form>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="visually-hidden" for="assignmentRevisionMessage">Mensaje</label>
        <div class="composer-input-wrap">
          <textarea
            class="composer-input"
            id="assignmentRevisionMessage"
            name="message"
            rows="2"
            maxlength="4000"
            placeholder="Describe los cambios que deseas aplicar"
            required
          ></textarea>
        </div>
        <div class="composer-footer">
          <button class="btn btn-primary assignment-chat-submit-button" type="submit" data-assignment-generate-submit>
            <i class="bi bi-stars me-1" aria-hidden="true"></i>Aplicar cambios
          </button>
        </div>
      </form>
    </div>
  <% } %>

</section>

<div class="modal fade" id="assignmentAddBlockModal" tabindex="-1" aria-labelledby="assignmentAddBlockModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <form class="modal-content" method="post" action="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/edit/blocks" data-assignment-generate-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="modal-header">
        <h2 class="modal-title fs-5" id="assignmentAddBlockModalLabel">Agregar bloque</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label" for="assignmentBlockKind">Tipo</label>
          <select class="form-select" id="assignmentBlockKind" name="blockKind" required>
            <% assignmentBlockKinds.forEach((kind) => { %>
              <option value="<%= kind.value %>"><%= kind.label %></option>
            <% }) %>
          </select>
        </div>
        <div class="assignment-block-kind-list mb-3">
          <% assignmentBlockKinds.forEach((kind) => { %>
            <div class="assignment-block-kind">
              <strong><%= kind.label %></strong>
              <span><%= kind.description %></span>
            </div>
          <% }) %>
        </div>
        <label class="form-label" for="assignmentBlockPrompt">Prompt</label>
        <textarea class="form-control" id="assignmentBlockPrompt" name="prompt" rows="5" required></textarea>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button class="btn btn-primary" type="submit" data-assignment-generate-submit>Crear bloque</button>
      </div>
    </form>
  </div>
</div>

<div class="modal fade" tabindex="-1" aria-hidden="true" data-assignment-pending-modal>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" aria-hidden="true"></div>
        <p class="mb-0">Actualizando la tarea...</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/app-shell-close', { pageScriptPartial: 'assignments-client-script' }) %>
