<%- include('partials/app-shell-open') %>

<%
  const moneyFormatter = new Intl.NumberFormat('en-US', {
    currency: 'USD',
    style: 'currency',
  });
  const dateFormatter = new Intl.DateTimeFormat('es', {
    dateStyle: 'medium',
    timeStyle: 'short',
  });
  const formatMoney = (cents) => moneyFormatter.format(cents / 100);
  const formatUsd = (value) => value === null || value === undefined
    ? 'No disponible'
    : moneyFormatter.format(value);
  const formatDate = (value) => {
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? value : dateFormatter.format(date);
  };
  const statusLabels = {
    failed: 'Fallido',
    fulfilled: 'Completado',
    pending: 'Pendiente',
  };
  const statusClasses = {
    failed: 'text-bg-danger',
    fulfilled: 'text-bg-success',
    pending: 'text-bg-warning',
  };
%>

<section class="practice-modules-view" aria-label="Créditos">
  <div class="practice-modules-header">
    <div>
      <p class="practice-modules-kicker">Cuenta</p>
      <h1 class="practice-modules-title">Créditos</h1>
      <p class="practice-modules-copy">
        Usa tus créditos para practicar con Mr. F en cualquiera de tus perfiles.
      </p>
    </div>
  </div>

  <section class="practice-module-detail-shell">
    <% if (checkoutStatus === 'success') { %>
      <div class="alert alert-success" role="status">
        Pago recibido. Stripe confirmará el pago por webhook y actualizaremos tus créditos automáticamente.
      </div>
    <% } else if (checkoutStatus === 'cancelled') { %>
      <div class="alert alert-secondary" role="status">
        El pago fue cancelado. No se realizó ningún cargo.
      </div>
    <% } else if (checkoutStatus === 'error') { %>
      <div class="alert alert-danger" role="alert">
        <%= checkoutError || 'No se pudo iniciar el pago con Stripe.' %>
      </div>
    <% } %>

    <div class="row g-4">
      <div class="col-12 col-xl-7">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
              <div>
                <p class="practiceModule-section-kicker mb-2">Saldo actual</p>
                <h2 class="display-5 fw-semibold mb-1">
                  <% if (balance.availableCredits === null) { %>
                    No disponible
                  <% } else { %>
                    <%= balance.availableCredits %>
                  <% } %>
                </h2>
                <p class="mb-0 text-body-secondary">
                  créditos disponibles
                </p>
              </div>
            </div>

            <% if (balance.error) { %>
              <div class="alert alert-warning mt-4 mb-0" role="alert">
                <strong>No pudimos consultar tu saldo ahora.</strong>
                <span class="d-block"><%= balance.error %></span>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-5">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex flex-column">
            <p class="practiceModule-section-kicker mb-2">Comprar créditos</p>
            <h2 class="h3 mb-2"><%= creditPackage.label %></h2>
            <p class="text-body-secondary">
              <%= creditPackage.description %>
            </p>

            <div class="list-group list-group-flush mb-4">
              <div class="list-group-item px-0 d-flex justify-content-between">
                <span>Pagas</span>
                <strong><%= formatMoney(creditPackage.customerAmountCents) %></strong>
              </div>
              <div class="list-group-item px-0 d-flex justify-content-between">
                <span>Recibes</span>
                <strong><%= creditPackage.creditedAmountCents %> créditos</strong>
              </div>
            </div>

            <% if (stripeConfigurationError) { %>
              <div class="alert alert-warning mt-auto mb-0" role="alert">
                <%= stripeConfigurationError %>
              </div>
            <% } else { %>
              <form method="post" action="/credits/checkout" class="mt-auto">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-primary w-100" type="submit">
                  Comprar por <%= formatMoney(creditPackage.customerAmountCents) %>
                </button>
                <p class="small text-body-secondary mt-3 mb-0">
                  Cada intercambio con Mr. F consume créditos. Este paquete está pensado para aproximadamente un mes de práctica regular; la duración exacta depende de cuánto uses el sistema.
                </p>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="practice-module-section-copy mt-4">
      <p class="practiceModule-section-kicker">Historial reciente</p>
      <div class="card shadow-sm">
        <div class="card-body">
          <% if (purchases.length > 0) { %>
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th scope="col">Fecha</th>
                    <th scope="col">Paquete</th>
                    <th scope="col">Pago</th>
                    <th scope="col">Créditos</th>
                    <th scope="col">Estado</th>
                  </tr>
                </thead>
                <tbody>
                  <% purchases.forEach((purchase) => { %>
                    <tr>
                      <td><%= formatDate(purchase.createdAt) %></td>
                      <td><%= purchase.packageCode === 'credits_200' ? '200 créditos' : purchase.packageCode %></td>
                      <td><%= formatMoney(purchase.customerAmountCents) %></td>
                      <td><%= purchase.creditedAmountCents %></td>
                      <td>
                        <span class="badge <%= statusClasses[purchase.status] || 'text-bg-secondary' %>">
                          <%= statusLabels[purchase.status] || purchase.status %>
                        </span>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="mb-0 text-body-secondary">
              Todavía no tienes compras registradas.
            </p>
          <% } %>
        </div>
      </div>
    </div>
  </section>
</section>

<%- include('partials/app-shell-close') %>
