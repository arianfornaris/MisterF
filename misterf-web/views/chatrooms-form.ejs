<%- include('partials/app-shell-open') %>

<section class="app-resource-view" aria-label="Salas de chat">
  <div class="resource-page-header resource-page-header-has-close">
    <div class="resource-page-header-detail">
      <p class="resource-page-kicker">Salas de chat</p>
      <h1 class="resource-page-title"><%= chatRoomPageMode === 'edit' ? 'Editar sala' : 'Nueva sala' %></h1>
      <p class="resource-page-copy">
        Crea salas con personajes de IA para simular conversaciones sociales y hacer que el usuario escriba con más libertad.
      </p>
    </div>
    <div class="resource-page-header-actions">
      <a
        class="resource-page-close-button"
        href="<%= selectedChatRoom ? `/chatrooms/${encodeURIComponent(selectedChatRoom.id)}` : '/chatrooms' %>"
        title="Cerrar"
        aria-label="Cerrar"
      >
        <i class="bi bi-x-lg" aria-hidden="true"></i>
      </a>
    </div>
  </div>

  <% const editingRoom = selectedChatRoom; %>
  <% const editingCharacters = selectedChatRoomCharacters || []; %>
  <% const chatRoomDraftValues = typeof chatRoomFormValues === 'object' && chatRoomFormValues ? chatRoomFormValues : {}; %>
  <section class="resource-page-form-shell">
    <div class="resource-page-form-card card shadow-sm">
      <div class="card-body d-grid gap-4">
        <% if (chatRoomGenerationError) { %>
          <div class="alert alert-warning mb-0" role="alert">
            <strong>No pude generar la sala automáticamente.</strong>
            <div><%= chatRoomGenerationError %></div>
          </div>
        <% } else if (chatRoomGenerationPrompt) { %>
          <div class="alert alert-light border mb-0" role="status">
            <strong>Borrador generado con IA.</strong>
            Revísalo y ajusta lo que haga falta antes de crear la sala.
          </div>
        <% } %>
        <form
          class="practice-module-form"
          method="post"
          action="<%= chatRoomPageMode === 'edit' && editingRoom ? `/chatrooms/${encodeURIComponent(editingRoom.id)}` : '/chatrooms' %>"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <label class="form-label" for="chatRoomTitle">Nombre de la sala</label>
          <input
            class="form-control"
            id="chatRoomTitle"
            name="title"
            type="text"
            value="<%= typeof chatRoomDraftValues.title === 'string' ? chatRoomDraftValues.title : (editingRoom ? editingRoom.title : '') %>"
            maxlength="120"
            required
          >

          <label class="form-label" for="chatRoomDescription">Descripción de la sala</label>
          <textarea
            class="form-control"
            id="chatRoomDescription"
            name="description"
            rows="4"
            required
          ><%= typeof chatRoomDraftValues.description === 'string' ? chatRoomDraftValues.description : (editingRoom ? editingRoom.description : '') %></textarea>
          <div class="form-text">
            Explica de qué trata la sala, qué tipo de conversación suele ocurrir, el tono general y el tipo de gente que participa.
          </div>

          <div class="d-grid gap-3 mt-4">
            <div class="d-flex align-items-center justify-content-between">
              <p class="resource-page-section-copy mb-0">Personajes</p>
              <div class="btn-group">
                <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#chatroomCharacter2" aria-expanded="<%= editingCharacters.length >= 2 ? 'true' : 'false' %>">
                  Agregar personaje 2
                </button>
                <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#chatroomCharacter3" aria-expanded="<%= editingCharacters.length >= 3 ? 'true' : 'false' %>">
                  Agregar personaje 3
                </button>
              </div>
            </div>

            <% for (let index = 0; index < 3; index += 1) { %>
              <% const character = editingCharacters[index]; %>
              <% const sectionId = `chatroomCharacter${index + 1}`; %>
              <% const shouldShow = index === 0 || editingCharacters.length > index; %>
              <div class="card shadow-sm <%= index === 0 ? '' : 'collapse' %> <%= shouldShow ? 'show' : '' %>" id="<%= sectionId %>">
                <div class="card-body d-grid gap-3">
                  <div class="d-flex align-items-center justify-content-between">
                    <h3 class="fs-6 mb-0">Personaje <%= index + 1 %></h3>
                    <% if (index > 0) { %>
                      <button class="btn btn-link btn-sm px-0" type="button" data-bs-toggle="collapse" data-bs-target="#<%= sectionId %>">
                        Ocultar
                      </button>
                    <% } %>
                  </div>

                  <div class="row g-3">
                    <div class="col-md-4">
                      <label class="form-label" for="characterName<%= index + 1 %>">Nombre</label>
                      <input
                        class="form-control"
                        id="characterName<%= index + 1 %>"
                        name="characterName<%= index + 1 %>"
                        type="text"
                        value="<%= character ? character.name : '' %>"
                      >
                    </div>

                    <div class="col-md-8">
                      <label class="form-label" for="characterShortDescription<%= index + 1 %>">Descripción corta (UI)</label>
                      <input
                        class="form-control"
                        id="characterShortDescription<%= index + 1 %>"
                        name="characterShortDescription<%= index + 1 %>"
                        type="text"
                        value="<%= character ? character.shortDescription : '' %>"
                      >
                    </div>

                    <div class="col-12">
                      <label class="form-label" for="characterFullDescription<%= index + 1 %>">Descripción completa</label>
                      <textarea
                        class="form-control"
                        id="characterFullDescription<%= index + 1 %>"
                        name="characterFullDescription<%= index + 1 %>"
                        rows="4"
                      ><%= character ? character.fullDescription : '' %></textarea>
                      <div class="form-text">
                        Describe su personalidad, tono, opiniones, forma de hablar, nivel de formalidad y actitud frente al tema de la sala.
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% } %>
          </div>

          <div class="practice-module-form-actions">
            <button type="submit" class="btn btn-primary">
              <%= chatRoomPageMode === 'edit' ? 'Guardar cambios' : 'Crear sala' %>
            </button>
            <a class="btn btn-outline-secondary" href="<%= editingRoom ? `/chatrooms/${encodeURIComponent(editingRoom.id)}` : '/chatrooms' %>">
              Cancelar
            </a>
          </div>
        </form>
      </div>
    </div>
  </section>
</section>

<%- include('partials/app-shell-close', { pageScriptPartial: 'chatrooms-client-script' }) %>
