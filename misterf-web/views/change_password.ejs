<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="icon" type="image/png" sizes="32x32" href="/public/brand/favicon-32.png">
    <link rel="stylesheet" href="/vendor/bootswatch/journal/bootstrap.min.css">
    <%- include('partials/app-stylesheet') %>
  </head>
  <body>
    <main class="app-shell">
      <section class="auth-sheet card" aria-label="<%= title %>">
        <form class="auth-form card-body" method="post" action="/change-password" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="auth-copy">
            <p class="auth-kicker">Seguridad</p>
            <h1><%= hasPassword ? 'Cambiar contraseña' : 'Crear contraseña' %></h1>
          </div>

          <% if (error) { %>
            <div class="alert alert-danger auth-error" role="alert"><%= error %></div>
          <% } %>

          <% if (hasPassword) { %>
            <div class="auth-field mb-0">
              <label class="form-label" for="currentPassword">Contraseña actual</label>
              <input
                id="currentPassword"
                class="form-control <%= fieldErrors.currentPassword ? 'is-invalid' : '' %>"
                name="currentPassword"
                type="password"
                autocomplete="current-password"
                required
                autofocus
              >
              <% if (fieldErrors.currentPassword) { %>
                <div class="invalid-feedback"><%= fieldErrors.currentPassword %></div>
              <% } %>
            </div>
          <% } %>

          <div class="auth-field mb-0">
            <label class="form-label" for="newPassword">Nueva contraseña</label>
            <input
              id="newPassword"
              class="form-control <%= fieldErrors.newPassword ? 'is-invalid' : '' %>"
              name="newPassword"
              type="password"
              autocomplete="new-password"
              minlength="10"
              required
              <%= hasPassword ? '' : 'autofocus' %>
            >
            <% if (fieldErrors.newPassword) { %>
              <div class="invalid-feedback"><%= fieldErrors.newPassword %></div>
            <% } %>
          </div>

          <button class="btn btn-primary auth-submit" type="submit">Actualizar contraseña</button>

          <p class="auth-switch"><a href="/">Volver al chat</a></p>
        </form>
      </section>
    </main>
  </body>
</html>
