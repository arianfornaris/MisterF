<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="stylesheet" href="/vendor/bootswatch/journal/bootstrap.min.css">
    <link rel="stylesheet" href="/public/css/app.css">
  </head>
  <body>
    <main class="app-shell">
      <section class="auth-sheet" aria-label="<%= title %>">
        <form class="auth-form" method="post" action="/change-password" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="auth-copy">
            <p class="auth-kicker">Seguridad</p>
            <h1><%= hasPassword ? 'Cambiar contraseña' : 'Crear contraseña' %></h1>
          </div>

          <% if (error) { %>
            <p class="auth-error"><%= error %></p>
          <% } %>

          <% if (hasPassword) { %>
            <label class="auth-field">
              <span>Contraseña actual</span>
              <input
                name="currentPassword"
                type="password"
                autocomplete="current-password"
                required
                autofocus
              >
              <% if (fieldErrors.currentPassword) { %>
                <small><%= fieldErrors.currentPassword %></small>
              <% } %>
            </label>
          <% } %>

          <label class="auth-field">
            <span>Nueva contraseña</span>
            <input
              name="newPassword"
              type="password"
              autocomplete="new-password"
              minlength="10"
              required
              <%= hasPassword ? '' : 'autofocus' %>
            >
            <% if (fieldErrors.newPassword) { %>
              <small><%= fieldErrors.newPassword %></small>
            <% } %>
          </label>

          <button class="btn btn-dark auth-submit" type="submit">Actualizar contraseña</button>

          <p class="auth-switch"><a href="/">Volver al chat</a></p>
        </form>
      </section>
    </main>
  </body>
</html>
