<%- include('partials/app-shell-open') %>

<section class="app-resource-view" aria-label="<%= hasPassword ? 'Cambiar contraseña' : 'Crear contraseña' %>">
  <div class="resource-page-header">
    <div>
      <p class="resource-page-kicker">Seguridad</p>
      <h1 class="resource-page-title"><%= hasPassword ? 'Cambiar contraseña' : 'Crear contraseña' %></h1>
      <p class="resource-page-copy">
        Protege tu cuenta con una contraseña segura. Después del cambio tendrás que iniciar sesión otra vez.
      </p>
    </div>
  </div>

  <section class="resource-page-detail-shell">
    <div class="card shadow-sm">
      <div class="card-body">
        <% if (error) { %>
          <div class="alert alert-danger" role="alert"><%= error %></div>
        <% } %>

        <form method="post" action="/change-password" class="d-grid gap-3" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <% if (hasPassword) { %>
            <div>
              <label class="form-label" for="currentPassword">Contraseña actual</label>
              <input
                id="currentPassword"
                class="form-control <%= fieldErrors.currentPassword ? 'is-invalid' : '' %>"
                name="currentPassword"
                type="password"
                autocomplete="current-password"
                required
                autofocus
              >
              <% if (fieldErrors.currentPassword) { %>
                <div class="invalid-feedback"><%= fieldErrors.currentPassword %></div>
              <% } %>
            </div>
          <% } %>

          <div>
            <label class="form-label" for="newPassword">Nueva contraseña</label>
            <input
              id="newPassword"
              class="form-control <%= fieldErrors.newPassword ? 'is-invalid' : '' %>"
              name="newPassword"
              type="password"
              autocomplete="new-password"
              minlength="10"
              required
              <%= hasPassword ? '' : 'autofocus' %>
            >
            <% if (fieldErrors.newPassword) { %>
              <div class="invalid-feedback"><%= fieldErrors.newPassword %></div>
            <% } %>
            <div class="form-text">Usa al menos 10 caracteres.</div>
          </div>

          <div>
            <label class="form-label" for="confirmPassword">Repite la nueva contraseña</label>
            <input
              id="confirmPassword"
              class="form-control <%= fieldErrors.confirmPassword ? 'is-invalid' : '' %>"
              name="confirmPassword"
              type="password"
              autocomplete="new-password"
              minlength="10"
              required
            >
            <% if (fieldErrors.confirmPassword) { %>
              <div class="invalid-feedback"><%= fieldErrors.confirmPassword %></div>
            <% } %>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-primary" type="submit">Actualizar contraseña</button>
            <a class="btn btn-secondary" href="/settings">Volver a ajustes de cuenta</a>
          </div>
        </form>
      </div>
    </div>
  </section>
</section>

<%- include('partials/app-shell-close') %>
