<%- include('partials/app-shell-open') %>

<section class="app-resource-view" aria-label="Salas de chat">
  <div class="resource-page-header resource-page-header-has-close">
    <div class="resource-page-header-detail">
      <p class="resource-page-kicker">Salas de chat</p>
      <h1 class="resource-page-title"><%= selectedSharedChatRoom ? selectedSharedChatRoom.title : 'Sala compartida' %></h1>
      <p class="resource-page-copy">
        Esta sala fue compartida contigo para que puedas reutilizar los mismos personajes y la misma situación en tu propio perfil.
      </p>
    </div>
    <div class="resource-page-header-actions">
      <a
        class="resource-page-close-button"
        href="<%= isAuthenticated ? '/chatrooms' : '/' %>"
        title="Cerrar"
        aria-label="Cerrar"
      >
        <i class="bi bi-x-lg" aria-hidden="true"></i>
      </a>
    </div>
  </div>

  <section class="resource-page-form-shell">
    <div class="resource-page-form-card card shadow-sm">
      <div class="card-body d-grid gap-3">
        <p class="mb-0 text-body-secondary">
          <% if (activeProfile) { %>
            Esta sala de chat fue compartida contigo. Revísala y decide si quieres importarla al perfil <strong><%= activeProfile.name %></strong>.
          <% } else { %>
            Esta sala de chat fue compartida contigo. Puedes revisarla ahora mismo y, si te interesa, iniciar sesión o crear una cuenta para importarla.
          <% } %>
        </p>
        <div class="card border-0 bg-body-tertiary">
          <div class="card-body d-grid gap-3">
            <div>
              <h2 class="h4 mb-1"><%= selectedSharedChatRoom.title %></h2>
              <p class="mb-2 text-body-secondary"><%= selectedSharedChatRoom.description %></p>
              <% if (selectedChatRoomSharedFromProfileName) { %>
                <p class="mb-0 text-body-secondary small">Compartida desde el perfil <%= selectedChatRoomSharedFromProfileName %></p>
              <% } %>
            </div>
            <div class="d-flex flex-wrap gap-2">
              <% selectedChatRoomCharacters.forEach((character) => { %>
                <span class="badge text-bg-light border">
                  <%= character.name %><%= character.shortDescription ? ` · ${character.shortDescription}` : '' %>
                </span>
              <% }) %>
            </div>
          </div>
        </div>
        <div class="d-flex justify-content-end gap-2">
          <a class="btn btn-link" href="<%= isAuthenticated ? '/chatrooms' : '/' %>">No ahora</a>
          <% if (isAuthenticated && activeProfile) { %>
            <form method="post" action="/chatrooms/shared/<%= encodeURIComponent(selectedChatRoomShareLink.id) %>/accept">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-primary" type="submit">Importar sala</button>
            </form>
          <% } else { %>
            <a class="btn btn-secondary" href="/signup?returnTo=<%= encodeURIComponent(`/chatrooms/shared/${selectedChatRoomShareLink.id}`) %>">Crear cuenta</a>
            <a class="btn btn-primary" href="/login?returnTo=<%= encodeURIComponent(`/chatrooms/shared/${selectedChatRoomShareLink.id}`) %>">Iniciar sesión</a>
          <% } %>
        </div>
      </div>
    </div>
  </section>
</section>

<%- include('partials/app-shell-close', { pageScriptPartial: 'chatrooms-client-script' }) %>
