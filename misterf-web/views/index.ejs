<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="icon" type="image/png" sizes="32x32" href="/public/brand/favicon-32.png">
    <link rel="stylesheet" href="/vendor/bootswatch/journal/bootstrap.min.css">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/public/css/app.css">
  </head>
  <body
    data-authenticated="<%= isAuthenticated ? 'true' : 'false' %>"
    data-socket-auth-token="<%= socketAuthToken %>"
    data-auth-message="<%= authMessage %>"
    data-guest-initial-greeting="<%= guestInitialGreeting %>"
    data-initial-conversation-id="<%= initialConversationId || '' %>"
    data-chat-mode="<%= chatMode %>"
    data-current-view="<%= currentView %>"
  >
    <main class="app-shell">
      <div class="chat-workspace <%= hasSession ? 'has-toolbar' : '' %>">
        <% if (hasSession) { %>
          <div class="chat-toolbar" aria-label="Controles del chat">
            <button
              class="btn btn-link chat-menu-button d-lg-none"
              type="button"
              data-bs-toggle="offcanvas"
              data-bs-target="#conversationPanel"
              aria-controls="conversationPanel"
              title="Conversaciones"
              aria-label="Conversaciones"
            >
              <i class="bi bi-list fs-4" aria-hidden="true"></i>
            </button>

            <button
              class="btn btn-link translator-button d-lg-none"
              type="button"
              data-bs-toggle="modal"
              data-bs-target="#translatorModal"
              data-open-translator
              title="Traductor"
              aria-label="Traductor"
            >
              <i class="bi bi-translate fs-5" aria-hidden="true"></i>
            </button>
          </div>

          <aside
            class="offcanvas-lg offcanvas-start conversation-panel"
            tabindex="-1"
            id="conversationPanel"
            aria-label="Panel lateral"
          >
            <div class="offcanvas-header">
              <a
                class="panel-home-link d-lg-none"
                href="/"
                title="Ir al inicio"
                aria-label="Ir al inicio"
              >
                <img
                  class="panel-home-logo"
                  src="/public/brand/panel-brand-64.png"
                  alt="Mister F"
                  width="24"
                  height="24"
                >
              </a>
              <button type="button" class="btn-close d-lg-none" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
            </div>
            <div class="offcanvas-body">
              <div class="panel-nav">
                <a class="panel-nav-link d-none d-lg-inline-flex" href="/">
                  <img
                    class="panel-nav-brand-logo"
                    src="/public/brand/panel-brand-64.png"
                    alt=""
                    width="20"
                    height="20"
                    aria-hidden="true"
                  >
                  Mr. F
                </a>

                <a class="panel-nav-link" href="/" data-new-conversation>
                  <i class="bi bi-pencil-square" aria-hidden="true"></i>
                  Nueva conversación
                </a>

                <a class="panel-nav-link <%= currentView === 'practiceModules' ? 'is-active' : '' %>" href="/practice-modules">
                  <i class="bi bi-folder" aria-hidden="true"></i>
                  Módulos de práctica
                </a>

                <button
                  class="panel-nav-link d-none d-lg-inline-flex"
                  type="button"
                  data-bs-toggle="modal"
                  data-bs-target="#translatorModal"
                  data-open-translator
                >
                  <i class="bi bi-translate" aria-hidden="true"></i>
                  Traductor
                </button>
              </div>

              <div class="panel-recents">
                <p class="panel-section-label">Recientes</p>

                <% if (conversations.length > 0) { %>
                  <div class="conversation-list">
                    <% conversations.forEach((conversation) => { %>
                      <div
                        class="conversation-item"
                        data-conversation-id="<%= conversation.id %>"
                      >
                        <a
                          class="conversation-open-button"
                          href="/c/<%= encodeURIComponent(conversation.id) %>"
                          data-open-conversation
                        >
                          <i class="bi bi-chat-dots conversation-open-icon" aria-hidden="true"></i>
                          <span class="conversation-open-copy">
                            <span class="conversation-title"><%= conversation.title %></span>
                            <time class="conversation-date" datetime="<%= conversation.updatedAt %>">
                              <%= conversation.updatedAt %>
                            </time>
                          </span>
                        </a>

                        <div class="conversation-actions dropdown">
                          <button
                            class="btn btn-link conversation-actions-button"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            title="Opciones de conversación"
                            aria-label="Opciones de conversación"
                          >
                            <i class="bi bi-three-dots" aria-hidden="true"></i>
                          </button>
                          <div class="dropdown-menu dropdown-menu-end conversation-actions-menu">
                            <button class="dropdown-item" type="button" data-rename-conversation>Renombrar</button>
                            <button class="dropdown-item text-danger" type="button" data-delete-conversation>Eliminar</button>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="conversation-empty">Todavía no hay conversaciones.</p>
                <% } %>
              </div>

              <div class="panel-bottom">
                <div class="user-menu dropdown">
                  <button
                    class="btn btn-link panel-nav-link user-panel-button"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    title="<%= activeProfile ? activeProfile.name : 'Perfil' %>"
                    aria-label="<%= activeProfile ? activeProfile.name : 'Perfil' %>"
                  >
                    <i class="bi bi-person-circle" aria-hidden="true"></i>
                    <%= activeProfile ? activeProfile.name : 'Perfil' %>
                  </button>

                  <div class="dropdown-menu user-menu-panel">
                    <% if (activeProfile) { %>
                      <p class="user-menu-email"><strong><%= activeProfile.name %></strong></p>
                    <% } %>
                    <p class="user-menu-email"><%= user.email %></p>
                    <a class="dropdown-item" href="/profiles">Cambiar perfil</a>
                    <a class="dropdown-item" href="/change-password">Cambiar contraseña</a>
                    <form method="post" action="/logout">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="dropdown-item" type="submit">Cerrar sesión</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </aside>

          <div
            class="modal fade"
            id="deleteConversationModal"
            tabindex="-1"
            aria-labelledby="deleteConversationModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content delete-conversation-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="deleteConversationModalLabel">Eliminar chat</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <p class="mb-0">
                    ¿Seguro que quieres eliminar “<span data-delete-conversation-title></span>”?
                    Esta acción no se puede deshacer.
                  </p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cancelar</button>
                  <button type="button" class="btn btn-danger" data-confirm-delete-conversation>Eliminar</button>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="translatorModal"
            tabindex="-1"
            aria-labelledby="translatorModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content translator-modal">
                <form id="translatorForm" autocomplete="off">
                  <div class="modal-header">
                    <h2 class="modal-title fs-5" id="translatorModalLabel">Traductor</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                  </div>
                  <div class="modal-body">
                    <div class="translator-mode btn-group" role="group" aria-label="Modo de traducción">
                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeAuto" value="auto" checked>
                      <label class="btn btn-outline-dark" for="translatorModeAuto">Auto</label>

                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeEsEn" value="es-en">
                      <label class="btn btn-outline-dark" for="translatorModeEsEn">ES → EN</label>

                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeEnEs" value="en-es">
                      <label class="btn btn-outline-dark" for="translatorModeEnEs">EN → ES</label>
                    </div>

                    <label class="visually-hidden" for="translatorInput">Texto para traducir</label>
                    <div class="translator-box">
                      <textarea
                        class="form-control translator-textarea"
                        id="translatorInput"
                        rows="5"
                        maxlength="2000"
                        autocomplete="off"
                        autocapitalize="none"
                        autocorrect="off"
                        spellcheck="false"
                      ></textarea>
                      <button
                        class="translator-copy-button"
                        type="button"
                        data-translator-copy="input"
                        title="Copiar texto"
                        aria-label="Copiar texto"
                      >
                        <i class="bi bi-copy" aria-hidden="true"></i>
                      </button>
                    </div>

                    <div class="translator-box translator-result-box">
                      <div class="translator-result" id="translatorResult" aria-live="polite"></div>
                      <button
                        class="translator-copy-button"
                        type="button"
                        data-translator-copy="result"
                        title="Copiar traducción"
                        aria-label="Copiar traducción"
                      >
                        <i class="bi bi-copy" aria-hidden="true"></i>
                      </button>
                    </div>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-dark" data-translator-submit>Traducir</button>
                  </div>
                </form>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="creditModal"
            tabindex="-1"
            aria-labelledby="creditModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content credit-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="creditModalLabel">Crédito agotado</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <p class="mb-0" data-credit-message>
                    Tu crédito de práctica se agotó por ahora.
                  </p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Entendido</button>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="practiceModuleHelpModal"
            tabindex="-1"
            aria-labelledby="practiceModuleHelpModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered modal-lg">
              <div class="modal-content translator-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="practiceModuleHelpModalLabel">Qué puede hacer el tutor</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body practice-module-help-modal-body">
                  <section class="practice-module-help-section">
                    <h3>Tipos de práctica que puedes pedir</h3>
                    <ul>
                      <li>Traducir del español al inglés con corrección guiada.</li>
                      <li>Comprender frases en inglés y explicarlas en español.</li>
                      <li>Mini-conversaciones o role-play con personajes ficticios.</li>
                      <li>Emparejar columnas de palabras, frases o significados.</li>
                      <li>Completar espacios escribiendo o eligiendo opciones.</li>
                      <li>Multiple choice de una o varias respuestas correctas.</li>
                      <li>Ordenar palabras para reconstruir una oración.</li>
                    </ul>
                  </section>

                  <section class="practice-module-help-section">
                    <h3>Ejemplos de instrucciones útiles</h3>
                    <ul>
                      <li>Practica vocabulario de colores con ejercicios variados y mucha corrección paciente.</li>
                      <li>Haz mini-conversaciones de restaurante para un nivel básico, con tono amable y situaciones realistas.</li>
                      <li>Trabaja el pasado simple con frases cortas, completar espacios y multiple choice.</li>
                      <li>Enfócate en inglés para entrevistas de trabajo con tono formal y correcciones claras.</li>
                    </ul>
                  </section>

                  <section class="practice-module-help-section">
                    <h3>Buenas prácticas</h3>
                    <ul>
                      <li>Especifica el tema, el tipo de situación y el nivel aproximado.</li>
                      <li>Puedes combinar varias dinámicas dentro de un mismo módulo de práctica.</li>
                      <li>No hace falta describir la interfaz; describe el objetivo pedagógico.</li>
                      <li>Puedes decir si quieres que el tutor sea más paciente, más exigente o más conversacional.</li>
                    </ul>
                  </section>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Entendido</button>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <section
          class="practice-modules-view <%= currentView === 'practiceModules' ? '' : 'd-none' %>"
          aria-label="Módulos de práctica"
        >
          <div class="practice-modules-header <%= practiceModulePageMode === 'detail' ? 'practice-modules-header-detail' : '' %> <%= practiceModulePageMode !== 'list' ? 'practice-modules-header-has-close' : '' %>">
            <div>
              <p class="practice-modules-kicker">Módulos de práctica</p>
              <h1 class="practice-modules-title">
                <% if (practiceModulePageMode === 'collectionNew') { %>
                  Nueva colección
                <% } else if (practiceModulePageMode === 'collectionEdit') { %>
                  Editar colección
                <% } else if (practiceModulePageMode === 'collectionShare') { %>
                  <%= selectedSharedPracticeModuleCollection ? selectedSharedPracticeModuleCollection.title : 'Colección compartida' %>
                <% } else if (practiceModulePageMode === 'collectionDetail') { %>
                  <%= selectedPracticeModuleCollection ? selectedPracticeModuleCollection.title : 'Colección' %>
                <% } else if (practiceModulePageMode === 'new') { %>
                  Nuevo módulo de práctica
                <% } else if (practiceModulePageMode === 'edit') { %>
                  Editar módulo de práctica
                <% } else if (practiceModulePageMode === 'share') { %>
                  <%= selectedSharedPracticeModule ? selectedSharedPracticeModule.title : 'Módulo de práctica compartido' %>
                <% } else { %>
                  <%= selectedPracticeModule ? selectedPracticeModule.title : 'Biblioteca de módulos de práctica' %>
                <% } %>
              </h1>
              <p class="practice-modules-copy">
                <% if (practiceModulePageMode === 'collectionNew') { %>
                  Crea una colección para agrupar y ordenar varios módulos de práctica alrededor de un mismo tema o propósito.
                <% } else if (practiceModulePageMode === 'collectionEdit') { %>
                  Ajusta el nombre y la descripción de esta colección sin tocar el contenido de los módulos.
                <% } else if (practiceModulePageMode === 'collectionShare') { %>
                  <%= selectedSharedPracticeModuleCollection ? selectedSharedPracticeModuleCollection.description : 'Te compartieron una colección.' %>
                <% } else if (practiceModulePageMode === 'collectionDetail') { %>
                  <%= selectedPracticeModuleCollection ? selectedPracticeModuleCollection.description : 'Organiza y ordena módulos de práctica dentro de una misma colección.' %>
                <% } else if (practiceModulePageMode === 'new') { %>
                  Diseña un módulo de práctica con un objetivo claro, una descripción útil y una guía precisa para el tutor.
                <% } else if (practiceModulePageMode === 'edit') { %>
                  Ajusta este módulo de práctica con calma. Los chats existentes conservarán su propia copia del módulo original.
                <% } else if (practiceModulePageMode === 'share') { %>
                  <%= selectedSharedPracticeModule ? selectedSharedPracticeModule.description : 'Te compartieron un módulo de práctica.' %>
                <% } else { %>
                  <%= selectedPracticeModule ? selectedPracticeModule.description : 'Crea experiencias guiadas para el tutor con un objetivo claro, una descripción y reglas propias.' %>
                <% } %>
              </p>
            </div>

            <% if (hasSession) { %>
              <div class="practice-modules-header-actions">
                <% if (practiceModulePageMode === 'new' || practiceModulePageMode === 'edit' || practiceModulePageMode === 'detail' || practiceModulePageMode === 'share' || practiceModulePageMode === 'collectionShare' || practiceModulePageMode === 'collectionNew' || practiceModulePageMode === 'collectionEdit' || practiceModulePageMode === 'collectionDetail') { %>
                  <a
                    class="btn-close practice-module-close-button"
                    href="<%= practiceModulePageMode === 'detail' || practiceModulePageMode === 'share' || practiceModulePageMode === 'collectionShare' || practiceModulePageMode === 'collectionDetail' ? '/practice-modules' : practiceModulePageMode === 'collectionEdit' && selectedPracticeModuleCollection ? `/practice-modules/collections/${encodeURIComponent(selectedPracticeModuleCollection.id)}` : selectedPracticeModule ? `/practice-modules/${encodeURIComponent(selectedPracticeModule.id)}` : '/practice-modules' %>"
                    title="Cerrar"
                    aria-label="Cerrar"
                  ></a>
                <% } %>
              </div>
            <% } %>
          </div>

          <% if (practiceModulePageMode === 'collectionDetail' && selectedPracticeModuleCollection) { %>
            <section class="practice-module-detail-shell">
              <div class="d-grid gap-3">
                <% if (selectedPracticeModuleCollection.sharedVia) { %>
                  <div class="d-flex">
                    <% if (selectedPracticeModuleCollectionSharedFromProfileName) { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida por <%= selectedPracticeModuleCollectionSharedFromProfileName %>
                      </span>
                    <% } else { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida <%= selectedPracticeModuleCollection.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                      </span>
                    <% } %>
                  </div>
                <% } %>

                <div class="practice-module-detail-inline-actions btn-toolbar" role="toolbar" aria-label="Acciones de la colección">
                  <div class="btn-group" role="group" aria-label="<%= selectedPracticeModuleCollection.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>">
                    <form
                      method="post"
                      action="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/favorite"
                    >
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <input type="hidden" name="favorite" value="<%= selectedPracticeModuleCollection.isFavorite ? '0' : '1' %>">
                      <input type="hidden" name="returnTo" value="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>">
                      <button class="btn btn-outline-dark" type="submit" title="<%= selectedPracticeModuleCollection.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>" aria-label="<%= selectedPracticeModuleCollection.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>">
                        <i class="bi <%= selectedPracticeModuleCollection.isFavorite ? 'bi-star-fill' : 'bi-star' %>" aria-hidden="true"></i>
                      </button>
                    </form>
                  </div>
                  <div class="btn-group" role="group" aria-label="Editar colección">
                    <a
                      class="btn btn-outline-dark"
                      href="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/edit"
                      title="Editar colección"
                      aria-label="Editar colección"
                    >
                      <i class="bi bi-pencil" aria-hidden="true"></i>
                    </a>
                  </div>
                  <% if (!selectedPracticeModuleCollection.archivedAt) { %>
                    <div class="btn-group" role="group" aria-label="Compartir colección">
                      <button
                        class="btn btn-outline-dark dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        title="Compartir colección"
                        aria-label="Compartir colección"
                      >
                        <i class="bi bi-share" aria-hidden="true"></i>
                      </button>
                      <div class="dropdown-menu">
                        <button
                          class="dropdown-item"
                          type="button"
                          data-bs-toggle="modal"
                          data-bs-target="#sharePracticeModuleCollectionProfileModal"
                        >
                          Compartir con perfil
                        </button>
                        <button
                          class="dropdown-item"
                          type="button"
                          data-bs-toggle="modal"
                          data-bs-target="#sharePracticeModuleCollectionLinkModal"
                        >
                          Obtener enlace
                        </button>
                      </div>
                    </div>
                  <% } %>
                  <div class="btn-group" role="group" aria-label="<%= selectedPracticeModuleCollection.archivedAt ? 'Restaurar colección' : 'Archivar colección' %>">
                    <form
                      method="post"
                      action="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/<%= selectedPracticeModuleCollection.archivedAt ? 'restore' : 'archive' %>"
                      onsubmit="return window.confirm('<%= selectedPracticeModuleCollection.archivedAt ? '¿Seguro que quieres restaurar esta colección?' : '¿Seguro que quieres archivar esta colección? También se archivarán sus módulos.' %>');"
                    >
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <input type="hidden" name="returnTo" value="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>">
                      <button class="btn btn-outline-dark" type="submit" title="<%= selectedPracticeModuleCollection.archivedAt ? 'Restaurar colección' : 'Archivar colección' %>" aria-label="<%= selectedPracticeModuleCollection.archivedAt ? 'Restaurar colección' : 'Archivar colección' %>">
                        <i class="bi <%= selectedPracticeModuleCollection.archivedAt ? 'bi-arrow-counterclockwise' : 'bi-archive' %>" aria-hidden="true"></i>
                      </button>
                    </form>
                  </div>
                </div>

                <p class="practiceModule-section-copy">Módulos de esta colección</p>

                <% if (practiceModuleCollectionModules.length > 0) { %>
                  <div class="list-group shadow-sm">
                    <% practiceModuleCollectionModules.forEach((entry) => { %>
                      <div class="list-group-item">
                        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                          <div class="min-w-0">
                            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                              <span class="badge text-bg-light border">#<%= entry.position %></span>
                              <a class="text-decoration-none fw-semibold" href="/practice-modules/<%= encodeURIComponent(entry.practiceModule.id) %>">
                                <%= entry.practiceModule.title %>
                              </a>
                            </div>
                            <p class="mb-0 text-body-secondary"><%= entry.practiceModule.description %></p>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="alert alert-light border mb-0">
                    Todavía no hay módulos en esta colección.
                  </div>
                <% } %>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'collectionEdit' && selectedPracticeModuleCollection) { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body d-grid gap-4">
                  <form
                    class="practice-module-form"
                    method="post"
                    action="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>"
                    autocomplete="off"
                  >
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <label class="form-label" for="practiceModuleCollectionTitle">Título</label>
                    <input
                      class="form-control"
                      id="practiceModuleCollectionTitle"
                      name="title"
                      maxlength="120"
                      value="<%= selectedPracticeModuleCollection.title %>"
                      required
                    >

                    <label class="form-label" for="practiceModuleCollectionDescription">Descripción</label>
                    <textarea
                      class="form-control"
                      id="practiceModuleCollectionDescription"
                      name="description"
                      rows="4"
                      maxlength="500"
                    ><%= selectedPracticeModuleCollection.description %></textarea>

                    <div class="practice-module-form-actions">
                      <button type="submit" class="btn btn-dark">Guardar cambios</button>
                    </div>
                  </form>

                  <div class="d-grid gap-3">
                    <p class="practiceModule-section-copy">Módulos de esta colección</p>

                    <% if (practiceModuleCollectionModules.length > 0) { %>
                      <div class="list-group shadow-sm">
                        <% practiceModuleCollectionModules.forEach((entry, index) => { %>
                          <div class="list-group-item">
                            <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                              <div class="min-w-0">
                                <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                  <span class="badge text-bg-light border">#<%= entry.position %></span>
                                  <a class="text-decoration-none fw-semibold" href="/practice-modules/<%= encodeURIComponent(entry.practiceModule.id) %>">
                                    <%= entry.practiceModule.title %>
                                  </a>
                                </div>
                                <p class="mb-0 text-body-secondary"><%= entry.practiceModule.description %></p>
                              </div>
                              <div class="d-flex align-items-center gap-2 flex-nowrap">
                                <form method="post" action="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/items/<%= encodeURIComponent(entry.practiceModule.id) %>/move-up">
                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                  <input type="hidden" name="returnTo" value="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/edit">
                                  <button class="btn btn-sm btn-outline-dark" type="submit" <%= index === 0 ? 'disabled' : '' %> title="Subir módulo" aria-label="Subir módulo">
                                    <i class="bi bi-arrow-up" aria-hidden="true"></i>
                                  </button>
                                </form>
                                <form method="post" action="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/items/<%= encodeURIComponent(entry.practiceModule.id) %>/move-down">
                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                  <input type="hidden" name="returnTo" value="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/edit">
                                  <button class="btn btn-sm btn-outline-dark" type="submit" <%= index === practiceModuleCollectionModules.length - 1 ? 'disabled' : '' %> title="Bajar módulo" aria-label="Bajar módulo">
                                    <i class="bi bi-arrow-down" aria-hidden="true"></i>
                                  </button>
                                </form>
                                <form method="post" action="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/items/<%= encodeURIComponent(entry.practiceModule.id) %>/remove">
                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                  <input type="hidden" name="returnTo" value="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/edit">
                                  <button class="btn btn-sm btn-outline-dark" type="submit" title="Quitar de la colección" aria-label="Quitar de la colección">
                                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                                  </button>
                                </form>
                              </div>
                            </div>
                          </div>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <div class="alert alert-light border mb-0">
                        Todavía no hay módulos en esta colección.
                      </div>
                    <% } %>

                    <div class="card shadow-sm">
                      <div class="card-body d-grid gap-3">
                        <p class="practiceModule-section-copy">Agregar módulo a la colección</p>
                        <% if (availablePracticeModulesForCollection.length > 0) { %>
                        <form
                          class="d-grid gap-3"
                          method="post"
                          action="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/items"
                            data-collection-module-picker
                          >
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="returnTo" value="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/edit">
                            <div class="practice-module-filter-input-wrap">
                              <input
                                class="form-control practice-module-filter-input"
                                type="search"
                                placeholder="Filtrar módulos disponibles"
                                aria-label="Filtrar módulos disponibles"
                                data-collection-module-filter
                              >
                            </div>
                            <div class="list-group practice-module-collection-picker-list" data-collection-module-list>
                              <% availablePracticeModulesForCollection.forEach((practiceModule) => { %>
                                <label
                                  class="list-group-item list-group-item-action d-flex align-items-start gap-3"
                                  data-collection-module-item
                                  data-search-text="<%= `${practiceModule.title}\n${practiceModule.description}`.toLowerCase() %>"
                                >
                                  <input
                                    class="form-check-input mt-1"
                                    type="checkbox"
                                    name="practiceModuleId"
                                    value="<%= practiceModule.id %>"
                                  >
                                  <span class="d-grid gap-1">
                                    <span class="fw-semibold"><%= practiceModule.title %></span>
                                    <span class="text-body-secondary small"><%= practiceModule.description %></span>
                                  </span>
                                </label>
                              <% }) %>
                            </div>
                            <p class="text-body-secondary small mb-0 d-none" data-collection-module-empty>
                              No encontré módulos con ese filtro.
                            </p>
                            <div class="d-flex justify-content-end">
                              <button class="btn btn-dark" type="submit">Agregar seleccionados</button>
                            </div>
                          </form>
                        <% } else { %>
                          <p class="mb-0 text-body-secondary">No hay más módulos activos disponibles para agregar en este perfil.</p>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'detail' && selectedPracticeModule) { %>
            <section class="practice-module-detail-shell">
              <div class="d-grid gap-3">
                <% if (selectedPracticeModule.sharedVia) { %>
                  <div>
                    <% if (selectedPracticeModuleSharedFromProfileName) { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida por <%= selectedPracticeModuleSharedFromProfileName %>
                      </span>
                    <% } else { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida <%= selectedPracticeModule.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                      </span>
                    <% } %>
                  </div>
                <% } %>

                <div class="practice-module-detail-inline-actions btn-toolbar" role="toolbar" aria-label="Acciones del módulo de práctica">
                  <div class="btn-group" role="group" aria-label="Editar módulo de práctica">
                    <a
                      class="btn btn-outline-dark"
                      href="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/edit"
                      title="Editar módulo de práctica"
                      aria-label="Editar módulo de práctica"
                    >
                      <i class="bi bi-pencil" aria-hidden="true"></i>
                    </a>
                  </div>
                  <div class="btn-group" role="group" aria-label="Compartir módulo de práctica">
                    <button
                      class="btn btn-outline-dark dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                      title="Compartir módulo de práctica"
                      aria-label="Compartir módulo de práctica"
                    >
                      <i class="bi bi-share" aria-hidden="true"></i>
                    </button>
                    <div class="dropdown-menu">
                      <button
                        class="dropdown-item"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#sharePracticeModuleProfileModal"
                      >
                        Compartir con perfil
                      </button>
                      <button
                        class="dropdown-item"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#sharePracticeModuleLinkModal"
                      >
                        Obtener enlace
                      </button>
                    </div>
                  </div>
                  <div class="btn-group" role="group" aria-label="<%= selectedPracticeModule.archivedAt ? 'Restaurar módulo de práctica' : 'Archivar módulo de práctica' %>">
                    <form
                      method="post"
                      action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/<%= selectedPracticeModule.archivedAt ? 'restore' : 'archive' %>"
                      onsubmit="return window.confirm('<%= selectedPracticeModule.archivedAt ? '¿Seguro que quieres restaurar este módulo de práctica?' : '¿Seguro que quieres archivar este módulo de práctica? Podrás recuperarlo después desde Archivados.' %>');"
                    >
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <input type="hidden" name="returnTo" value="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>">
                      <button
                        class="btn btn-outline-dark"
                        type="submit"
                        title="<%= selectedPracticeModule.archivedAt ? 'Restaurar módulo de práctica' : 'Archivar módulo de práctica' %>"
                        aria-label="<%= selectedPracticeModule.archivedAt ? 'Restaurar módulo de práctica' : 'Archivar módulo de práctica' %>"
                      >
                        <i class="bi <%= selectedPracticeModule.archivedAt ? 'bi-arrow-counterclockwise' : 'bi-archive' %>" aria-hidden="true"></i>
                      </button>
                    </form>
                  </div>
                </div>

                <p class="practiceModule-section-copy">Chats de este módulo de práctica</p>

                <form
                  class="practice-module-start-form"
                  method="post"
                  action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/chats"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-dark">Comenzar módulo de práctica</button>
                </form>

                <div class="card shadow-sm">
                  <div class="card-body d-grid gap-3">
                    <p class="practiceModule-section-copy">Colecciones</p>
                    <% if (containingCollectionsForSelectedPracticeModule.length > 0) { %>
                      <div class="d-flex flex-wrap gap-2">
                        <% containingCollectionsForSelectedPracticeModule.forEach((collection) => { %>
                          <a class="badge text-bg-light border text-decoration-none" href="/practice-modules/collections/<%= encodeURIComponent(collection.id) %>">
                            <%= collection.title %>
                          </a>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <p class="mb-0 text-body-secondary">Este módulo todavía no pertenece a ninguna colección.</p>
                    <% } %>
                  </div>
                </div>

                <% if (practiceModuleConversations.length > 0) { %>
                  <div class="practice-module-chat-list list-group shadow-sm">
                    <% practiceModuleConversations.forEach((conversation) => { %>
                      <a
                        class="practice-module-chat-item list-group-item list-group-item-action d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-1"
                        href="/c/<%= encodeURIComponent(conversation.id) %>"
                      >
                        <span class="practice-module-chat-title"><%= conversation.title %></span>
                        <time class="practice-module-chat-date" datetime="<%= conversation.updatedAt %>">
                          <%= conversation.updatedAt %>
                        </time>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="practice-module-empty mb-0">Todavía no hay chats para este módulo de práctica.</p>
                <% } %>
              </div>
            </section>
          <% } %>

          <% if (practiceModulePageMode === 'list') { %>
            <div class="d-flex flex-wrap gap-2 mb-4">
              <a class="btn btn-dark" href="/practice-modules/new">
                Nuevo módulo de práctica
              </a>
              <a class="btn btn-outline-dark" href="/practice-modules/collections/new">
                Nueva colección
              </a>
            </div>

            <form class="practiceModule-filter-form" method="get" action="/practice-modules" role="search">
              <div class="practice-module-filter-input-wrap">
                <input
                  class="form-control practice-module-filter-input"
                  type="search"
                  name="q"
                  value="<%= practiceModuleFilterQuery || '' %>"
                  placeholder="Filtrar módulos de práctica por texto"
                  aria-label="Filtrar módulos de práctica por texto"
                >
                <% if (practiceModuleFilterQuery) { %>
                  <a class="practice-module-filter-clear" href="/practice-modules" aria-label="Limpiar filtro">
                    Limpiar
                  </a>
                <% } %>
              </div>
            </form>

            <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
              <a
                class="btn <%= showArchivedPracticeModules ? 'btn-dark' : 'btn-outline-dark' %> btn-sm"
                href="<%= showArchivedPracticeModules ? '/practice-modules' : `/practice-modules${practiceModuleFilterQuery ? `?q=${encodeURIComponent(practiceModuleFilterQuery)}&archived=1` : '?archived=1'}` %>"
              >
                <i class="bi <%= showArchivedPracticeModules ? 'bi-archive-fill' : 'bi-archive' %>" aria-hidden="true"></i>
                <span class="ms-1"><%= showArchivedPracticeModules ? 'Ocultar archivadas' : 'Ver archivadas' %></span>
              </a>
            </div>
          <% } %>

          <% if (practiceModulePageMode === 'collectionNew') { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body">
                  <form
                    class="practice-module-form"
                    method="post"
                    action="/practice-modules/collections"
                    autocomplete="off"
                  >
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <label class="form-label" for="practiceModuleCollectionTitle">Título</label>
                    <input
                      class="form-control"
                      id="practiceModuleCollectionTitle"
                      name="title"
                      maxlength="120"
                      value=""
                      required
                    >

                    <label class="form-label" for="practiceModuleCollectionDescription">Descripción</label>
                    <textarea
                      class="form-control"
                      id="practiceModuleCollectionDescription"
                      name="description"
                      rows="4"
                      maxlength="500"
                    ></textarea>

                    <div class="practice-module-form-actions">
                      <button type="submit" class="btn btn-dark">Crear colección</button>
                    </div>
                  </form>
                </div>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'new' || practiceModulePageMode === 'edit') { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body">
                <form
                  class="practice-module-form"
                  method="post"
                  action="<%= practiceModulePageMode === 'edit' && selectedPracticeModule ? `/practice-modules/${encodeURIComponent(selectedPracticeModule.id)}` : '/practice-modules' %>"
                  autocomplete="off"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                  <label class="form-label" for="practiceModuleTitle">
                    Título
                  </label>
                  <input
                    class="form-control"
                    id="practiceModuleTitle"
                    name="title"
                    maxlength="120"
                    value="<%= practiceModulePageMode === 'edit' && selectedPracticeModule ? selectedPracticeModule.title : '' %>"
                    required
                  >

                  <label class="form-label" for="practiceModuleDescription">
                    Descripción
                  </label>
                  <textarea
                    class="form-control"
                    id="practiceModuleDescription"
                    name="description"
                    rows="4"
                    maxlength="500"
                    required
                  ><%= practiceModulePageMode === 'edit' && selectedPracticeModule ? selectedPracticeModule.description : '' %></textarea>

                  <div class="practice-module-help-row">
                    <label class="form-label" for="practiceModuleTutorInstructions">
                      Instrucciones al tutor
                    </label>
                    <button
                      class="btn btn-link practice-module-help-button"
                      type="button"
                      data-bs-toggle="modal"
                      data-bs-target="#practiceModuleHelpModal"
                    >
                      Ayuda
                    </button>
                  </div>
                  <textarea
                    class="form-control"
                    id="practiceModuleTutorInstructions"
                    name="tutorInstructions"
                    rows="10"
                    maxlength="4000"
                    required
                  ><%= practiceModulePageMode === 'edit' && selectedPracticeModule ? selectedPracticeModule.tutorInstructions : '' %></textarea>

                  <div class="practice-module-form-actions">
                    <button type="submit" class="btn btn-dark">
                      <%= practiceModulePageMode === 'edit' ? 'Guardar cambios' : 'Crear módulo de práctica' %>
                    </button>
                  </div>
                </form>
                </div>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'share' && selectedSharedPracticeModule && selectedPracticeModuleShareLink) { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body">
                  <div class="d-grid gap-3">
                    <p class="mb-0 text-body-secondary">
                      <% if (activeProfile) { %>
                        Este módulo de práctica fue compartido contigo. Revísalo y decide si quieres importarlo al perfil <strong><%= activeProfile.name %></strong>.
                      <% } else { %>
                        Este módulo de práctica fue compartido contigo. Puedes revisarlo ahora mismo y, si te interesa, iniciar sesión o crear una cuenta para importarlo.
                      <% } %>
                    </p>
                    <div class="d-flex justify-content-end gap-2">
                      <a class="btn btn-link" href="<%= isAuthenticated ? '/practice-modules' : '/' %>">No ahora</a>
                      <% if (isAuthenticated && activeProfile) { %>
                        <form method="post" action="/practice-modules/shared/<%= encodeURIComponent(selectedPracticeModuleShareLink.id) %>/accept">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-dark" type="submit">Importar módulo</button>
                        </form>
                      <% } else { %>
                        <a class="btn btn-outline-dark" href="/signup?returnTo=<%= encodeURIComponent(`/practice-modules/shared/${selectedPracticeModuleShareLink.id}`) %>">Crear cuenta</a>
                        <a class="btn btn-dark" href="/login?returnTo=<%= encodeURIComponent(`/practice-modules/shared/${selectedPracticeModuleShareLink.id}`) %>">Iniciar sesión</a>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'collectionShare' && selectedSharedPracticeModuleCollection && selectedPracticeModuleCollectionShareLink) { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body">
                  <div class="d-grid gap-3">
                    <p class="mb-0 text-body-secondary">
                      <% if (activeProfile) { %>
                        Esta colección fue compartida contigo. Revísala y decide si quieres importarla al perfil <strong><%= activeProfile.name %></strong>.
                      <% } else { %>
                        Esta colección fue compartida contigo. Puedes revisarla ahora mismo y, si te interesa, iniciar sesión o crear una cuenta para importarla.
                      <% } %>
                    </p>
                    <% if (practiceModuleCollectionModules.length > 0) { %>
                      <div class="list-group shadow-sm">
                        <% practiceModuleCollectionModules.forEach((entry) => { %>
                          <div class="list-group-item">
                            <div class="d-flex align-items-start gap-2">
                              <span class="badge text-bg-light border">#<%= entry.position %></span>
                              <div class="min-w-0">
                                <div class="fw-semibold"><%= entry.practiceModule.title %></div>
                                <p class="mb-0 text-body-secondary small"><%= entry.practiceModule.description %></p>
                              </div>
                            </div>
                          </div>
                        <% }) %>
                      </div>
                    <% } %>
                    <div class="d-flex justify-content-end gap-2">
                      <a class="btn btn-link" href="<%= isAuthenticated ? '/practice-modules' : '/' %>">No ahora</a>
                      <% if (isAuthenticated && activeProfile) { %>
                        <form method="post" action="/practice-modules/collections/shared/<%= encodeURIComponent(selectedPracticeModuleCollectionShareLink.id) %>/accept">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-dark" type="submit">Importar colección</button>
                        </form>
                      <% } else { %>
                        <a class="btn btn-outline-dark" href="/signup?returnTo=<%= encodeURIComponent(`/practice-modules/collections/shared/${selectedPracticeModuleCollectionShareLink.id}`) %>">Crear cuenta</a>
                        <a class="btn btn-dark" href="/login?returnTo=<%= encodeURIComponent(`/practice-modules/collections/shared/${selectedPracticeModuleCollectionShareLink.id}`) %>">Iniciar sesión</a>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'list') { %>
            <% if (practiceModuleCollections.length > 0 || favoritePracticeModuleCollections.length > 0 || favoritePracticeModules.length > 0 || practiceModules.length > 0 || sharedLessons.length > 0 || archivedPracticeModules.length > 0 || archivedPracticeModuleCollections.length > 0) { %>
              <% if (favoritePracticeModuleCollections.length > 0 || favoritePracticeModules.length > 0) { %>
                <div class="d-flex align-items-center justify-content-between mb-3">
                  <h2 class="h5 mb-0">Favoritos</h2>
                  <span class="badge text-bg-light border"><%= favoritePracticeModuleCollections.length + favoritePracticeModules.length %></span>
                </div>
                <div class="practice-modules-grid mb-4">
                  <% favoritePracticeModuleCollections.forEach((collection) => { %>
                    <article class="practice-module-card card shadow-sm h-100">
                      <div class="card-body d-grid gap-2">
                        <div class="practice-module-card-meta">
                          <p class="practice-module-card-kicker mb-0">Colección</p>
                          <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">
                            <%= collection.moduleCount %> <%= collection.moduleCount === 1 ? 'módulo' : 'módulos' %>
                          </span>
                        </div>
                        <h2 class="h4 practice-module-card-title">
                          <a
                            class="practice-module-card-link text-decoration-none text-reset"
                            href="/practice-modules/collections/<%= encodeURIComponent(collection.id) %>"
                          >
                            <%= collection.title %>
                          </a>
                        </h2>
                        <p class="mb-0 text-body-secondary"><%= collection.description || 'Agrupa varios módulos de práctica bajo un mismo tema o propósito.' %></p>
                        <% if (collection.sourceProfileName) { %>
                          <p class="mb-0 text-body-secondary small">Compartida por <%= collection.sourceProfileName %></p>
                        <% } %>
                        <div class="practice-module-card-actions btn-group mt-2" role="group" aria-label="Acciones rápidas">
                          <div class="dropdown">
                            <button
                              class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0"
                              type="button"
                              data-bs-toggle="dropdown"
                              aria-expanded="false"
                              title="Compartir colección"
                              aria-label="Compartir colección"
                            >
                              <i class="bi bi-share" aria-hidden="true"></i>
                            </button>
                            <div class="dropdown-menu">
                              <a class="dropdown-item" href="/practice-modules/collections/<%= encodeURIComponent(collection.id) %>?share=profile">Compartir con perfil</a>
                              <a class="dropdown-item" href="/practice-modules/collections/<%= encodeURIComponent(collection.id) %>?share=link">Obtener enlace</a>
                            </div>
                          </div>
                          <form method="post" action="/practice-modules/collections/<%= encodeURIComponent(collection.id) %>/favorite">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="favorite" value="0">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Quitar de favoritas" aria-label="Quitar de favoritas">
                              <i class="bi bi-star-fill" aria-hidden="true"></i>
                            </button>
                          </form>
                          <form method="post" action="/practice-modules/collections/<%= encodeURIComponent(collection.id) %>/archive">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Archivar colección" aria-label="Archivar colección">
                              <i class="bi bi-archive" aria-hidden="true"></i>
                            </button>
                          </form>
                        </div>
                      </div>
                    </article>
                  <% }) %>
                  <% favoritePracticeModules.forEach((practiceModule) => { %>
                    <article class="practice-module-card card shadow-sm h-100">
                      <div class="card-body d-grid gap-2">
                        <div class="practice-module-card-meta">
                          <div class="d-flex align-items-center gap-2 flex-wrap">
                            <p class="practice-module-card-kicker mb-0">Módulo de práctica</p>
                            <% if (practiceModule.archivedAt) { %>
                              <span class="badge text-bg-light border">Archivado</span>
                            <% } %>
                          </div>
                          <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">
                            <%= practiceModule.conversationCount %> <%= practiceModule.conversationCount === 1 ? 'chat' : 'chats' %>
                          </span>
                        </div>
