<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="stylesheet" href="/vendor/bootswatch/journal/bootstrap.min.css">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/public/css/app.css">
  </head>
  <body
    data-authenticated="<%= isAuthenticated ? 'true' : 'false' %>"
    data-socket-auth-token="<%= socketAuthToken %>"
    data-auth-message="<%= authMessage %>"
    data-guest-initial-greeting="<%= guestInitialGreeting %>"
    data-initial-conversation-id="<%= initialConversationId || '' %>"
    data-chat-mode="<%= chatMode %>"
    data-current-view="<%= currentView %>"
  >
    <main class="app-shell">
      <div class="chat-workspace <%= hasSession ? 'has-toolbar' : '' %>">
        <% if (hasSession) { %>
          <div class="chat-toolbar" aria-label="Controles del chat">
            <button
              class="btn btn-link chat-menu-button"
              type="button"
              data-bs-toggle="offcanvas"
              data-bs-target="#conversationPanel"
              aria-controls="conversationPanel"
              title="Conversaciones"
              aria-label="Conversaciones"
            >
              <i class="bi bi-list fs-4" aria-hidden="true"></i>
            </button>

            <button
              class="btn btn-link translator-button"
              type="button"
              data-bs-toggle="modal"
              data-bs-target="#translatorModal"
              data-open-translator
              title="Traductor"
              aria-label="Traductor"
            >
              <i class="bi bi-translate fs-5" aria-hidden="true"></i>
            </button>
          </div>

          <aside
            class="offcanvas offcanvas-start conversation-panel"
            tabindex="-1"
            id="conversationPanel"
            aria-label="Panel lateral"
          >
            <div class="offcanvas-header">
              <a
                class="panel-home-link"
                href="/"
                title="Ir al inicio"
                aria-label="Ir al inicio"
              >
                <i class="bi bi-house-door fs-5" aria-hidden="true"></i>
              </a>
              <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
            </div>
            <div class="offcanvas-body">
              <div class="panel-nav">
                <a class="panel-nav-link" href="/" data-new-conversation>
                  <i class="bi bi-pencil-square" aria-hidden="true"></i>
                  Nueva conversación
                </a>

                <a class="panel-nav-link <%= currentView === 'lessons' ? 'is-active' : '' %>" href="/lessons">
                  <i class="bi bi-folder" aria-hidden="true"></i>
                  Lecciones
                </a>
              </div>

              <div class="panel-recents">
                <p class="panel-section-label">Recientes</p>

                <% if (conversations.length > 0) { %>
                  <div class="conversation-list">
                    <% conversations.forEach((conversation) => { %>
                      <div
                        class="conversation-item"
                        data-conversation-id="<%= conversation.id %>"
                      >
                        <a
                          class="conversation-open-button"
                          href="/c/<%= encodeURIComponent(conversation.id) %>"
                          data-open-conversation
                        >
                          <span class="conversation-title"><%= conversation.title %></span>
                          <time class="conversation-date" datetime="<%= conversation.updatedAt %>">
                            <%= conversation.updatedAt %>
                          </time>
                        </a>

                        <div class="conversation-actions dropdown">
                          <button
                            class="btn btn-link conversation-actions-button"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            title="Opciones de conversación"
                            aria-label="Opciones de conversación"
                          >
                            <i class="bi bi-three-dots" aria-hidden="true"></i>
                          </button>
                          <div class="dropdown-menu dropdown-menu-end conversation-actions-menu">
                            <button class="dropdown-item" type="button" data-rename-conversation>Renombrar</button>
                            <button class="dropdown-item text-danger" type="button" data-delete-conversation>Eliminar</button>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="conversation-empty">Todavía no hay conversaciones.</p>
                <% } %>
              </div>

              <div class="panel-bottom">
                <div class="user-menu dropdown">
                  <button
                    class="btn btn-link panel-nav-link user-panel-button"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    title="<%= activeProfile ? activeProfile.name : 'Perfil' %>"
                    aria-label="<%= activeProfile ? activeProfile.name : 'Perfil' %>"
                  >
                    <i class="bi bi-person-circle" aria-hidden="true"></i>
                    <%= activeProfile ? activeProfile.name : 'Perfil' %>
                  </button>

                  <div class="dropdown-menu user-menu-panel">
                    <% if (activeProfile) { %>
                      <p class="user-menu-email"><strong><%= activeProfile.name %></strong></p>
                    <% } %>
                    <p class="user-menu-email"><%= user.email %></p>
                    <a class="dropdown-item" href="/profiles">Cambiar perfil</a>
                    <a class="dropdown-item" href="/change-password">Cambiar contraseña</a>
                    <form method="post" action="/logout">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="dropdown-item" type="submit">Cerrar sesión</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </aside>

          <div
            class="modal fade"
            id="deleteConversationModal"
            tabindex="-1"
            aria-labelledby="deleteConversationModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content delete-conversation-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="deleteConversationModalLabel">Eliminar chat</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <p class="mb-0">
                    ¿Seguro que quieres eliminar “<span data-delete-conversation-title></span>”?
                    Esta acción no se puede deshacer.
                  </p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cancelar</button>
                  <button type="button" class="btn btn-danger" data-confirm-delete-conversation>Eliminar</button>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="translatorModal"
            tabindex="-1"
            aria-labelledby="translatorModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content translator-modal">
                <form id="translatorForm" autocomplete="off">
                  <div class="modal-header">
                    <h2 class="modal-title fs-5" id="translatorModalLabel">Traductor</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                  </div>
                  <div class="modal-body">
                    <div class="translator-mode btn-group" role="group" aria-label="Modo de traducción">
                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeAuto" value="auto" checked>
                      <label class="btn btn-outline-dark" for="translatorModeAuto">Auto</label>

                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeEsEn" value="es-en">
                      <label class="btn btn-outline-dark" for="translatorModeEsEn">ES → EN</label>

                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeEnEs" value="en-es">
                      <label class="btn btn-outline-dark" for="translatorModeEnEs">EN → ES</label>
                    </div>

                    <label class="visually-hidden" for="translatorInput">Texto para traducir</label>
                    <div class="translator-box">
                      <textarea
                        class="form-control translator-textarea"
                        id="translatorInput"
                        rows="5"
                        maxlength="2000"
                        autocomplete="off"
                        autocapitalize="none"
                        autocorrect="off"
                        spellcheck="false"
                      ></textarea>
                      <button
                        class="translator-copy-button"
                        type="button"
                        data-translator-copy="input"
                        title="Copiar texto"
                        aria-label="Copiar texto"
                      >
                        <i class="bi bi-copy" aria-hidden="true"></i>
                      </button>
                    </div>

                    <div class="translator-box translator-result-box">
                      <div class="translator-result" id="translatorResult" aria-live="polite"></div>
                      <button
                        class="translator-copy-button"
                        type="button"
                        data-translator-copy="result"
                        title="Copiar traducción"
                        aria-label="Copiar traducción"
                      >
                        <i class="bi bi-copy" aria-hidden="true"></i>
                      </button>
                    </div>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-dark" data-translator-submit>Traducir</button>
                  </div>
                </form>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="creditModal"
            tabindex="-1"
            aria-labelledby="creditModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content credit-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="creditModalLabel">Crédito agotado</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <p class="mb-0" data-credit-message>
                    Tu crédito de práctica se agotó por ahora.
                  </p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Entendido</button>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="lessonHelpModal"
            tabindex="-1"
            aria-labelledby="lessonHelpModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered modal-lg">
              <div class="modal-content translator-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="lessonHelpModalLabel">Qué puede hacer el tutor</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body lesson-help-modal-body">
                  <section class="lesson-help-section">
                    <h3>Tipos de práctica que puedes pedir</h3>
                    <ul>
                      <li>Traducir del español al inglés con corrección guiada.</li>
                      <li>Comprender frases en inglés y explicarlas en español.</li>
                      <li>Mini-conversaciones o role-play con personajes ficticios.</li>
                      <li>Emparejar columnas de palabras, frases o significados.</li>
                      <li>Completar espacios escribiendo o eligiendo opciones.</li>
                      <li>Multiple choice de una o varias respuestas correctas.</li>
                      <li>Ordenar palabras para reconstruir una oración.</li>
                    </ul>
                  </section>

                  <section class="lesson-help-section">
                    <h3>Ejemplos de instrucciones útiles</h3>
                    <ul>
                      <li>Practica vocabulario de colores con ejercicios variados y mucha corrección paciente.</li>
                      <li>Haz mini-conversaciones de restaurante para un nivel básico, con tono amable y situaciones realistas.</li>
                      <li>Trabaja el pasado simple con frases cortas, completar espacios y multiple choice.</li>
                      <li>Enfócate en inglés para entrevistas de trabajo con tono formal y correcciones claras.</li>
                    </ul>
                  </section>

                  <section class="lesson-help-section">
                    <h3>Buenas prácticas</h3>
                    <ul>
                      <li>Especifica el tema, el tipo de situación y el nivel aproximado.</li>
                      <li>Puedes combinar varias dinámicas dentro de una misma lección.</li>
                      <li>No hace falta describir la interfaz; describe el objetivo pedagógico.</li>
                      <li>Puedes decir si quieres que el tutor sea más paciente, más exigente o más conversacional.</li>
                    </ul>
                  </section>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Entendido</button>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <section
          class="lessons-view <%= currentView === 'lessons' ? '' : 'd-none' %>"
          aria-label="Lecciones"
        >
          <div class="lessons-header <%= lessonPageMode === 'detail' ? 'lessons-header-detail' : '' %> <%= lessonPageMode !== 'list' ? 'lessons-header-has-close' : '' %>">
            <div>
              <p class="lessons-kicker">Lecciones</p>
              <h1 class="lessons-title">
                <% if (lessonPageMode === 'new') { %>
                  Nueva lección
                <% } else if (lessonPageMode === 'edit') { %>
                  Editar lección
                <% } else if (lessonPageMode === 'share') { %>
                  <%= selectedSharedLesson ? selectedSharedLesson.title : 'Lección compartida' %>
                <% } else { %>
                  <%= selectedLesson ? selectedLesson.title : 'Biblioteca de lecciones' %>
                <% } %>
              </h1>
              <p class="lessons-copy">
                <% if (lessonPageMode === 'new') { %>
                  Diseña una lección con un objetivo claro, una descripción útil y una guía precisa para el tutor.
                <% } else if (lessonPageMode === 'edit') { %>
                  Ajusta esta lección con calma. Los chats existentes conservarán su propia copia de la lección original.
                <% } else if (lessonPageMode === 'share') { %>
                  <%= selectedSharedLesson ? selectedSharedLesson.description : 'Te compartieron una lección.' %>
                <% } else { %>
                  <%= selectedLesson ? selectedLesson.description : 'Crea experiencias guiadas para el tutor con un objetivo claro, una descripción y reglas propias.' %>
                <% } %>
              </p>

              <% if (lessonPageMode === 'detail' && selectedLesson) { %>
                <% if (selectedLesson.sharedVia) { %>
                  <div class="mt-3">
                    <% if (selectedLessonSharedFromProfileName) { %>
                      <span class="badge text-bg-light border lesson-shared-badge" role="status">
                        Compartida por <%= selectedLessonSharedFromProfileName %>
                      </span>
                    <% } else { %>
                      <span class="badge text-bg-light border lesson-shared-badge" role="status">
                        Compartida <%= selectedLesson.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                      </span>
                    <% } %>
                  </div>
                <% } %>

                <div class="lesson-detail-inline-actions btn-toolbar" role="toolbar" aria-label="Acciones de la lección">
                  <div class="btn-group" role="group" aria-label="Editar lección">
                    <a
                      class="btn btn-outline-dark"
                      href="/lessons/<%= encodeURIComponent(selectedLesson.id) %>/edit"
                      title="Editar lección"
                      aria-label="Editar lección"
                    >
                      <i class="bi bi-pencil" aria-hidden="true"></i>
                    </a>
                  </div>
                  <div class="btn-group" role="group" aria-label="Compartir lección">
                    <button
                      class="btn btn-outline-dark dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                      title="Compartir lección"
                      aria-label="Compartir lección"
                    >
                      <i class="bi bi-share" aria-hidden="true"></i>
                    </button>
                    <div class="dropdown-menu">
                      <button
                        class="dropdown-item"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#shareLessonProfileModal"
                      >
                        Compartir con perfil
                      </button>
                      <button
                        class="dropdown-item"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#shareLessonLinkModal"
                      >
                        Obtener enlace
                      </button>
                    </div>
                  </div>
                  <div class="btn-group" role="group" aria-label="Eliminar lección">
                    <form
                      method="post"
                      action="/lessons/<%= encodeURIComponent(selectedLesson.id) %>/delete"
                      onsubmit="return window.confirm('¿Seguro que quieres eliminar esta lección? Los chats existentes conservarán su copia histórica, pero la lección ya no aparecerá en la biblioteca.');"
                    >
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button
                        class="btn btn-outline-danger"
                        type="submit"
                        title="Eliminar lección"
                        aria-label="Eliminar lección"
                      >
                        <i class="bi bi-trash" aria-hidden="true"></i>
                      </button>
                    </form>
                  </div>
                </div>

                <p class="lesson-section-copy">Chats de esta lección</p>

                <form
                  class="lesson-start-form"
                  method="post"
                  action="/lessons/<%= encodeURIComponent(selectedLesson.id) %>/chats"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-dark">Comenzar lección</button>
                </form>

                <% if (lessonConversations.length > 0) { %>
                  <div class="lesson-chat-list list-group shadow-sm">
                    <% lessonConversations.forEach((conversation) => { %>
                      <a
                        class="lesson-chat-item list-group-item list-group-item-action d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-1"
                        href="/c/<%= encodeURIComponent(conversation.id) %>"
                      >
                        <span class="lesson-chat-title"><%= conversation.title %></span>
                        <time class="lesson-chat-date" datetime="<%= conversation.updatedAt %>">
                          <%= conversation.updatedAt %>
                        </time>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="lesson-empty">Todavía no hay chats para esta lección.</p>
                <% } %>
              <% } %>
            </div>

            <% if (hasSession) { %>
              <div class="lessons-header-actions">
                <% if (lessonPageMode === 'new' || lessonPageMode === 'edit' || lessonPageMode === 'detail' || lessonPageMode === 'share') { %>
                  <a
                    class="btn-close lesson-close-button"
                    href="<%= lessonPageMode === 'detail' || lessonPageMode === 'share' ? '/lessons' : selectedLesson ? `/lessons/${encodeURIComponent(selectedLesson.id)}` : '/lessons' %>"
                    title="Cerrar"
                    aria-label="Cerrar"
                  ></a>
                <% } %>
                <% if (lessonPageMode === 'list') { %>
                  <a class="btn btn-dark" href="/lessons/new">
                    Nueva lección
                  </a>
                <% } %>
              </div>
            <% } %>
          </div>

          <% if (lessonPageMode === 'list') { %>
            <form class="lesson-filter-form" method="get" action="/lessons" role="search">
              <div class="lesson-filter-input-wrap">
                <input
                  class="form-control lesson-filter-input"
                  type="search"
                  name="q"
                  value="<%= lessonFilterQuery || '' %>"
                  placeholder="Filtrar lecciones por texto"
                  aria-label="Filtrar lecciones por texto"
                >
                <% if (lessonFilterQuery) { %>
                  <a class="lesson-filter-clear" href="/lessons" aria-label="Limpiar filtro">
                    Limpiar
                  </a>
                <% } %>
              </div>
            </form>
          <% } %>

          <% if (lessonPageMode === 'new' || lessonPageMode === 'edit') { %>
            <section class="lesson-form-shell">
              <div class="lesson-form-card card shadow-sm">
                <div class="card-body">
                <form
                  class="lesson-form"
                  method="post"
                  action="<%= lessonPageMode === 'edit' && selectedLesson ? `/lessons/${encodeURIComponent(selectedLesson.id)}` : '/lessons' %>"
                  autocomplete="off"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                  <label class="form-label" for="lessonTitle">
                    Título
                  </label>
                  <input
                    class="form-control"
                    id="lessonTitle"
                    name="title"
                    maxlength="120"
                    value="<%= lessonPageMode === 'edit' && selectedLesson ? selectedLesson.title : '' %>"
                    required
                  >

                  <label class="form-label" for="lessonDescription">
                    Descripción
                  </label>
                  <textarea
                    class="form-control"
                    id="lessonDescription"
                    name="description"
                    rows="4"
                    maxlength="500"
                    required
                  ><%= lessonPageMode === 'edit' && selectedLesson ? selectedLesson.description : '' %></textarea>

                  <div class="lesson-help-row">
                    <label class="form-label" for="lessonTutorInstructions">
                      Instrucciones al tutor
                    </label>
                    <button
                      class="btn btn-link lesson-help-button"
                      type="button"
                      data-bs-toggle="modal"
                      data-bs-target="#lessonHelpModal"
                    >
                      Ayuda
                    </button>
                  </div>
                  <textarea
                    class="form-control"
                    id="lessonTutorInstructions"
                    name="tutorInstructions"
                    rows="10"
                    maxlength="4000"
                    required
                  ><%= lessonPageMode === 'edit' && selectedLesson ? selectedLesson.tutorInstructions : '' %></textarea>

                  <div class="lesson-form-actions">
                    <button type="submit" class="btn btn-dark">
                      <%= lessonPageMode === 'edit' ? 'Guardar cambios' : 'Crear lección' %>
                    </button>
                  </div>
                </form>
                </div>
              </div>
            </section>
          <% } else if (lessonPageMode === 'share' && selectedSharedLesson && selectedLessonShareLink) { %>
            <section class="lesson-form-shell">
              <div class="lesson-form-card card shadow-sm">
                <div class="card-body">
                  <div class="d-grid gap-3">
                    <div>
                      <p class="mb-2 text-body-secondary">Revisa la lección y decide si quieres importarla a tu perfil activo.</p>
                      <dl class="mb-0">
                        <dt class="small text-uppercase text-body-secondary">Título</dt>
                        <dd class="mb-3"><%= selectedSharedLesson.title %></dd>
                        <dt class="small text-uppercase text-body-secondary">Descripción</dt>
                        <dd class="mb-3"><%= selectedSharedLesson.description %></dd>
                        <dt class="small text-uppercase text-body-secondary">Tipo</dt>
                        <dd class="mb-0">
                          <% if (selectedSharedLesson.sharedVia) { %>
                            Compartida originalmente por <%= selectedSharedLesson.sharedVia === 'link' ? 'enlace' : 'perfil' %>
                          <% } else { %>
                            Lección compartida
                          <% } %>
                        </dd>
                      </dl>
                    </div>
                  </div>
                </div>
              </div>
            </section>
          <% } else if (lessonPageMode === 'list') { %>
            <% if (lessons.length > 0 || sharedLessons.length > 0) { %>
              <% if (lessons.length > 0) { %>
                <div class="d-flex align-items-center justify-content-between mb-3">
                  <h2 class="h5 mb-0">Tus lecciones</h2>
                  <span class="badge text-bg-light border"><%= lessons.length %></span>
                </div>
                <div class="lessons-grid">
                  <% lessons.forEach((lesson) => { %>
                    <article class="lesson-card card shadow-sm h-100">
                      <div class="card-body d-grid gap-2">
                        <div class="lesson-card-meta">
                          <p class="lesson-card-kicker">Lección</p>
                          <span class="badge rounded-pill text-bg-light border lesson-chat-count-badge">
                            <%= lesson.conversationCount %> <%= lesson.conversationCount === 1 ? 'chat' : 'chats' %>
                          </span>
                        </div>
                        <h2 class="h4">
                          <a
                            class="stretched-link text-decoration-none text-reset"
                            href="/lessons/<%= encodeURIComponent(lesson.id) %>"
                          >
                            <%= lesson.title %>
                          </a>
                        </h2>
                        <p class="mb-0 text-body-secondary"><%= lesson.description %></p>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>

              <% if (sharedLessons.length > 0) { %>
                <div class="d-flex align-items-center justify-content-between mb-3 mt-4">
                  <h2 class="h5 mb-0">Compartidas contigo</h2>
                  <span class="badge text-bg-light border"><%= sharedLessons.length %></span>
                </div>
                <div class="lessons-grid">
                  <% sharedLessons.forEach((lesson) => { %>
                    <article class="lesson-card card shadow-sm h-100">
                      <div class="card-body d-grid gap-2">
                        <div class="lesson-card-meta">
                          <p class="lesson-card-kicker">Compartida</p>
                          <span class="badge rounded-pill text-bg-light border lesson-chat-count-badge">
                            <%= lesson.conversationCount %> <%= lesson.conversationCount === 1 ? 'chat' : 'chats' %>
                          </span>
                        </div>
                        <h2 class="h4">
                          <a
                            class="stretched-link text-decoration-none text-reset"
                            href="/lessons/<%= encodeURIComponent(lesson.id) %>"
                          >
                            <%= lesson.title %>
                          </a>
                        </h2>
                        <p class="mb-0 text-body-secondary"><%= lesson.description %></p>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>
            <% } else { %>
              <div class="lesson-empty-state alert alert-light border">
                <p>
                  <%= lessonFilterQuery
                    ? 'No encontré lecciones que coincidan con ese texto.'
                    : 'Todavía no hay lecciones. Crea la primera y dale un marco propio al tutor.' %>
                </p>
              </div>
            <% } %>
          <% } %>
        </section>

        <% if (currentView === 'lessons' && lessonPageMode === 'detail' && selectedLesson) { %>
          <div
            class="modal fade"
            id="shareLessonProfileModal"
            tabindex="-1"
            aria-labelledby="shareLessonProfileModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="shareLessonProfileModalLabel">Compartir con perfil</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <% if (shareTargetProfiles.length > 0) { %>
                    <form method="post" action="/lessons/<%= encodeURIComponent(selectedLesson.id) %>/share/profile" class="d-grid gap-3">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <div>
                        <label class="form-label" for="shareTargetProfileId">Perfil destino</label>
                        <select class="form-select" id="shareTargetProfileId" name="targetProfileId" required>
                          <% shareTargetProfiles.forEach((profile) => { %>
                            <option value="<%= profile.id %>"><%= profile.name %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-dark">Compartir ahora</button>
                      </div>
                    </form>
                  <% } else { %>
                    <p class="mb-0 text-body-secondary">No tienes otros perfiles disponibles para recibir esta lección.</p>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="shareLessonLinkModal"
            tabindex="-1"
            aria-labelledby="shareLessonLinkModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="shareLessonLinkModalLabel">Enlace para compartir</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body d-grid gap-3">
                  <div>
                    <label class="form-label" for="lessonShareLinkField">Enlace</label>
                    <input
                      class="form-control"
                      id="lessonShareLinkField"
                      type="text"
                      readonly
                      value="<%= lessonShareUrl %>"
                      data-lesson-share-link-field
                    >
                  </div>
                  <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-dark" type="button" data-copy-lesson-share-link>
                      <i class="bi bi-copy me-1" aria-hidden="true"></i>
                      Copiar
                    </button>
                    <button class="btn btn-outline-dark" type="button" data-native-share-lesson-link>
                      <i class="bi bi-share me-1" aria-hidden="true"></i>
                      Compartir
                    </button>
                  </div>
                  <% if (lessonShareQrDataUrl) { %>
                    <div class="d-flex justify-content-center">
                      <img
                        class="lesson-share-qr"
                        src="<%= lessonShareQrDataUrl %>"
                        alt="QR del enlace para compartir la lección"
                        width="180"
                        height="180"
                      >
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <% if (currentView === 'lessons' && lessonPageMode === 'share' && selectedSharedLesson && selectedLessonShareLink) { %>
          <div
            class="modal fade"
            id="acceptSharedLessonModal"
            tabindex="-1"
            aria-labelledby="acceptSharedLessonModalLabel"
            aria-hidden="true"
            data-auto-open-share-modal
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="acceptSharedLessonModalLabel">Aceptar lección compartida</h2>
                  <a class="btn-close" href="/lessons" aria-label="Cerrar"></a>
                </div>
                <div class="modal-body d-grid gap-3">
                  <p class="mb-0">
                    <% if (activeProfile) { %>
                      ¿Quieres importar esta lección al perfil <strong><%= activeProfile.name %></strong>?
                    <% } else { %>
                      Inicia sesión para importar esta lección a uno de tus perfiles.
                    <% } %>
                  </p>
                  <div class="d-flex justify-content-end gap-2">
                    <a class="btn btn-link" href="/lessons">No ahora</a>
                    <% if (isAuthenticated && activeProfile) { %>
                      <form method="post" action="/lessons/shared/<%= encodeURIComponent(selectedLessonShareLink.id) %>/accept">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-dark" type="submit">Aceptar</button>
                      </form>
                    <% } else { %>
                      <a class="btn btn-dark" href="/login">Iniciar sesión</a>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <section
          class="lessons-view <%= currentView === 'profiles' ? '' : 'd-none' %>"
          aria-label="Perfiles"
        >
          <div class="lessons-header <%= profilePageMode !== 'list' ? 'lessons-header-has-close' : '' %>">
            <div>
              <p class="lessons-kicker">Perfiles</p>
              <h1 class="lessons-title">
                <% if (profilePageMode === 'new') { %>
                  Nuevo perfil
                <% } else if (profilePageMode === 'edit') { %>
                  Editar perfil
                <% } else { %>
                  Cambiar perfil
                <% } %>
              </h1>
              <p class="lessons-copy">
                <% if (profilePageMode === 'new') { %>
                  Crea un perfil separado para organizar conversaciones y lecciones sin mezclarlas con las demás.
                <% } else if (profilePageMode === 'edit' && selectedProfile) { %>
                  Ajusta el nombre y la descripción de este perfil.
                <% } else { %>
                  Cada perfil mantiene separadas sus conversaciones y lecciones.
                <% } %>
              </p>
            </div>

            <% if (hasSession) { %>
              <div class="lessons-header-actions">
                <% if (profilePageMode === 'list') { %>
                  <a class="btn btn-dark" href="/profiles/new">
                    Crear perfil
                  </a>
                <% } else { %>
                  <a
                    class="btn-close lesson-close-button"
                    href="/profiles"
                    title="Cerrar"
                    aria-label="Cerrar"
                  ></a>
                <% } %>
              </div>
            <% } %>
          </div>

          <% if (profilePageMode === 'new' || profilePageMode === 'edit') { %>
            <section class="lesson-form-shell">
              <div class="lesson-form-card card shadow-sm">
                <div class="card-body">
                <form
                  class="lesson-form"
                  method="post"
                  action="<%= profilePageMode === 'edit' && selectedProfile ? `/profiles/${encodeURIComponent(selectedProfile.id)}` : '/profiles' %>"
                  autocomplete="off"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="returnTo" value="/profiles">

                  <label class="form-label" for="profileName">Nombre</label>
                  <input
                    class="form-control"
                    id="profileName"
                    name="name"
                    maxlength="120"
                    value="<%= profilePageMode === 'edit' && selectedProfile ? selectedProfile.name : '' %>"
                    required
                  >

                  <label class="form-label" for="profileDescription">Descripción</label>
                  <textarea
                    class="form-control"
                    id="profileDescription"
                    name="description"
                    rows="4"
                    maxlength="500"
                  ><%= profilePageMode === 'edit' && selectedProfile ? selectedProfile.description : '' %></textarea>

                  <div class="lesson-form-actions">
                    <button type="submit" class="btn btn-dark">
                      <%= profilePageMode === 'edit' ? 'Guardar cambios' : 'Crear perfil' %>
                    </button>
                  </div>
                </form>
                </div>
              </div>
            </section>
          <% } else if (profiles && profiles.length > 0) { %>
            <div class="profiles-list">
              <% profiles.forEach((profile) => { %>
                <article class="lesson-card profile-card card shadow-sm <%= activeProfile && activeProfile.id === profile.id ? 'is-active' : '' %>">
                  <div class="card-body d-grid gap-2">
                    <div class="lesson-card-meta">
                      <p class="lesson-card-kicker">Perfil</p>
                      <% if (activeProfile && activeProfile.id === profile.id) { %>
                        <span class="badge rounded-pill text-bg-light border lesson-chat-count-badge">Activo</span>
                      <% } %>
                    </div>
                    <h2 class="h4"><%= profile.name %></h2>
                    <p class="mb-0 text-body-secondary"><%= profile.description || 'Sin descripción.' %></p>
                    <div class="profile-card-actions">
                      <% if (activeProfile && activeProfile.id === profile.id) { %>
                        <a class="btn btn-outline-dark" href="/profiles/<%= encodeURIComponent(profile.id) %>/edit">
                          Editar perfil
                        </a>
                      <% } else { %>
                        <form method="post" action="/profiles/switch">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <input type="hidden" name="profileId" value="<%= profile.id %>">
                          <input type="hidden" name="returnTo" value="/profiles">
                          <button class="btn btn-dark" type="submit">Usar este perfil</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="lesson-empty-state alert alert-light border">
              <p>Todavía no hay perfiles. Crea el primero para separar tu práctica en distintos contextos.</p>
            </div>
          <% } %>
        </section>

        <section class="chat-layout <%= currentView === 'chat' ? '' : 'd-none' %>" aria-label="Chat con Mister F">
          <div
            class="messages"
            id="chatPane"
            tabindex="0"
          >
            <section class="lesson-start-panel d-none" data-lesson-start-panel>
              <p class="lesson-start-kicker">Lección</p>
              <h2 class="lesson-start-title" data-lesson-start-title></h2>
              <p class="lesson-start-description" data-lesson-start-description></p>
              <p class="lesson-start-status text-body-secondary d-none" data-lesson-start-status>
                Comenzando la lección...
              </p>
              <button class="btn btn-dark" type="button" data-lesson-start-button>
                Comenzar
              </button>
            </section>
            <div id="messages" aria-live="polite"></div>
          </div>

          <form id="chatForm" class="composer" autocomplete="off">
            <label class="visually-hidden" for="messageInput">Escribe tu mensaje</label>
            <span class="composer-prompt" aria-hidden="true">&gt;</span>
            <div class="composer-input-wrap">
              <textarea
                id="messageInput"
                class="composer-input"
                rows="1"
                maxlength="1200"
                placeholder="Escribe tu mensaje"
                autocomplete="off"
                autocapitalize="none"
                autocorrect="off"
                spellcheck="false"
                autofocus
              ></textarea>
            </div>
            <div class="composer-footer">
              <div
                class="llm-context-meter"
                data-llm-context-meter
                role="progressbar"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
                aria-valuetext="0 por ciento del contexto usado"
                title="Uso del contexto del modelo"
                aria-label="Uso del contexto del modelo"
              >
                <svg
                  class="llm-context-meter-ring"
                  viewBox="0 0 40 40"
                  aria-hidden="true"
                >
                  <circle
                    class="llm-context-meter-track"
                    cx="20"
                    cy="20"
                    r="16"
                  ></circle>
                  <circle
                    class="llm-context-meter-progress"
                    cx="20"
                    cy="20"
                    r="16"
                    data-llm-context-circle
                  ></circle>
                </svg>
              </div>

              <button
                class="btn btn-dark send-button"
                type="submit"
                title="Enviar"
                aria-label="Enviar"
                data-send-button
              >
                <i class="bi bi-send" aria-hidden="true"></i>
              </button>
            </div>
            <div
              class="composer-status small text-body-secondary d-none"
              data-tool-status
              aria-live="polite"
            ></div>
          </form>
        </section>
      </div>
    </main>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/vendor/dompurify/purify.min.js"></script>
    <script src="/vendor/marked/marked.umd.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/public/js/chat.js"></script>
  </body>
</html>
