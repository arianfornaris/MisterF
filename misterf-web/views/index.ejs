<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="stylesheet" href="/vendor/bootswatch/journal/bootstrap.min.css">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/public/css/app.css">
  </head>
  <body
    data-authenticated="<%= isAuthenticated ? 'true' : 'false' %>"
    data-socket-auth-token="<%= socketAuthToken %>"
    data-auth-message="<%= authMessage %>"
    data-guest-initial-greeting="<%= guestInitialGreeting %>"
    data-initial-conversation-id="<%= initialConversationId || '' %>"
    data-chat-mode="<%= chatMode %>"
    data-current-view="<%= currentView %>"
  >
    <main class="app-shell">
      <div class="chat-workspace <%= hasSession ? 'has-toolbar' : '' %>">
        <% if (hasSession) { %>
          <div class="chat-toolbar" aria-label="Controles del chat">
            <button
              class="btn btn-link chat-menu-button"
              type="button"
              data-bs-toggle="offcanvas"
              data-bs-target="#conversationPanel"
              aria-controls="conversationPanel"
              title="Conversaciones"
              aria-label="Conversaciones"
            >
              <i class="bi bi-list fs-4" aria-hidden="true"></i>
            </button>

            <button
              class="btn btn-link translator-button"
              type="button"
              data-bs-toggle="modal"
              data-bs-target="#translatorModal"
              data-open-translator
              title="Traductor"
              aria-label="Traductor"
            >
              <i class="bi bi-translate fs-5" aria-hidden="true"></i>
            </button>
          </div>

          <aside
            class="offcanvas offcanvas-start conversation-panel"
            tabindex="-1"
            id="conversationPanel"
            aria-label="Panel lateral"
          >
            <div class="offcanvas-header">
              <a
                class="panel-home-link"
                href="/"
                title="Ir al inicio"
                aria-label="Ir al inicio"
              >
                <i class="bi bi-house-door fs-5" aria-hidden="true"></i>
              </a>
              <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
            </div>
            <div class="offcanvas-body">
              <div class="panel-nav">
                <a class="panel-nav-link" href="/" data-new-conversation>
                  <i class="bi bi-pencil-square" aria-hidden="true"></i>
                  Nueva conversación
                </a>

                <a class="panel-nav-link <%= currentView === 'practiceModules' ? 'is-active' : '' %>" href="/practice-modules">
                  <i class="bi bi-folder" aria-hidden="true"></i>
                  Módulos de práctica
                </a>
              </div>

              <div class="panel-recents">
                <p class="panel-section-label">Recientes</p>

                <% if (conversations.length > 0) { %>
                  <div class="conversation-list">
                    <% conversations.forEach((conversation) => { %>
                      <div
                        class="conversation-item"
                        data-conversation-id="<%= conversation.id %>"
                      >
                        <a
                          class="conversation-open-button"
                          href="/c/<%= encodeURIComponent(conversation.id) %>"
                          data-open-conversation
                        >
                          <span class="conversation-title"><%= conversation.title %></span>
                          <time class="conversation-date" datetime="<%= conversation.updatedAt %>">
                            <%= conversation.updatedAt %>
                          </time>
                        </a>

                        <div class="conversation-actions dropdown">
                          <button
                            class="btn btn-link conversation-actions-button"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            title="Opciones de conversación"
                            aria-label="Opciones de conversación"
                          >
                            <i class="bi bi-three-dots" aria-hidden="true"></i>
                          </button>
                          <div class="dropdown-menu dropdown-menu-end conversation-actions-menu">
                            <button class="dropdown-item" type="button" data-rename-conversation>Renombrar</button>
                            <button class="dropdown-item text-danger" type="button" data-delete-conversation>Eliminar</button>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="conversation-empty">Todavía no hay conversaciones.</p>
                <% } %>
              </div>

              <div class="panel-bottom">
                <div class="user-menu dropdown">
                  <button
                    class="btn btn-link panel-nav-link user-panel-button"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    title="<%= activeProfile ? activeProfile.name : 'Perfil' %>"
                    aria-label="<%= activeProfile ? activeProfile.name : 'Perfil' %>"
                  >
                    <i class="bi bi-person-circle" aria-hidden="true"></i>
                    <%= activeProfile ? activeProfile.name : 'Perfil' %>
                  </button>

                  <div class="dropdown-menu user-menu-panel">
                    <% if (activeProfile) { %>
                      <p class="user-menu-email"><strong><%= activeProfile.name %></strong></p>
                    <% } %>
                    <p class="user-menu-email"><%= user.email %></p>
                    <a class="dropdown-item" href="/profiles">Cambiar perfil</a>
                    <a class="dropdown-item" href="/change-password">Cambiar contraseña</a>
                    <form method="post" action="/logout">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="dropdown-item" type="submit">Cerrar sesión</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </aside>

          <div
            class="modal fade"
            id="deleteConversationModal"
            tabindex="-1"
            aria-labelledby="deleteConversationModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content delete-conversation-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="deleteConversationModalLabel">Eliminar chat</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <p class="mb-0">
                    ¿Seguro que quieres eliminar “<span data-delete-conversation-title></span>”?
                    Esta acción no se puede deshacer.
                  </p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cancelar</button>
                  <button type="button" class="btn btn-danger" data-confirm-delete-conversation>Eliminar</button>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="translatorModal"
            tabindex="-1"
            aria-labelledby="translatorModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content translator-modal">
                <form id="translatorForm" autocomplete="off">
                  <div class="modal-header">
                    <h2 class="modal-title fs-5" id="translatorModalLabel">Traductor</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                  </div>
                  <div class="modal-body">
                    <div class="translator-mode btn-group" role="group" aria-label="Modo de traducción">
                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeAuto" value="auto" checked>
                      <label class="btn btn-outline-dark" for="translatorModeAuto">Auto</label>

                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeEsEn" value="es-en">
                      <label class="btn btn-outline-dark" for="translatorModeEsEn">ES → EN</label>

                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeEnEs" value="en-es">
                      <label class="btn btn-outline-dark" for="translatorModeEnEs">EN → ES</label>
                    </div>

                    <label class="visually-hidden" for="translatorInput">Texto para traducir</label>
                    <div class="translator-box">
                      <textarea
                        class="form-control translator-textarea"
                        id="translatorInput"
                        rows="5"
                        maxlength="2000"
                        autocomplete="off"
                        autocapitalize="none"
                        autocorrect="off"
                        spellcheck="false"
                      ></textarea>
                      <button
                        class="translator-copy-button"
                        type="button"
                        data-translator-copy="input"
                        title="Copiar texto"
                        aria-label="Copiar texto"
                      >
                        <i class="bi bi-copy" aria-hidden="true"></i>
                      </button>
                    </div>

                    <div class="translator-box translator-result-box">
                      <div class="translator-result" id="translatorResult" aria-live="polite"></div>
                      <button
                        class="translator-copy-button"
                        type="button"
                        data-translator-copy="result"
                        title="Copiar traducción"
                        aria-label="Copiar traducción"
                      >
                        <i class="bi bi-copy" aria-hidden="true"></i>
                      </button>
                    </div>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-dark" data-translator-submit>Traducir</button>
                  </div>
                </form>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="creditModal"
            tabindex="-1"
            aria-labelledby="creditModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content credit-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="creditModalLabel">Crédito agotado</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <p class="mb-0" data-credit-message>
                    Tu crédito de práctica se agotó por ahora.
                  </p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Entendido</button>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="practiceModuleHelpModal"
            tabindex="-1"
            aria-labelledby="practiceModuleHelpModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered modal-lg">
              <div class="modal-content translator-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="practiceModuleHelpModalLabel">Qué puede hacer el tutor</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body practice-module-help-modal-body">
                  <section class="practice-module-help-section">
                    <h3>Tipos de práctica que puedes pedir</h3>
                    <ul>
                      <li>Traducir del español al inglés con corrección guiada.</li>
                      <li>Comprender frases en inglés y explicarlas en español.</li>
                      <li>Mini-conversaciones o role-play con personajes ficticios.</li>
                      <li>Emparejar columnas de palabras, frases o significados.</li>
                      <li>Completar espacios escribiendo o eligiendo opciones.</li>
                      <li>Multiple choice de una o varias respuestas correctas.</li>
                      <li>Ordenar palabras para reconstruir una oración.</li>
                    </ul>
                  </section>

                  <section class="practice-module-help-section">
                    <h3>Ejemplos de instrucciones útiles</h3>
                    <ul>
                      <li>Practica vocabulario de colores con ejercicios variados y mucha corrección paciente.</li>
                      <li>Haz mini-conversaciones de restaurante para un nivel básico, con tono amable y situaciones realistas.</li>
                      <li>Trabaja el pasado simple con frases cortas, completar espacios y multiple choice.</li>
                      <li>Enfócate en inglés para entrevistas de trabajo con tono formal y correcciones claras.</li>
                    </ul>
                  </section>

                  <section class="practice-module-help-section">
                    <h3>Buenas prácticas</h3>
                    <ul>
                      <li>Especifica el tema, el tipo de situación y el nivel aproximado.</li>
                      <li>Puedes combinar varias dinámicas dentro de un mismo módulo de práctica.</li>
                      <li>No hace falta describir la interfaz; describe el objetivo pedagógico.</li>
                      <li>Puedes decir si quieres que el tutor sea más paciente, más exigente o más conversacional.</li>
                    </ul>
                  </section>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Entendido</button>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <section
          class="practice-modules-view <%= currentView === 'practiceModules' ? '' : 'd-none' %>"
          aria-label="Módulos de práctica"
        >
          <div class="practice-modules-header <%= practiceModulePageMode === 'detail' ? 'practice-modules-header-detail' : '' %> <%= practiceModulePageMode !== 'list' ? 'practice-modules-header-has-close' : '' %>">
            <div>
              <p class="practice-modules-kicker">Módulos de práctica</p>
              <h1 class="practice-modules-title">
                <% if (practiceModulePageMode === 'new') { %>
                  Nuevo módulo de práctica
                <% } else if (practiceModulePageMode === 'edit') { %>
                  Editar módulo de práctica
                <% } else if (practiceModulePageMode === 'share') { %>
                  <%= selectedSharedPracticeModule ? selectedSharedPracticeModule.title : 'Módulo de práctica compartido' %>
                <% } else { %>
                  <%= selectedPracticeModule ? selectedPracticeModule.title : 'Biblioteca de módulos de práctica' %>
                <% } %>
              </h1>
              <p class="practice-modules-copy">
                <% if (practiceModulePageMode === 'new') { %>
                  Diseña un módulo de práctica con un objetivo claro, una descripción útil y una guía precisa para el tutor.
                <% } else if (practiceModulePageMode === 'edit') { %>
                  Ajusta este módulo de práctica con calma. Los chats existentes conservarán su propia copia del módulo original.
                <% } else if (practiceModulePageMode === 'share') { %>
                  <%= selectedSharedPracticeModule ? selectedSharedPracticeModule.description : 'Te compartieron un módulo de práctica.' %>
                <% } else { %>
                  <%= selectedPracticeModule ? selectedPracticeModule.description : 'Crea experiencias guiadas para el tutor con un objetivo claro, una descripción y reglas propias.' %>
                <% } %>
              </p>

              <% if (practiceModulePageMode === 'detail' && selectedPracticeModule) { %>
                <% if (selectedPracticeModule.sharedVia) { %>
                  <div class="mt-3">
                    <% if (selectedPracticeModuleSharedFromProfileName) { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida por <%= selectedPracticeModuleSharedFromProfileName %>
                      </span>
                    <% } else { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida <%= selectedPracticeModule.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                      </span>
                    <% } %>
                  </div>
                <% } %>

                <div class="practice-module-detail-inline-actions btn-toolbar" role="toolbar" aria-label="Acciones del módulo de práctica">
                  <div class="btn-group" role="group" aria-label="Editar módulo de práctica">
                    <a
                      class="btn btn-outline-dark"
                      href="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/edit"
                      title="Editar módulo de práctica"
                      aria-label="Editar módulo de práctica"
                    >
                      <i class="bi bi-pencil" aria-hidden="true"></i>
                    </a>
                  </div>
                  <div class="btn-group" role="group" aria-label="Compartir módulo de práctica">
                    <button
                      class="btn btn-outline-dark dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                      title="Compartir módulo de práctica"
                      aria-label="Compartir módulo de práctica"
                    >
                      <i class="bi bi-share" aria-hidden="true"></i>
                    </button>
                    <div class="dropdown-menu">
                      <button
                        class="dropdown-item"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#sharePracticeModuleProfileModal"
                      >
                        Compartir con perfil
                      </button>
                      <button
                        class="dropdown-item"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#sharePracticeModuleLinkModal"
                      >
                        Obtener enlace
                      </button>
                    </div>
                  </div>
                  <div class="btn-group" role="group" aria-label="Eliminar módulo de práctica">
                    <form
                      method="post"
                      action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/delete"
                      onsubmit="return window.confirm('¿Seguro que quieres eliminar este módulo de práctica? Los chats existentes conservarán su copia histórica, pero el módulo ya no aparecerá en la biblioteca.');"
                    >
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button
                        class="btn btn-outline-danger"
                        type="submit"
                        title="Eliminar módulo de práctica"
                        aria-label="Eliminar módulo de práctica"
                      >
                        <i class="bi bi-trash" aria-hidden="true"></i>
                      </button>
                    </form>
                  </div>
                </div>

                <p class="practiceModule-section-copy">Chats de este módulo de práctica</p>

                <form
                  class="practice-module-start-form"
                  method="post"
                  action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/chats"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-dark">Comenzar módulo de práctica</button>
                </form>

                <% if (practiceModuleConversations.length > 0) { %>
                  <div class="practice-module-chat-list list-group shadow-sm">
                    <% practiceModuleConversations.forEach((conversation) => { %>
                      <a
                        class="practice-module-chat-item list-group-item list-group-item-action d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-1"
                        href="/c/<%= encodeURIComponent(conversation.id) %>"
                      >
                        <span class="practice-module-chat-title"><%= conversation.title %></span>
                        <time class="practice-module-chat-date" datetime="<%= conversation.updatedAt %>">
                          <%= conversation.updatedAt %>
                        </time>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="practice-module-empty">Todavía no hay chats para este módulo de práctica.</p>
                <% } %>
              <% } %>
            </div>

            <% if (hasSession) { %>
              <div class="practice-modules-header-actions">
                <% if (practiceModulePageMode === 'new' || practiceModulePageMode === 'edit' || practiceModulePageMode === 'detail' || practiceModulePageMode === 'share') { %>
                  <a
                    class="btn-close practice-module-close-button"
                    href="<%= practiceModulePageMode === 'detail' || practiceModulePageMode === 'share' ? '/practice-modules' : selectedPracticeModule ? `/practice-modules/${encodeURIComponent(selectedPracticeModule.id)}` : '/practice-modules' %>"
                    title="Cerrar"
                    aria-label="Cerrar"
                  ></a>
                <% } %>
                <% if (practiceModulePageMode === 'list') { %>
                  <a class="btn btn-dark" href="/practice-modules/new">
                    Nuevo módulo de práctica
                  </a>
                <% } %>
              </div>
            <% } %>
          </div>

          <% if (practiceModulePageMode === 'list') { %>
            <form class="practiceModule-filter-form" method="get" action="/practice-modules" role="search">
              <div class="practice-module-filter-input-wrap">
                <input
                  class="form-control practice-module-filter-input"
                  type="search"
                  name="q"
                  value="<%= practiceModuleFilterQuery || '' %>"
                  placeholder="Filtrar módulos de práctica por texto"
                  aria-label="Filtrar módulos de práctica por texto"
                >
                <% if (practiceModuleFilterQuery) { %>
                  <a class="practice-module-filter-clear" href="/practice-modules" aria-label="Limpiar filtro">
                    Limpiar
                  </a>
                <% } %>
              </div>
            </form>

            <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
              <a
                class="btn <%= showArchivedPracticeModules ? 'btn-dark' : 'btn-outline-dark' %> btn-sm"
                href="<%= showArchivedPracticeModules ? '/practice-modules' : `/practice-modules${practiceModuleFilterQuery ? `?q=${encodeURIComponent(practiceModuleFilterQuery)}&archived=1` : '?archived=1'}` %>"
              >
                <i class="bi <%= showArchivedPracticeModules ? 'bi-archive-fill' : 'bi-archive' %>" aria-hidden="true"></i>
                <span class="ms-1"><%= showArchivedPracticeModules ? 'Ocultar archivadas' : 'Ver archivadas' %></span>
              </a>
            </div>
          <% } %>

          <% if (practiceModulePageMode === 'new' || practiceModulePageMode === 'edit') { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body">
                <form
                  class="practice-module-form"
                  method="post"
                  action="<%= practiceModulePageMode === 'edit' && selectedPracticeModule ? `/practice-modules/${encodeURIComponent(selectedPracticeModule.id)}` : '/practice-modules' %>"
                  autocomplete="off"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                  <label class="form-label" for="practiceModuleTitle">
                    Título
                  </label>
                  <input
                    class="form-control"
                    id="practiceModuleTitle"
                    name="title"
                    maxlength="120"
                    value="<%= practiceModulePageMode === 'edit' && selectedPracticeModule ? selectedPracticeModule.title : '' %>"
                    required
                  >

                  <label class="form-label" for="practiceModuleDescription">
                    Descripción
                  </label>
                  <textarea
                    class="form-control"
                    id="practiceModuleDescription"
                    name="description"
                    rows="4"
                    maxlength="500"
                    required
                  ><%= practiceModulePageMode === 'edit' && selectedPracticeModule ? selectedPracticeModule.description : '' %></textarea>

                  <div class="practice-module-help-row">
                    <label class="form-label" for="practiceModuleTutorInstructions">
                      Instrucciones al tutor
                    </label>
                    <button
                      class="btn btn-link practice-module-help-button"
                      type="button"
                      data-bs-toggle="modal"
                      data-bs-target="#practiceModuleHelpModal"
                    >
                      Ayuda
                    </button>
                  </div>
                  <textarea
                    class="form-control"
                    id="practiceModuleTutorInstructions"
                    name="tutorInstructions"
                    rows="10"
                    maxlength="4000"
                    required
                  ><%= practiceModulePageMode === 'edit' && selectedPracticeModule ? selectedPracticeModule.tutorInstructions : '' %></textarea>

                  <div class="practice-module-form-actions">
                    <button type="submit" class="btn btn-dark">
                      <%= practiceModulePageMode === 'edit' ? 'Guardar cambios' : 'Crear módulo de práctica' %>
                    </button>
                  </div>
                </form>
                </div>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'share' && selectedSharedPracticeModule && selectedPracticeModuleShareLink) { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body">
                  <div class="d-grid gap-3">
                    <div>
                      <p class="mb-2 text-body-secondary">Revisa el módulo de práctica y decide si quieres importarlo a tu perfil activo.</p>
                      <dl class="mb-0">
                        <dt class="small text-uppercase text-body-secondary">Título</dt>
                        <dd class="mb-3"><%= selectedSharedPracticeModule.title %></dd>
                        <dt class="small text-uppercase text-body-secondary">Descripción</dt>
                        <dd class="mb-3"><%= selectedSharedPracticeModule.description %></dd>
                        <dt class="small text-uppercase text-body-secondary">Tipo</dt>
                        <dd class="mb-0">
                          <% if (selectedSharedPracticeModule.sharedVia) { %>
                            Compartido originalmente por <%= selectedSharedPracticeModule.sharedVia === 'link' ? 'enlace' : 'perfil' %>
                          <% } else { %>
                            Módulo de práctica compartido
                          <% } %>
                        </dd>
                      </dl>
                    </div>
                  </div>
                </div>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'list') { %>
            <% if (favoritePracticeModules.length > 0 || practiceModules.length > 0 || sharedLessons.length > 0 || archivedPracticeModules.length > 0) { %>
              <% if (favoritePracticeModules.length > 0) { %>
                <div class="d-flex align-items-center justify-content-between mb-3">
                  <h2 class="h5 mb-0">Favoritos</h2>
                  <span class="badge text-bg-light border"><%= favoritePracticeModules.length %></span>
                </div>
                <div class="practice-modules-grid">
                  <% favoritePracticeModules.forEach((practiceModule) => { %>
                    <article class="practice-module-card card shadow-sm h-100">
                      <div class="card-body d-grid gap-2">
                        <div class="practice-module-card-meta">
                          <p class="practice-module-card-kicker">Módulo de práctica</p>
                          <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">
                            <%= practiceModule.conversationCount %> <%= practiceModule.conversationCount === 1 ? 'chat' : 'chats' %>
                          </span>
                        </div>
                        <h2 class="h4">
                          <a
                            class="stretched-link text-decoration-none text-reset"
                            href="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>"
                          >
                            <%= practiceModule.title %>
                          </a>
                        </h2>
                        <p class="mb-0 text-body-secondary"><%= practiceModule.description %></p>
                        <div class="practice-module-card-actions btn-group mt-2" role="group" aria-label="Acciones rápidas">
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/favorite">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="favorite" value="0">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Quitar de favoritas" aria-label="Quitar de favoritas">
                              <i class="bi bi-star-fill" aria-hidden="true"></i>
                            </button>
                          </form>
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/archive">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Archivar módulo de práctica" aria-label="Archivar módulo de práctica">
                              <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                          </form>
                        </div>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>

              <% if (practiceModules.length > 0) { %>
                <div class="d-flex align-items-center justify-content-between mb-3">
                  <h2 class="h5 mb-0">Tus módulos de práctica</h2>
                  <span class="badge text-bg-light border"><%= practiceModules.length %></span>
                </div>
                <div class="practice-modules-grid">
                  <% practiceModules.forEach((practiceModule) => { %>
                    <article class="practice-module-card card shadow-sm h-100">
                      <div class="card-body d-grid gap-2">
                        <div class="practice-module-card-meta">
                          <p class="practice-module-card-kicker">Módulo de práctica</p>
                          <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">
                            <%= practiceModule.conversationCount %> <%= practiceModule.conversationCount === 1 ? 'chat' : 'chats' %>
                          </span>
                        </div>
                        <h2 class="h4">
                          <a
                            class="stretched-link text-decoration-none text-reset"
                            href="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>"
                          >
                            <%= practiceModule.title %>
                          </a>
                        </h2>
                        <p class="mb-0 text-body-secondary"><%= practiceModule.description %></p>
                        <div class="practice-module-card-actions btn-group mt-2" role="group" aria-label="Acciones rápidas">
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/favorite">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="favorite" value="<%= practiceModule.isFavorite ? '0' : '1' %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="<%= practiceModule.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>" aria-label="<%= practiceModule.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>">
                              <i class="bi <%= practiceModule.isFavorite ? 'bi-star-fill' : 'bi-star' %>" aria-hidden="true"></i>
                            </button>
                          </form>
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/archive">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Archivar módulo de práctica" aria-label="Archivar módulo de práctica">
                              <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                          </form>
                        </div>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>

              <% if (sharedLessons.length > 0) { %>
                <div class="d-flex align-items-center justify-content-between mb-3 mt-4">
                  <h2 class="h5 mb-0">Compartidos contigo</h2>
                  <span class="badge text-bg-light border"><%= sharedLessons.length %></span>
                </div>
                <div class="practice-modules-grid">
                  <% sharedLessons.forEach((practiceModule) => { %>
                    <article class="practice-module-card card shadow-sm h-100">
                      <div class="card-body d-grid gap-2">
                        <div class="practice-module-card-meta">
                          <p class="practice-module-card-kicker">Compartida</p>
                          <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">
                            <%= practiceModule.conversationCount %> <%= practiceModule.conversationCount === 1 ? 'chat' : 'chats' %>
                          </span>
                        </div>
                        <h2 class="h4">
                          <a
                            class="stretched-link text-decoration-none text-reset"
                            href="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>"
                          >
                            <%= practiceModule.title %>
                          </a>
                        </h2>
                        <p class="mb-0 text-body-secondary"><%= practiceModule.description %></p>
                        <div class="practice-module-card-actions btn-group mt-2" role="group" aria-label="Acciones rápidas">
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/favorite">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="favorite" value="<%= practiceModule.isFavorite ? '0' : '1' %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="<%= practiceModule.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>" aria-label="<%= practiceModule.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>">
                              <i class="bi <%= practiceModule.isFavorite ? 'bi-star-fill' : 'bi-star' %>" aria-hidden="true"></i>
                            </button>
                          </form>
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/archive">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Archivar módulo de práctica" aria-label="Archivar módulo de práctica">
                              <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                          </form>
                        </div>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>

              <% if (showArchivedPracticeModules && archivedPracticeModules.length > 0) { %>
                <div class="d-flex align-items-center justify-content-between mb-3 mt-4">
                  <h2 class="h5 mb-0">Archivados</h2>
                  <span class="badge text-bg-light border"><%= archivedPracticeModules.length %></span>
                </div>
                <div class="practice-modules-grid">
                  <% archivedPracticeModules.forEach((practiceModule) => { %>
                    <article class="practice-module-card card shadow-sm h-100 border-secondary-subtle">
                      <div class="card-body d-grid gap-2">
                        <div class="practice-module-card-meta">
                          <p class="practice-module-card-kicker">Archivada</p>
                          <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">
                            <%= practiceModule.conversationCount %> <%= practiceModule.conversationCount === 1 ? 'chat' : 'chats' %>
                          </span>
                        </div>
                        <h2 class="h4">
                          <a
                            class="stretched-link text-decoration-none text-reset"
                            href="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>"
                          >
                            <%= practiceModule.title %>
                          </a>
                        </h2>
                        <p class="mb-0 text-body-secondary"><%= practiceModule.description %></p>
                        <div class="practice-module-card-actions btn-group mt-2" role="group" aria-label="Acciones rápidas">
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/restore">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Restaurar módulo de práctica" aria-label="Restaurar módulo de práctica">
                              <i class="bi bi-box-arrow-up" aria-hidden="true"></i>
                            </button>
                          </form>
                        </div>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>
            <% } else { %>
              <div class="practice-module-empty-state alert alert-light border">
                <p>
                  <%= practiceModuleFilterQuery
                    ? 'No encontré módulos de práctica que coincidan con ese texto.'
                    : 'Todavía no hay módulos de práctica. Crea el primero y dale un marco propio al tutor.' %>
                </p>
              </div>
            <% } %>
          <% } %>
        </section>

        <% if (currentView === 'practiceModules' && practiceModulePageMode === 'detail' && selectedPracticeModule) { %>
          <div
            class="modal fade"
            id="sharePracticeModuleProfileModal"
            tabindex="-1"
            aria-labelledby="sharePracticeModuleProfileModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeModuleProfileModalLabel">Compartir con perfil</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <% if (shareTargetPracticeModuleProfiles.length > 0) { %>
                    <form method="post" action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/share/profile" class="d-grid gap-3">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <div>
                        <label class="form-label" for="shareTargetProfileId">Perfil destino</label>
                        <select class="form-select" id="shareTargetProfileId" name="targetProfileId" required>
                          <% shareTargetPracticeModuleProfiles.forEach((profile) => { %>
                            <option value="<%= profile.id %>"><%= profile.name %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-dark">Compartir ahora</button>
                      </div>
                    </form>
                  <% } else { %>
                    <p class="mb-0 text-body-secondary">No tienes otros perfiles disponibles para recibir este módulo de práctica.</p>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="sharePracticeModuleLinkModal"
            tabindex="-1"
            aria-labelledby="sharePracticeModuleLinkModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeModuleLinkModalLabel">Enlace para compartir</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body d-grid gap-3">
                  <div>
                    <label class="form-label" for="practiceModuleShareLinkField">Enlace</label>
                    <input
                      class="form-control"
                      id="practiceModuleShareLinkField"
                      type="text"
                      readonly
                      value="<%= practiceModuleShareUrl %>"
                      data-practiceModule-share-link-field
                    >
                  </div>
                  <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-dark" type="button" data-copy-practiceModule-share-link>
                      <i class="bi bi-copy me-1" aria-hidden="true"></i>
                      Copiar
                    </button>
                    <button class="btn btn-outline-dark" type="button" data-native-share-practiceModule-link>
                      <i class="bi bi-share me-1" aria-hidden="true"></i>
                      Compartir
                    </button>
                  </div>
                  <% if (practiceModuleShareQrDataUrl) { %>
                    <div class="d-flex justify-content-center">
                      <img
                        class="practiceModule-share-qr"
                        src="<%= practiceModuleShareQrDataUrl %>"
                        alt="QR del enlace para compartir el módulo de práctica"
                        width="180"
                        height="180"
                      >
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <% if (currentView === 'practiceModules' && practiceModulePageMode === 'share' && selectedSharedPracticeModule && selectedPracticeModuleShareLink) { %>
          <div
            class="modal fade"
            id="acceptSharedPracticeModuleModal"
            tabindex="-1"
            aria-labelledby="acceptSharedPracticeModuleModalLabel"
            aria-hidden="true"
            data-auto-open-share-modal
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="acceptSharedPracticeModuleModalLabel">Aceptar módulo de práctica compartida</h2>
                  <a class="btn-close" href="/practice-modules" aria-label="Cerrar"></a>
                </div>
                <div class="modal-body d-grid gap-3">
                  <p class="mb-0">
                    <% if (activeProfile) { %>
                      ¿Quieres importar este módulo de práctica al perfil <strong><%= activeProfile.name %></strong>?
                    <% } else { %>
                      Inicia sesión para importar este módulo de práctica a uno de tus perfiles.
                    <% } %>
                  </p>
                  <div class="d-flex justify-content-end gap-2">
                    <a class="btn btn-link" href="/practice-modules">No ahora</a>
                    <% if (isAuthenticated && activeProfile) { %>
                      <form method="post" action="/practice-modules/shared/<%= encodeURIComponent(selectedPracticeModuleShareLink.id) %>/accept">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-dark" type="submit">Aceptar</button>
                      </form>
                    <% } else { %>
                      <a class="btn btn-dark" href="/login">Iniciar sesión</a>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <section
          class="practice-modules-view <%= currentView === 'profiles' ? '' : 'd-none' %>"
          aria-label="Perfiles"
        >
          <div class="practice-modules-header <%= profilePageMode !== 'list' ? 'practice-modules-header-has-close' : '' %>">
            <div>
              <p class="practice-modules-kicker">Perfiles</p>
              <h1 class="practice-modules-title">
                <% if (profilePageMode === 'new') { %>
                  Nuevo perfil
                <% } else if (profilePageMode === 'edit') { %>
                  Editar perfil
                <% } else { %>
                  Cambiar perfil
                <% } %>
              </h1>
              <p class="practice-modules-copy">
                <% if (profilePageMode === 'new') { %>
                  Crea un perfil separado para organizar conversaciones y módulos de práctica sin mezclarlas con las demás.
                <% } else if (profilePageMode === 'edit' && selectedProfile) { %>
                  Ajusta el nombre y la descripción de este perfil.
                <% } else { %>
                  Cada perfil mantiene separadas sus conversaciones y módulos de práctica.
                <% } %>
              </p>
            </div>

            <% if (hasSession) { %>
              <div class="practice-modules-header-actions">
                <% if (profilePageMode === 'list') { %>
                  <a class="btn btn-dark" href="/profiles/new">
                    Crear perfil
                  </a>
                <% } else { %>
                  <a
                    class="btn-close practice-module-close-button"
                    href="/profiles"
                    title="Cerrar"
                    aria-label="Cerrar"
                  ></a>
                <% } %>
              </div>
            <% } %>
          </div>

          <% if (profilePageMode === 'new' || profilePageMode === 'edit') { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body">
                <form
                  class="practice-module-form"
                  method="post"
                  action="<%= profilePageMode === 'edit' && selectedProfile ? `/profiles/${encodeURIComponent(selectedProfile.id)}` : '/profiles' %>"
                  autocomplete="off"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="returnTo" value="/profiles">

                  <label class="form-label" for="profileName">Nombre</label>
                  <input
                    class="form-control"
                    id="profileName"
                    name="name"
                    maxlength="120"
                    value="<%= profilePageMode === 'edit' && selectedProfile ? selectedProfile.name : '' %>"
                    required
                  >

                  <label class="form-label" for="profileDescription">Descripción</label>
                  <textarea
                    class="form-control"
                    id="profileDescription"
                    name="description"
                    rows="4"
                    maxlength="500"
                  ><%= profilePageMode === 'edit' && selectedProfile ? selectedProfile.description : '' %></textarea>

                  <div class="practice-module-form-actions">
                    <button type="submit" class="btn btn-dark">
                      <%= profilePageMode === 'edit' ? 'Guardar cambios' : 'Crear perfil' %>
                    </button>
                  </div>
                </form>
                </div>
              </div>
            </section>
          <% } else if (profiles && profiles.length > 0) { %>
            <div class="profiles-list">
              <% profiles.forEach((profile) => { %>
                <article class="practice-module-card profile-card card shadow-sm <%= activeProfile && activeProfile.id === profile.id ? 'is-active' : '' %>">
                  <div class="card-body d-grid gap-2">
                    <div class="practice-module-card-meta">
                      <p class="practice-module-card-kicker">Perfil</p>
                      <% if (activeProfile && activeProfile.id === profile.id) { %>
                        <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">Activo</span>
                      <% } %>
                    </div>
                    <h2 class="h4"><%= profile.name %></h2>
                    <p class="mb-0 text-body-secondary"><%= profile.description || 'Sin descripción.' %></p>
                    <div class="profile-card-actions">
                      <% if (activeProfile && activeProfile.id === profile.id) { %>
                        <a class="btn btn-outline-dark" href="/profiles/<%= encodeURIComponent(profile.id) %>/edit">
                          Editar perfil
                        </a>
                      <% } else { %>
                        <form method="post" action="/profiles/switch">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <input type="hidden" name="profileId" value="<%= profile.id %>">
                          <input type="hidden" name="returnTo" value="/profiles">
                          <button class="btn btn-dark" type="submit">Usar este perfil</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="practice-module-empty-state alert alert-light border">
              <p>Todavía no hay perfiles. Crea el primero para separar tu práctica en distintos contextos.</p>
            </div>
          <% } %>
        </section>

        <section class="chat-layout <%= currentView === 'chat' ? '' : 'd-none' %>" aria-label="Chat con Mister F">
          <div
            class="messages"
            id="chatPane"
            tabindex="0"
          >
            <section class="practice-module-start-panel d-none" data-practice-module-start-panel>
              <p class="practiceModule-start-kicker">Módulo de práctica</p>
              <h2 class="practiceModule-start-title" data-practiceModule-start-title></h2>
              <p class="practiceModule-start-description" data-practiceModule-start-description></p>
              <p class="practice-module-start-status text-body-secondary d-none" data-practice-module-start-status>
                Comenzando el módulo de práctica...
              </p>
              <button class="btn btn-dark" type="button" data-practiceModule-start-button>
                Comenzar
              </button>
            </section>
            <div id="messages" aria-live="polite"></div>
          </div>

          <form id="chatForm" class="composer" autocomplete="off">
            <label class="visually-hidden" for="messageInput">Escribe tu mensaje</label>
            <span class="composer-prompt" aria-hidden="true">&gt;</span>
            <div class="composer-input-wrap">
              <textarea
                id="messageInput"
                class="composer-input"
                rows="1"
                maxlength="1200"
                placeholder="Escribe tu mensaje"
                autocomplete="off"
                autocapitalize="none"
                autocorrect="off"
                spellcheck="false"
                autofocus
              ></textarea>
            </div>
            <div class="composer-footer">
              <div
                class="llm-context-meter"
                data-llm-context-meter
                role="progressbar"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
                aria-valuetext="0 por ciento del contexto usado"
                title="Uso del contexto del modelo"
                aria-label="Uso del contexto del modelo"
              >
                <svg
                  class="llm-context-meter-ring"
                  viewBox="0 0 40 40"
                  aria-hidden="true"
                >
                  <circle
                    class="llm-context-meter-track"
                    cx="20"
                    cy="20"
                    r="16"
                  ></circle>
                  <circle
                    class="llm-context-meter-progress"
                    cx="20"
                    cy="20"
                    r="16"
                    data-llm-context-circle
                  ></circle>
                </svg>
              </div>

              <button
                class="btn btn-dark send-button"
                type="submit"
                title="Enviar"
                aria-label="Enviar"
                data-send-button
              >
                <i class="bi bi-send" aria-hidden="true"></i>
              </button>
            </div>
            <div
              class="composer-status small text-body-secondary d-none"
              data-tool-status
              aria-live="polite"
            ></div>
          </form>
        </section>
      </div>
    </main>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/vendor/dompurify/purify.min.js"></script>
    <script src="/vendor/marked/marked.umd.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/public/js/chat.js"></script>
  </body>
</html>
