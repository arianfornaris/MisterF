                          <% }) %>
                        </select>
                      </div>
                      <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-dark">Compartir ahora</button>
                      </div>
                    </form>
                  <% } else { %>
                    <p class="mb-0 text-body-secondary">No tienes otros perfiles disponibles para recibir esta colección.</p>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="sharePracticeModuleCollectionLinkModal"
            tabindex="-1"
            aria-labelledby="sharePracticeModuleCollectionLinkModalLabel"
            aria-hidden="true"
            <%= practiceModuleShareMode === 'link' ? 'data-auto-open-share-modal' : '' %>
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeModuleCollectionLinkModalLabel">Enlace para compartir colección</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body d-grid gap-3">
                  <div>
                    <label class="form-label" for="practiceModuleCollectionShareLinkField">Enlace</label>
                    <input
                      class="form-control"
                      id="practiceModuleCollectionShareLinkField"
                      type="text"
                      readonly
                      value="<%= practiceModuleCollectionShareUrl %>"
                      data-practiceModule-share-link-field
                    >
                  </div>
                  <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-dark" type="button" data-copy-practiceModule-share-link>
                      <i class="bi bi-copy me-1" aria-hidden="true"></i>
                      Copiar
                    </button>
                    <button class="btn btn-outline-dark" type="button" data-native-share-practiceModule-link>
                      <i class="bi bi-share me-1" aria-hidden="true"></i>
                      Compartir
                    </button>
                  </div>
                  <% if (practiceModuleCollectionShareQrDataUrl) { %>
                    <div class="d-flex justify-content-center">
                      <img
                        class="practiceModule-share-qr"
                        src="<%= practiceModuleCollectionShareQrDataUrl %>"
                        alt="QR del enlace para compartir la colección"
                        width="180"
                        height="180"
                      >
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <section
          class="practice-modules-view <%= currentView === 'profiles' ? '' : 'd-none' %>"
          aria-label="Perfiles"
        >
          <div class="practice-modules-header <%= profilePageMode !== 'list' ? 'practice-modules-header-has-close' : '' %>">
            <div>
              <p class="practice-modules-kicker">Perfiles</p>
              <h1 class="practice-modules-title">
                <% if (profilePageMode === 'new') { %>
                  Nuevo perfil
                <% } else if (profilePageMode === 'edit') { %>
                  Editar perfil
                <% } else { %>
                  Cambiar perfil
                <% } %>
              </h1>
              <p class="practice-modules-copy">
                <% if (profilePageMode === 'new') { %>
                  Crea un perfil separado para organizar conversaciones y módulos de práctica sin mezclarlas con las demás.
                <% } else if (profilePageMode === 'edit' && selectedProfile) { %>
                  Ajusta el nombre y la descripción de este perfil.
                <% } else { %>
                  Cada perfil mantiene separadas sus conversaciones y módulos de práctica.
                <% } %>
              </p>
            </div>

            <% if (hasSession) { %>
              <div class="practice-modules-header-actions">
                <% if (profilePageMode === 'list') { %>
                  <a class="btn btn-dark" href="/profiles/new">
                    Crear perfil
                  </a>
                <% } else { %>
                  <a
                    class="btn-close practice-module-close-button"
                    href="/profiles"
                    title="Cerrar"
                    aria-label="Cerrar"
                  ></a>
                <% } %>
              </div>
            <% } %>
          </div>

          <% if (profilePageMode === 'new' || profilePageMode === 'edit') { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body">
                <form
                  class="practice-module-form"
                  method="post"
                  action="<%= profilePageMode === 'edit' && selectedProfile ? `/profiles/${encodeURIComponent(selectedProfile.id)}` : '/profiles' %>"
                  autocomplete="off"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="returnTo" value="/profiles">

                  <label class="form-label" for="profileName">Nombre</label>
                  <input
                    class="form-control"
                    id="profileName"
                    name="name"
                    maxlength="120"
                    value="<%= profilePageMode === 'edit' && selectedProfile ? selectedProfile.name : '' %>"
                    required
                  >

                  <label class="form-label" for="profileDescription">Descripción</label>
                  <textarea
                    class="form-control"
                    id="profileDescription"
                    name="description"
                    rows="4"
                    maxlength="500"
                  ><%= profilePageMode === 'edit' && selectedProfile ? selectedProfile.description : '' %></textarea>

                  <div class="practice-module-form-actions">
                    <button type="submit" class="btn btn-dark">
                      <%= profilePageMode === 'edit' ? 'Guardar cambios' : 'Crear perfil' %>
                    </button>
                  </div>
                </form>
                </div>
              </div>
            </section>
          <% } else if (profiles && profiles.length > 0) { %>
            <div class="profiles-list">
              <% profiles.forEach((profile) => { %>
                <article class="practice-module-card profile-card card shadow-sm <%= activeProfile && activeProfile.id === profile.id ? 'is-active' : '' %>">
                  <div class="card-body d-grid gap-2">
                    <div class="practice-module-card-meta">
                      <p class="practice-module-card-kicker">Perfil</p>
                      <% if (activeProfile && activeProfile.id === profile.id) { %>
                        <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">Activo</span>
                      <% } %>
                    </div>
                    <h2 class="h4"><%= profile.name %></h2>
                    <p class="mb-0 text-body-secondary"><%= profile.description || 'Sin descripción.' %></p>
                    <div class="profile-card-actions">
                      <% if (activeProfile && activeProfile.id === profile.id) { %>
                        <a class="btn btn-outline-dark" href="/profiles/<%= encodeURIComponent(profile.id) %>/edit">
                          Editar perfil
                        </a>
                      <% } else { %>
                        <form method="post" action="/profiles/switch">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <input type="hidden" name="profileId" value="<%= profile.id %>">
                          <input type="hidden" name="returnTo" value="/profiles">
                          <button class="btn btn-dark" type="submit">Usar este perfil</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="practice-module-empty-state alert alert-light border">
              <p>Todavía no hay perfiles. Crea el primero para separar tu práctica en distintos contextos.</p>
            </div>
          <% } %>
        </section>

        <section class="chat-layout <%= currentView === 'chat' ? '' : 'd-none' %>" aria-label="Chat con Mister F">
          <div
            class="messages"
            id="chatPane"
            tabindex="0"
          >
            <section class="practice-module-start-panel d-none" data-practice-module-start-panel>
              <p class="practiceModule-start-kicker">Módulo de práctica</p>
              <h2 class="practiceModule-start-title" data-practiceModule-start-title></h2>
              <p class="practiceModule-start-description" data-practiceModule-start-description></p>
              <p class="practice-module-start-status text-body-secondary d-none" data-practice-module-start-status>
                Comenzando el módulo de práctica...
              </p>
              <button class="btn btn-dark" type="button" data-practiceModule-start-button>
                Comenzar
              </button>
            </section>
            <div id="messages" aria-live="polite"></div>
          </div>

          <form id="chatForm" class="composer" autocomplete="off">
            <label class="visually-hidden" for="messageInput">Escribe tu mensaje</label>
            <span class="composer-prompt" aria-hidden="true">&gt;</span>
            <div class="composer-input-wrap">
              <textarea
                id="messageInput"
                class="composer-input"
                rows="1"
                maxlength="1200"
                placeholder="Escribe tu mensaje"
                autocomplete="off"
                autocapitalize="none"
                autocorrect="off"
                spellcheck="false"
                autofocus
              ></textarea>
            </div>
            <div class="composer-footer">
              <div
                class="llm-context-meter"
                data-llm-context-meter
                role="progressbar"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
                aria-valuetext="0 por ciento del contexto usado"
                title="Uso del contexto del modelo"
                aria-label="Uso del contexto del modelo"
              >
                <svg
                  class="llm-context-meter-ring"
                  viewBox="0 0 40 40"
                  aria-hidden="true"
                >
                  <circle
                    class="llm-context-meter-track"
                    cx="20"
                    cy="20"
                    r="16"
                  ></circle>
                  <circle
                    class="llm-context-meter-progress"
                    cx="20"
                    cy="20"
                    r="16"
                    data-llm-context-circle
                  ></circle>
                </svg>
              </div>

              <div class="dropdown composer-model-dropdown">
                <button
                  id="modelTierSelect"
                  class="btn btn-link composer-model-button dropdown-toggle"
                  type="button"
                  data-model-tier-button
                  data-model-tier="regular"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  aria-label="Seleccionar modelo"
                >
                  <span data-model-tier-label>Regular</span>
                </button>
                <div class="dropdown-menu dropdown-menu-end composer-model-menu">
                  <button class="dropdown-item" type="button" data-model-tier-option="regular">
                    <span>Intelig. regular · muy rápido · costo 1x</span>
                  </button>
                  <button class="dropdown-item" type="button" data-model-tier-option="advanced">
                    <span>Intelig. avanzada · rápido · costo 2x</span>
                  </button>
                  <button class="dropdown-item" type="button" data-model-tier-option="max">
                    <span>Intelig. máxima · lento · costo 8x</span>
                  </button>
                </div>
              </div>

              <button
                class="btn btn-dark send-button"
                type="submit"
                title="Enviar"
                aria-label="Enviar"
                data-send-button
              >
                <i class="bi bi-send" aria-hidden="true"></i>
              </button>
            </div>
            <div
              class="composer-status small text-body-secondary d-none"
              data-tool-status
              aria-live="polite"
            ></div>
          </form>
        </section>
      </div>
    </main>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/vendor/dompurify/purify.min.js"></script>
    <script src="/vendor/marked/marked.umd.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/public/js/chat.js"></script>
  </body>
</html>
