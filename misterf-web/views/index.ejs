<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="stylesheet" href="/vendor/bootswatch/journal/bootstrap.min.css">
    <link rel="stylesheet" href="/public/css/app.css">
  </head>
  <body
    data-authenticated="<%= isAuthenticated ? 'true' : 'false' %>"
    data-socket-auth-token="<%= socketAuthToken %>"
    data-auth-message="<%= authMessage %>"
    data-guest-initial-greeting="<%= guestInitialGreeting %>"
  >
    <main class="app-shell">
      <div class="chat-workspace <%= hasSession ? 'has-toolbar' : '' %>">
        <% if (hasSession) { %>
          <div class="chat-toolbar" aria-label="Controles del chat">
            <button
              class="btn btn-link chat-menu-button"
              type="button"
              data-bs-toggle="offcanvas"
              data-bs-target="#conversationPanel"
              aria-controls="conversationPanel"
              title="Conversaciones"
              aria-label="Conversaciones"
            >
              <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>

            <button
              class="btn btn-link translator-button"
              type="button"
              data-bs-toggle="modal"
              data-bs-target="#translatorModal"
              data-open-translator
              title="Traductor"
              aria-label="Traductor"
            >
              <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M4 5h9M9 3v2m2 0c-.7 3.3-2.7 6-6 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M7 9c1.2 1.6 2.7 2.8 4.6 3.7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M13 21l4.2-10h1.6L23 21M14.4 18h7.2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div class="user-menu dropdown">
              <button
                class="btn btn-link user-menu-button"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
                title="Menu de usuario"
                aria-label="Menu de usuario"
              >
                <svg aria-hidden="true" width="19" height="19" viewBox="0 0 24 24" fill="none">
                  <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" stroke="currentColor" stroke-width="2"/>
                  <path d="M4 21a8 8 0 0 1 16 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </button>

              <div class="dropdown-menu dropdown-menu-end user-menu-panel">
                <p class="user-menu-email"><%= user.email %></p>
                <a class="dropdown-item" href="/change-password">Cambiar contraseña</a>
                <form method="post" action="/logout">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="dropdown-item" type="submit">Cerrar sesión</button>
                </form>
              </div>
            </div>
          </div>

          <aside
            class="offcanvas offcanvas-start conversation-panel"
            tabindex="-1"
            id="conversationPanel"
            aria-labelledby="conversationPanelLabel"
          >
            <div class="offcanvas-header">
              <h2 class="offcanvas-title" id="conversationPanelLabel">Conversaciones</h2>
              <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
            </div>
            <div class="offcanvas-body">
              <button class="btn btn-link new-conversation-button" type="button" data-new-conversation>
                <svg aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                Nueva conversación
              </button>

              <% if (conversations.length > 0) { %>
                <div class="conversation-list">
                  <% conversations.forEach((conversation) => { %>
                    <div
                      class="conversation-item"
                      data-conversation-id="<%= conversation.id %>"
                    >
                      <button class="conversation-open-button" type="button" data-open-conversation>
                        <span class="conversation-title"><%= conversation.title %></span>
                        <time class="conversation-date" datetime="<%= conversation.updatedAt %>">
                          <%= conversation.updatedAt %>
                        </time>
                      </button>

                      <div class="conversation-actions dropdown">
                        <button
                          class="btn btn-link conversation-actions-button"
                          type="button"
                          data-bs-toggle="dropdown"
                          aria-expanded="false"
                          title="Opciones de conversación"
                          aria-label="Opciones de conversación"
                        >
                          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <circle cx="5" cy="12" r="1.8"/>
                            <circle cx="12" cy="12" r="1.8"/>
                            <circle cx="19" cy="12" r="1.8"/>
                          </svg>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end conversation-actions-menu">
                          <button class="dropdown-item" type="button" data-rename-conversation>Renombrar</button>
                          <button class="dropdown-item text-danger" type="button" data-delete-conversation>Eliminar</button>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="conversation-empty">Todavía no hay conversaciones.</p>
              <% } %>
            </div>
          </aside>

          <div
            class="modal fade"
            id="deleteConversationModal"
            tabindex="-1"
            aria-labelledby="deleteConversationModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content delete-conversation-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="deleteConversationModalLabel">Eliminar conversación</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <p class="mb-0">
                    ¿Seguro que quieres eliminar “<span data-delete-conversation-title></span>”?
                    Esta acción no se puede deshacer.
                  </p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cancelar</button>
                  <button type="button" class="btn btn-danger" data-confirm-delete-conversation>Eliminar</button>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="translatorModal"
            tabindex="-1"
            aria-labelledby="translatorModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content translator-modal">
                <form id="translatorForm" autocomplete="off">
                  <div class="modal-header">
                    <h2 class="modal-title fs-5" id="translatorModalLabel">Traductor</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                  </div>
                  <div class="modal-body">
                    <div class="translator-mode btn-group" role="group" aria-label="Modo de traducción">
                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeAuto" value="auto" checked>
                      <label class="btn btn-outline-dark" for="translatorModeAuto">Auto</label>

                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeEsEn" value="es-en">
                      <label class="btn btn-outline-dark" for="translatorModeEsEn">ES → EN</label>

                      <input class="btn-check" type="radio" name="translatorMode" id="translatorModeEnEs" value="en-es">
                      <label class="btn btn-outline-dark" for="translatorModeEnEs">EN → ES</label>
                    </div>

                    <label class="visually-hidden" for="translatorInput">Texto para traducir</label>
                    <div class="translator-box">
                      <textarea
                        class="form-control translator-textarea"
                        id="translatorInput"
                        rows="5"
                        maxlength="2000"
                        autocomplete="off"
                        autocapitalize="none"
                        autocorrect="off"
                        spellcheck="false"
                      ></textarea>
                      <button
                        class="translator-copy-button"
                        type="button"
                        data-translator-copy="input"
                        title="Copiar texto"
                        aria-label="Copiar texto"
                      >
                        <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none">
                          <path d="M8 8V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2 M6 8h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </div>

                    <div class="translator-box translator-result-box">
                      <div class="translator-result" id="translatorResult" aria-live="polite"></div>
                      <button
                        class="translator-copy-button"
                        type="button"
                        data-translator-copy="result"
                        title="Copiar traducción"
                        aria-label="Copiar traducción"
                      >
                        <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none">
                          <path d="M8 8V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2 M6 8h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-dark" data-translator-submit>Traducir</button>
                  </div>
                </form>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="creditModal"
            tabindex="-1"
            aria-labelledby="creditModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content credit-modal">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="creditModalLabel">Crédito agotado</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <p class="mb-0" data-credit-message>
                    Tu crédito de práctica se agotó por ahora.
                  </p>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Entendido</button>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <section class="chat-layout" aria-label="Chat con Mister F">
          <ul class="nav nav-tabs sheet-tabs" id="sheetTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button
                class="nav-link active"
                id="chat-tab"
                type="button"
                role="tab"
                data-bs-toggle="tab"
                data-bs-target="#chatPane"
                aria-controls="chatPane"
                aria-selected="true"
              >
                Chat
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="practice-tab"
                type="button"
                role="tab"
                data-bs-toggle="tab"
                data-bs-target="#practicePane"
                aria-controls="practicePane"
                aria-selected="false"
              >
                Intentos
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="progress-tab"
                type="button"
                role="tab"
                data-bs-toggle="tab"
                data-bs-target="#progressPane"
                aria-controls="progressPane"
                aria-selected="false"
              >
                Progreso
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="vocabulary-tab"
                type="button"
                role="tab"
                data-bs-toggle="tab"
                data-bs-target="#vocabularyPane"
                aria-controls="vocabularyPane"
                aria-selected="false"
              >
                Vocabulario
              </button>
            </li>
          </ul>

          <div class="tab-content sheet-tab-content">
            <div
              class="tab-pane fade show active messages"
              id="chatPane"
              role="tabpanel"
              aria-labelledby="chat-tab"
              tabindex="0"
            >
              <div id="messages" aria-live="polite"></div>
            </div>

            <div
              class="tab-pane fade practice-pane"
              id="practicePane"
              role="tabpanel"
              aria-labelledby="practice-tab"
              tabindex="0"
            >
              <div id="practiceContent" class="practice-content"></div>
            </div>

            <div
              class="tab-pane fade progress-pane"
              id="progressPane"
              role="tabpanel"
              aria-labelledby="progress-tab"
              tabindex="0"
            >
              <div id="progressContent" class="progress-content"></div>
            </div>

            <div
              class="tab-pane fade vocabulary-pane"
              id="vocabularyPane"
              role="tabpanel"
              aria-labelledby="vocabulary-tab"
              tabindex="0"
            >
              <div id="vocabularyContent" class="vocabulary-content"></div>
            </div>
          </div>

          <form id="chatForm" class="composer" autocomplete="off">
            <label class="visually-hidden" for="messageInput">Respuesta en ingles</label>
            <span class="composer-prompt" aria-hidden="true">&gt;</span>
            <div class="composer-input-wrap">
              <textarea
                id="messageInput"
                class="composer-input"
                rows="1"
                maxlength="1200"
                placeholder="Escribe tu frase en inglés"
                autocomplete="off"
                autocapitalize="none"
                autocorrect="off"
                spellcheck="false"
                autofocus
              ></textarea>
            </div>
            <button class="btn btn-dark send-button" type="submit" title="Enviar" aria-label="Enviar">
              <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M4 12h15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="m13 6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </form>
        </section>
      </div>
    </main>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/vendor/dompurify/purify.min.js"></script>
    <script src="/vendor/marked/marked.umd.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/public/js/chat.js"></script>
  </body>
</html>
