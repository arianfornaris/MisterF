<%- include('partials/app-shell-open') %>

<section class="app-resource-view quizzes-page">
  <div class="resource-page-header">
    <div>
      <p class="resource-eyebrow">Resultado</p>
      <h1><%= resultTitle %></h1>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <% if (isAuthenticated) { %>
        <form method="post" action="/quiz-attempts/<%= encodeURIComponent(attempt.id) %>/practice">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% if (guestToken) { %><input type="hidden" name="guestToken" value="<%= guestToken %>"><% } %>
          <button class="btn btn-primary" type="submit">
            <i class="bi bi-chat-dots me-1" aria-hidden="true"></i>Practicar
          </button>
        </form>
        <%- include('partials/create-resource-from-context', {
          action: `/quiz-attempts/${encodeURIComponent(attempt.id)}/resource`,
        }) %>
        <% if (!attempt.userId && guestToken) { %>
          <form method="post" action="/quiz-attempts/<%= encodeURIComponent(attempt.id) %>/claim">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="guestToken" value="<%= guestToken %>">
            <button class="btn btn-outline-secondary" type="submit">Guardar en mi progreso</button>
          </form>
        <% } %>
      <% } else { %>
        <a class="btn btn-primary" href="/login">
          <i class="bi bi-box-arrow-in-right me-1" aria-hidden="true"></i>Iniciar sesión
        </a>
      <% } %>
    </div>
  </div>

  <% if (resultActionError) { %>
    <div class="alert alert-warning" role="alert">
      <p class="mb-2"><%= resultActionError %></p>
      <% if (resultActionErrorIsCredit) { %>
        <a class="btn btn-primary btn-sm" href="/credits?returnTo=<%= encodeURIComponent(`/quiz-attempts/${attempt.id}/result${guestToken ? `?guestToken=${guestToken}` : ''}`) %>">Comprar créditos</a>
      <% } %>
    </div>
  <% } %>

  <div class="resource-detail-summary">
    <p><%= draft.title %></p>
    <div class="resource-meta-row">
      <span><i class="bi bi-check-circle" aria-hidden="true"></i> <%= summary.correctCount %> correctas</span>
      <span><i class="bi bi-exclamation-circle" aria-hidden="true"></i> <%= summary.partialCount %> parciales</span>
      <span><i class="bi bi-x-circle" aria-hidden="true"></i> <%= summary.incorrectCount %> por mejorar</span>
    </div>
  </div>

  <div data-quiz-result-host></div>
  <div class="quiz-block-list" data-quiz-result-fallback>
    <% resultBlock.items.forEach((resultItem, index) => { %>
      <%- include('partials/quiz-result-item', { index, resultItem }) %>
    <% }) %>
  </div>
</section>

<script type="application/json" data-quiz-result-json><%- resultBlockJson %></script>

<div class="modal fade" tabindex="-1" aria-hidden="true" data-quiz-pending-modal>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" aria-hidden="true"></div>
        <p class="mb-0">Creando la guía de práctica...</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/app-shell-close', { pageScriptPartial: 'quizzes-client-script' }) %>
