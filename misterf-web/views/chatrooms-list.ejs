<%- include('partials/app-shell-open') %>

<section class="practice-modules-view" aria-label="Salas de chat">
  <div class="practice-modules-header">
    <div class="practice-modules-header-detail">
      <p class="practice-modules-kicker">Salas de chat</p>
      <h1 class="practice-modules-title">Salas de chat</h1>
      <p class="practice-modules-copy">
        Crea salas con personajes de IA para simular conversaciones sociales y hacer que el usuario escriba con más libertad.
      </p>
    </div>
  </div>

  <div class="mb-4">
    <button
      class="btn btn-primary"
      type="button"
      data-bs-toggle="modal"
      data-bs-target="#generateChatRoomModal"
    >
      Crear sala
    </button>
  </div>

  <div class="d-grid gap-4">

    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <% if (hasArchivedChatRooms) { %>
          <a
            class="btn <%= showArchivedChatRooms ? 'btn-primary' : 'btn-secondary' %> btn-sm"
            href="<%= showArchivedChatRooms ? '/chatrooms' : '?archived=1' %>"
          >
            <i class="bi <%= showArchivedChatRooms ? 'bi-archive-fill' : 'bi-archive' %>" aria-hidden="true"></i>
            <span class="ms-1"><%= showArchivedChatRooms ? 'Ocultar archivadas' : 'Ver archivadas' %></span>
          </a>
        <% } %>
      </div>
      <div class="btn-group btn-group-sm" role="group" aria-label="Cambiar presentación del contenido">
        <a
          href="/chatrooms?<%= new URLSearchParams(Object.fromEntries(Object.entries({ ...(showArchivedChatRooms ? { archived: '1' } : {}), layout: 'cards' })).toString() %>"
          class="btn <%= chatRoomLayout === 'cards' ? 'btn-primary' : 'btn-secondary' %>"
          title="Mostrar como cards"
        >
          <i class="bi bi-grid-3x3-gap-fill" aria-hidden="true"></i>
          <span class="visually-hidden">Mostrar como cards</span>
        </a>
        <a
          href="/chatrooms?<%= new URLSearchParams(Object.fromEntries(Object.entries({ ...(showArchivedChatRooms ? { archived: '1' } : {}), layout: 'list' })).toString() %>"
          class="btn <%= chatRoomLayout === 'list' ? 'btn-primary' : 'btn-secondary' %>"
          title="Mostrar como lista"
        >
          <i class="bi bi-list-ul" aria-hidden="true"></i>
          <span class="visually-hidden">Mostrar como lista</span>
        </a>
      </div>
    </div>

    <% if (chatRooms.length > 0) { %>
      <% if (chatRoomLayout === 'list') { %>
        <div class="list-group shadow-sm">
          <% chatRooms.forEach((room) => { %>
            <div class="list-group-item position-relative d-flex align-items-start justify-content-between gap-3">
              <div class="min-w-0 flex-grow-1">
                <a class="stretched-link" href="/chatrooms/<%= encodeURIComponent(room.id) %>">
                  <span class="visually-hidden">Ver detalles de <%= room.title %></span>
                </a>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                  <h2 class="h6 fw-normal mb-0"><%= room.title %></h2>
                  <% if (room.sharedVia) { %>
                    <span class="badge text-bg-light border" role="status">
                      Compartida <%= room.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                    </span>
                  <% } %>
                  <% if (room.archivedAt) { %>
                    <span class="badge text-bg-light border" role="status">Archivada</span>
                  <% } %>
                </div>
                <% if (room.sourceProfileName) { %>
                  <p class="mb-0 small text-body-secondary">Compartida por <%= room.sourceProfileName %></p>
                <% } %>
                <div class="d-flex flex-wrap gap-2 mt-2">
                  <% room.characters.forEach((character) => { %>
                    <span class="badge text-bg-light border">
                      <i class="bi bi-person" aria-hidden="true"></i>
                      <span class="ms-1"><%= character.name %><%= character.shortDescription ? ` · ${character.shortDescription}` : '' %></span>
                    </span>
                  <% }) %>
                </div>
              </div>
              <div class="d-flex align-items-center gap-2 flex-shrink-0 ms-2 position-relative z-1">
                <form method="post" action="/chatrooms/<%= encodeURIComponent(room.id) %>/join">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-primary btn-sm" type="submit">Unirse</button>
                </form>
                <div class="dropdown">
                  <button
                    class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0 resource-card-menu-button"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    aria-label="Acciones de la sala"
                    title="Acciones de la sala"
                  >
                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="/chatrooms/<%= encodeURIComponent(room.id) %>/history">Historial</a></li>
                    <li><a class="dropdown-item" href="/chatrooms?room=<%= encodeURIComponent(room.id) %>&share=profile">Compartir con perfil</a></li>
                    <li><a class="dropdown-item" href="/chatrooms?room=<%= encodeURIComponent(room.id) %>&share=link">Compartir por enlace</a></li>
                    <li><a class="dropdown-item" href="/chatrooms/<%= encodeURIComponent(room.id) %>/edit">Editar</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <form method="post" action="/chatrooms/<%= encodeURIComponent(room.id) %>/<%= room.archivedAt ? 'restore' : 'archive' %>" onsubmit="return window.confirm('<%= room.archivedAt ? '¿Seguro que quieres restaurar esta sala?' : '¿Seguro que quieres archivar esta sala de chat?' %>');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="returnTo" value="<%= showArchivedChatRooms ? '/chatrooms?archived=1' : '/chatrooms' %>">
                        <button class="dropdown-item" type="submit"><%= room.archivedAt ? 'Restaurar' : 'Archivar' %></button>
                      </form>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
      <div class="row g-3">
        <% chatRooms.forEach((room) => { %>
          <div class="col-12 col-xl-6">
            <div class="card h-100">
              <div class="card-header bg-success-subtle text-success-emphasis d-flex align-items-center justify-content-between gap-3">
                <span>Sala de chat</span>
                <div class="dropdown position-relative z-1">
                  <button
                    class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0 resource-card-menu-button"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    aria-label="Acciones de la sala"
                    title="Acciones de la sala"
                  >
                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                      <a class="dropdown-item" href="/chatrooms/<%= encodeURIComponent(room.id) %>/history">
                        <i class="bi bi-clock-history me-2" aria-hidden="true"></i>
                        Historial
                      </a>
                    </li>
                    <li>
                      <a class="dropdown-item" href="/chatrooms?room=<%= encodeURIComponent(room.id) %>&share=profile">
                        <i class="bi bi-person me-2" aria-hidden="true"></i>
                        Compartir con perfil
                      </a>
                    </li>
                    <li>
                      <a class="dropdown-item" href="/chatrooms?room=<%= encodeURIComponent(room.id) %>&share=link">
                        <i class="bi bi-link-45deg me-2" aria-hidden="true"></i>
                        Compartir por enlace
                      </a>
                    </li>
                    <li>
                      <a class="dropdown-item" href="/chatrooms/<%= encodeURIComponent(room.id) %>/edit">
                        <i class="bi bi-pencil me-2" aria-hidden="true"></i>
                        Editar
                      </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <form
                        method="post"
                        action="/chatrooms/<%= encodeURIComponent(room.id) %>/<%= room.archivedAt ? 'restore' : 'archive' %>"
                        onsubmit="return window.confirm('<%= room.archivedAt ? '¿Seguro que quieres restaurar esta sala?' : '¿Seguro que quieres archivar esta sala de chat?' %>');"
                      >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="returnTo" value="<%= showArchivedChatRooms ? '/chatrooms?archived=1' : '/chatrooms' %>">
                        <button class="dropdown-item" type="submit">
                          <i class="bi <%= room.archivedAt ? 'bi-arrow-counterclockwise' : 'bi-archive' %> me-2" aria-hidden="true"></i>
                          <%= room.archivedAt ? 'Restaurar' : 'Archivar' %>
                        </button>
                      </form>
                    </li>
                  </ul>
                </div>
              </div>
              <div class="card-body">
                <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
                  <h2 class="card-title h4 mb-0"><%= room.title %></h2>
                  <% if (room.sharedVia) { %>
                    <span class="badge text-bg-light border practice-module-shared-badge position-relative z-1" role="status">
                      Compartida <%= room.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                    </span>
                  <% } %>
                  <% if (room.archivedAt) { %>
                    <span class="badge text-bg-light border position-relative z-1" role="status">Archivada</span>
                  <% } %>
                </div>
                <p class="card-text mb-2 text-body-secondary"><%= room.description %></p>
                <% if (room.sourceProfileName) { %>
                  <p class="card-text mb-2 text-body-secondary small">Compartida por <%= room.sourceProfileName %></p>
                <% } %>
                <div class="d-flex flex-wrap gap-2">
                  <% room.characters.forEach((character) => { %>
                    <span class="badge text-bg-light border">
                      <i class="bi bi-person" aria-hidden="true"></i>
                      <span class="ms-1"><%= character.name %><%= character.shortDescription ? ` · ${character.shortDescription}` : '' %></span>
                    </span>
                  <% }) %>
                </div>
              </div>
              <div class="card-footer bg-transparent d-flex flex-wrap gap-2">
                <div>
                  <form method="post" action="/chatrooms/<%= encodeURIComponent(room.id) %>/join">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-primary btn-sm d-inline-flex align-items-center gap-1" type="submit">
                      <i class="bi bi-chat-text" aria-hidden="true"></i>
                      <span>Unirse</span>
                    </button>
                  </form>
                </div>
                <a
                  class="btn btn-secondary btn-sm d-inline-flex align-items-center gap-1"
                  href="/chatrooms/<%= encodeURIComponent(room.id) %>"
                >
                  <i class="bi bi-card-text" aria-hidden="true"></i>
                  <span>Detalles</span>
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <% } %>
    <% } else { %>
      <div class="card">
        <div class="card-body">
          <p class="mb-0 text-body-secondary">
            <%= showArchivedChatRooms ? 'No tienes salas de chat archivadas.' : 'Todavía no has creado ninguna sala de chat.' %>
          </p>
        </div>
      </div>
    <% } %>
  </div>

  <%- include('partials/chatroom-share-modals') %>

  <div
    class="modal fade"
    id="generateChatRoomModal"
    tabindex="-1"
    aria-labelledby="generateChatRoomModalLabel"
    aria-hidden="true"
    <% if (chatRoomGenerationModalAutoOpen) { %>data-auto-open-modal="true"<% } %>
  >
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <form method="post" action="/chatrooms/generate-draft">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="resourceLabel" value="sala">
          <div class="modal-header">
            <h2 class="modal-title fs-5" id="generateChatRoomModalLabel">Crear sala</h2>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
          </div>
          <div class="modal-body d-grid gap-3">
            <p class="mb-0 text-body-secondary">
              Describe la situación, el tema de conversación y cómo deberían ser los personajes. La sala se creará automáticamente y después podrás revisar sus datos y editarla si quieres.
            </p>
            <% if (chatRoomGenerationError) { %>
              <div class="alert alert-warning mb-0" role="alert">
                <strong>No pude generar la sala automáticamente.</strong>
                <div><%= chatRoomGenerationError %></div>
              </div>
            <% } %>
            <div class="accordion" id="chatRoomGenerationExamplesAccordion">
              <div class="accordion-item">
                <h3 class="accordion-header">
                  <button
                    class="accordion-button collapsed"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#chatRoomGenerationExamples"
                    aria-expanded="false"
                    aria-controls="chatRoomGenerationExamples"
                  >
                    Ejemplos útiles de qué puedes incluir
                  </button>
                </h3>
                <div
                  id="chatRoomGenerationExamples"
                  class="accordion-collapse collapse"
                  data-bs-parent="#chatRoomGenerationExamplesAccordion"
                >
                  <div class="accordion-body">
                    <p class="mb-2">
                      Puedes mencionar cosas como el nivel del usuario, el contexto social o profesional, el tono de la conversación, la relación entre personajes, los temas que deberían debatir y los tipos de opiniones que podrían tener.
                    </p>
                    <p class="mb-0 text-body-secondary">
                      Ejemplo: una sala de compañeros de trabajo debatiendo si la IA mejora o empeora la productividad, con personajes que tengan opiniones distintas y hablen de forma natural.
                    </p>
                  </div>
                </div>
              </div>
            </div>
            <label class="form-label mb-0" for="chatRoomGenerationPrompt">Describe la sala que quieres crear</label>
            <textarea
              class="form-control"
              id="chatRoomGenerationPrompt"
              name="prompt"
              rows="6"
              required
            ><%= chatRoomGenerationPrompt || '' %></textarea>
          </div>
          <div class="modal-footer">
            <button
              type="submit"
              class="btn btn-primary"
              data-resource-generate-submit
            >
              Crear
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div
    class="modal fade"
    id="chatRoomGenerationPendingModal"
    tabindex="-1"
    aria-labelledby="chatRoomGenerationPendingModalLabel"
    aria-hidden="true"
    data-resource-pending-modal
    data-resource-pending-label="sala"
    data-bs-backdrop="static"
    data-bs-keyboard="false"
  >
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content">
        <div class="modal-body text-center py-4 d-grid gap-3">
          <div
            class="spinner-border text-dark mx-auto"
            role="status"
            aria-hidden="true"
          ></div>
          <div>
            <h2 class="fs-6 mb-1" id="chatRoomGenerationPendingModalLabel">Creando sala...</h2>
            <p class="mb-0 text-body-secondary small">
              Esto puede tardar unos segundos.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/app-shell-close', { pageScriptPartial: 'chatrooms-client-script' }) %>
