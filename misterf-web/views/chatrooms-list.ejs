<%- include('partials/app-shell-open') %>

<section class="practice-modules-view" aria-label="Salas de chat">
  <div class="practice-modules-header">
    <div class="practice-modules-header-detail">
      <p class="practice-modules-kicker">Salas de chat</p>
      <h1 class="practice-modules-title">Salas de chat</h1>
      <p class="practice-modules-copy">
        Crea salas con personajes de IA para simular conversaciones sociales y hacer que el usuario escriba con más libertad.
      </p>
    </div>
  </div>

  <div class="mb-4">
    <a class="btn btn-dark" href="/chatrooms/new">Crear sala</a>
  </div>

  <div class="d-grid gap-4">
    <p class="mb-0 text-body-secondary">Crea una sala y entra a conversar con personajes de IA en texto plano.</p>

    <% if (chatRooms.length > 0) { %>
      <div class="row g-3">
        <% chatRooms.forEach((room) => { %>
          <div class="col-12 col-xl-6">
            <div class="card h-100">
              <div class="card-body d-grid gap-3">
                <div>
                  <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                    <h2 class="fs-4 mb-0"><%= room.title %></h2>
                    <% if (room.sharedVia) { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida <%= room.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                      </span>
                    <% } %>
                  </div>
                  <p class="mb-2 text-body-secondary"><%= room.description %></p>
                  <% if (room.sourceProfileName) { %>
                    <p class="mb-2 text-body-secondary small">Compartida por <%= room.sourceProfileName %></p>
                  <% } %>
                  <div class="d-flex flex-wrap gap-2">
                    <% room.characters.forEach((character) => { %>
                      <span class="badge text-bg-light border">
                        <%= character.name %><%= character.shortDescription ? ` · ${character.shortDescription}` : '' %>
                      </span>
                    <% }) %>
                  </div>
                </div>

                <div class="d-flex flex-wrap gap-2">
                  <form method="post" action="/chatrooms/<%= encodeURIComponent(room.id) %>/join">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-dark btn-sm d-inline-flex align-items-center gap-1" type="submit">
                      <i class="bi bi-chat-text" aria-hidden="true"></i>
                      <span>Unirse</span>
                    </button>
                  </form>
                  <a class="btn btn-outline-dark btn-sm" href="/chatrooms/<%= encodeURIComponent(room.id) %>/history" aria-label="Ver historial" title="Ver historial">
                    <i class="bi bi-clock-history" aria-hidden="true"></i>
                  </a>
                  <div class="dropdown">
                    <button
                      class="btn btn-outline-dark btn-sm dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                    >
                      <i class="bi bi-share" aria-hidden="true"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li>
                        <a class="dropdown-item" href="/chatrooms/<%= encodeURIComponent(room.id) %>?share=profile">
                          <i class="bi bi-person me-2" aria-hidden="true"></i>
                          Compartir con perfil
                        </a>
                      </li>
                      <li>
                        <a class="dropdown-item" href="/chatrooms/<%= encodeURIComponent(room.id) %>?share=link">
                          <i class="bi bi-link-45deg me-2" aria-hidden="true"></i>
                          Compartir por enlace
                        </a>
                      </li>
                    </ul>
                  </div>
                  <a class="btn btn-outline-dark btn-sm" href="/chatrooms/<%= encodeURIComponent(room.id) %>/edit" aria-label="Editar sala" title="Editar sala">
                    <i class="bi bi-pencil" aria-hidden="true"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="card">
        <div class="card-body">
          <p class="mb-0 text-body-secondary">Todavía no has creado ninguna sala de chat.</p>
        </div>
      </div>
    <% } %>
  </div>

  <% if (selectedChatRoomShareLink) { %>
    <div
      class="modal fade"
      id="shareChatRoomProfileModal"
      tabindex="-1"
      aria-labelledby="shareChatRoomProfileModalLabel"
      aria-hidden="true"
      <%= chatRoomShareMode === 'profile' ? 'data-auto-open-share-modal' : '' %>
    >
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h2 class="modal-title fs-5" id="shareChatRoomProfileModalLabel">Compartir con perfil</h2>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
          </div>
          <div class="modal-body">
            <% if (selectedChatRoom && shareTargetChatRoomProfiles.length > 0) { %>
              <form method="post" action="/chatrooms/<%= encodeURIComponent(selectedChatRoom.id) %>/share/profile" class="d-grid gap-3">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                  <label class="form-label" for="shareTargetChatRoomProfileId">Perfil destino</label>
                  <select class="form-select" id="shareTargetChatRoomProfileId" name="targetProfileId" required>
                    <% shareTargetChatRoomProfiles.forEach((profile) => { %>
                      <option value="<%= profile.id %>"><%= profile.name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="d-flex justify-content-end">
                  <button type="submit" class="btn btn-dark">Compartir ahora</button>
                </div>
              </form>
            <% } else { %>
              <p class="mb-0 text-body-secondary">No tienes otros perfiles disponibles para recibir esta sala.</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div
      class="modal fade"
      id="shareChatRoomLinkModal"
      tabindex="-1"
      aria-labelledby="shareChatRoomLinkModalLabel"
      aria-hidden="true"
      <%= chatRoomShareMode === 'link' ? 'data-auto-open-share-modal' : '' %>
    >
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h2 class="modal-title fs-5" id="shareChatRoomLinkModalLabel">Enlace para compartir</h2>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
          </div>
          <div class="modal-body d-grid gap-3">
            <div>
              <label class="form-label" for="chatRoomShareLinkField">Enlace</label>
              <input
                class="form-control"
                id="chatRoomShareLinkField"
                type="text"
                readonly
                value="<%= chatRoomShareUrl %>"
                data-chatroom-share-link-field
              >
            </div>
            <div class="d-flex flex-wrap gap-2">
              <button class="btn btn-outline-dark" type="button" data-copy-chatroom-share-link>
                <i class="bi bi-copy me-1" aria-hidden="true"></i>
                Copiar
              </button>
              <button class="btn btn-outline-dark" type="button" data-native-share-chatroom-link>
                <i class="bi bi-share me-1" aria-hidden="true"></i>
                Compartir
              </button>
            </div>
            <% if (chatRoomShareQrDataUrl) { %>
              <div class="d-flex justify-content-center">
                <img
                  class="practiceModule-share-qr"
                  src="<%= chatRoomShareQrDataUrl %>"
                  alt="QR del enlace para compartir la sala de chat"
                  width="180"
                  height="180"
                >
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</section>

<%- include('partials/app-shell-close', { pageScriptPartial: 'chatrooms-client-script' }) %>
