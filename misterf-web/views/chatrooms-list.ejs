<%- include('partials/app-shell-open') %>

<section class="practice-modules-view" aria-label="Salas de chat">
  <div class="practice-modules-header">
    <div class="practice-modules-header-detail">
      <p class="practice-modules-kicker">Salas de chat</p>
      <h1 class="practice-modules-title">Salas de chat</h1>
      <p class="practice-modules-copy">
        Crea salas con personajes de IA para simular conversaciones sociales y hacer que el usuario escriba con más libertad.
      </p>
    </div>
  </div>

  <div class="mb-4">
    <a class="btn btn-dark" href="/chatrooms/new">Crear sala</a>
  </div>

  <div class="d-grid gap-4">
    <p class="mb-0 text-body-secondary">Crea una sala y entra a conversar con personajes de IA en texto plano.</p>

    <div class="d-flex flex-wrap align-items-center gap-2">
      <a
        class="btn <%= showArchivedChatRooms ? 'btn-dark' : 'btn-outline-dark' %> btn-sm"
        href="<%= showArchivedChatRooms ? '/chatrooms' : '?archived=1' %>"
      >
        <i class="bi <%= showArchivedChatRooms ? 'bi-archive-fill' : 'bi-archive' %>" aria-hidden="true"></i>
        <span class="ms-1"><%= showArchivedChatRooms ? 'Ocultar archivadas' : 'Ver archivadas' %></span>
      </a>
    </div>

    <% if (chatRooms.length > 0) { %>
      <div class="row g-3">
        <% chatRooms.forEach((room) => { %>
          <div class="col-12 col-xl-6">
            <div class="card h-100">
              <div class="card-body d-grid gap-3">
                <div>
                  <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                    <h2 class="fs-4 mb-0">
                      <a class="link-dark text-decoration-none" href="/chatrooms/<%= encodeURIComponent(room.id) %>"><%= room.title %></a>
                    </h2>
                    <% if (room.sharedVia) { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida <%= room.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                      </span>
                    <% } %>
                    <% if (room.archivedAt) { %>
                      <span class="badge text-bg-light border" role="status">Archivada</span>
                    <% } %>
                  </div>
                  <p class="mb-2 text-body-secondary"><%= room.description %></p>
                  <% if (room.sourceProfileName) { %>
                    <p class="mb-2 text-body-secondary small">Compartida por <%= room.sourceProfileName %></p>
                  <% } %>
                  <div class="d-flex flex-wrap gap-2">
                    <% room.characters.forEach((character) => { %>
                      <span class="badge text-bg-light border">
                        <%= character.name %><%= character.shortDescription ? ` · ${character.shortDescription}` : '' %>
                      </span>
                    <% }) %>
                  </div>
                </div>

                <div class="d-flex flex-wrap gap-2">
                  <form method="post" action="/chatrooms/<%= encodeURIComponent(room.id) %>/join">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-dark btn-sm d-inline-flex align-items-center gap-1" type="submit">
                      <i class="bi bi-chat-text" aria-hidden="true"></i>
                      <span>Unirse</span>
                    </button>
                  </form>
                  <a class="btn btn-outline-dark btn-sm" href="/chatrooms/<%= encodeURIComponent(room.id) %>/history" aria-label="Ver historial" title="Ver historial">
                    <i class="bi bi-clock-history" aria-hidden="true"></i>
                  </a>
                  <div class="dropdown">
                    <button
                      class="btn btn-outline-dark btn-sm dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                    >
                      <i class="bi bi-share" aria-hidden="true"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li>
                        <a class="dropdown-item" href="/chatrooms?room=<%= encodeURIComponent(room.id) %>&share=profile">
                          <i class="bi bi-person me-2" aria-hidden="true"></i>
                          Compartir con perfil
                        </a>
                      </li>
                      <li>
                        <a class="dropdown-item" href="/chatrooms?room=<%= encodeURIComponent(room.id) %>&share=link">
                          <i class="bi bi-link-45deg me-2" aria-hidden="true"></i>
                          Compartir por enlace
                        </a>
                      </li>
                    </ul>
                  </div>
                  <a class="btn btn-outline-dark btn-sm" href="/chatrooms/<%= encodeURIComponent(room.id) %>/edit" aria-label="Editar sala" title="Editar sala">
                    <i class="bi bi-pencil" aria-hidden="true"></i>
                  </a>
                  <form
                    method="post"
                    action="/chatrooms/<%= encodeURIComponent(room.id) %>/<%= room.archivedAt ? 'restore' : 'archive' %>"
                    onsubmit="return window.confirm('<%= room.archivedAt ? '¿Seguro que quieres restaurar esta sala?' : '¿Seguro que quieres archivar esta sala de chat?' %>');"
                  >
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="returnTo" value="<%= showArchivedChatRooms ? '/chatrooms?archived=1' : '/chatrooms' %>">
                    <button class="btn btn-outline-dark btn-sm" type="submit" aria-label="<%= room.archivedAt ? 'Restaurar sala' : 'Archivar sala' %>" title="<%= room.archivedAt ? 'Restaurar sala' : 'Archivar sala' %>">
                      <i class="bi <%= room.archivedAt ? 'bi-arrow-counterclockwise' : 'bi-archive' %>" aria-hidden="true"></i>
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="card">
        <div class="card-body">
          <p class="mb-0 text-body-secondary">
            <%= showArchivedChatRooms ? 'No tienes salas de chat archivadas.' : 'Todavía no has creado ninguna sala de chat.' %>
          </p>
        </div>
      </div>
    <% } %>
  </div>

  <%- include('partials/chatroom-share-modals') %>
</section>

<%- include('partials/app-shell-close', { pageScriptPartial: 'chatrooms-client-script' }) %>
