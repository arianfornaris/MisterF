<%- include('partials/app-shell-open') %>

<section class="app-resource-view assignments-page">
  <div class="resource-page-header resource-page-header-detail resource-page-header-has-close">
    <div>
      <p class="resource-eyebrow">Tarea</p>
      <h1><%= selectedAssignment.title %></h1>
    </div>
    <div class="resource-page-header-actions">
      <a
        class="resource-page-close-button"
        href="/assignments"
        title="Cerrar"
        aria-label="Cerrar"
      >
        <i class="bi bi-x-lg" aria-hidden="true"></i>
      </a>
    </div>
  </div>

  <div class="resource-detail-summary">
    <p><%= selectedAssignment.description || draft.targetTopic || 'Sin descripción' %></p>
    <div class="resource-meta-row">
      <% if (draft.targetTopic) { %><span><i class="bi bi-bullseye" aria-hidden="true"></i> <%= draft.targetTopic %></span><% } %>
      <% if (draft.level) { %><span><i class="bi bi-bar-chart" aria-hidden="true"></i> <%= draft.level %></span><% } %>
      <span><i class="bi bi-list-check" aria-hidden="true"></i> <%= draft.blocks.length %> bloques</span>
    </div>
  </div>

  <div class="resource-action-row">
    <form method="post" action="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/test-attempts">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-primary" type="submit">
        <i class="bi bi-play-circle me-1" aria-hidden="true"></i>Probar
      </button>
    </form>
    <div class="dropdown">
      <button
        class="btn btn-secondary dropdown-toggle"
        type="button"
        data-bs-toggle="dropdown"
        aria-expanded="false"
      >
        Opciones
      </button>
      <ul class="dropdown-menu">
        <li>
          <button
            class="dropdown-item"
            type="button"
            data-bs-toggle="modal"
            data-bs-target="#assignmentShareProfileModal"
          >
            <i class="bi bi-person me-2" aria-hidden="true"></i>
            Compartir con perfil
          </button>
        </li>
        <li>
          <button
            class="dropdown-item"
            type="button"
            data-bs-toggle="modal"
            data-bs-target="#assignmentShareLinkModal"
          >
            <i class="bi bi-link-45deg me-2" aria-hidden="true"></i>
            Obtener enlace
          </button>
        </li>
        <li>
          <a class="dropdown-item" href="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/edit">
            <i class="bi bi-pencil me-2" aria-hidden="true"></i>
            Editar tarea
          </a>
        </li>
        <li>
          <form method="post" action="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/favorite">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="returnTo" value="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>">
            <button class="dropdown-item" type="submit">
              <i class="bi <%= selectedAssignment.isFavorite ? 'bi-star-fill' : 'bi-star' %> me-2" aria-hidden="true"></i>
              <%= selectedAssignment.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>
            </button>
          </form>
        </li>
        <li><hr class="dropdown-divider"></li>
        <li>
          <form
            method="post"
            action="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/<%= selectedAssignment.archivedAt ? 'restore' : 'archive' %>"
            onsubmit="return window.confirm('<%= selectedAssignment.archivedAt ? '¿Seguro que quieres restaurar esta tarea?' : '¿Seguro que quieres archivar esta tarea? Podrás recuperarla después desde Archivadas.' %>');"
          >
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="returnTo" value="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>">
            <button class="dropdown-item" type="submit">
              <i class="bi <%= selectedAssignment.archivedAt ? 'bi-arrow-counterclockwise' : 'bi-archive' %> me-2" aria-hidden="true"></i>
              <%= selectedAssignment.archivedAt ? 'Restaurar tarea' : 'Archivar tarea' %>
            </button>
          </form>
        </li>
      </ul>
    </div>
  </div>

  <% if (selectedAssignment.sharedVia) { %>
    <div class="d-flex">
      <% if (selectedAssignmentSharedFromProfileName) { %>
        <span class="badge text-bg-light border" role="status">
          Compartida por <%= selectedAssignmentSharedFromProfileName %>
        </span>
      <% } else { %>
        <span class="badge text-bg-light border" role="status">
          Compartida <%= selectedAssignment.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
        </span>
      <% } %>
    </div>
  <% } %>

  <section class="resource-section">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
      <h2 class="h5 mb-0">Bloques</h2>
      <span class="badge text-bg-light border"><%= draft.blocks.length %></span>
    </div>
    <div class="list-group shadow-sm">
      <% assignmentBlockOutlineItems.forEach((block) => { %>
        <article class="list-group-item">
          <div class="d-flex align-items-start gap-3">
            <span class="badge rounded-pill text-bg-light border flex-shrink-0">#<%= block.blockNumber %></span>
            <div class="flex-grow-1">
              <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                <h3 class="h6 mb-0 text-break"><%= block.prompt %></h3>
                <span class="badge text-bg-secondary"><%= block.kindLabel %></span>
              </div>
              <% if (block.sentence) { %>
                <p class="mb-2 text-body-secondary text-break"><%= block.sentence %></p>
              <% } %>
              <% if (block.metaItems.length > 0) { %>
                <div class="d-flex flex-wrap gap-2">
                  <% block.metaItems.forEach((item) => { %>
                    <span class="badge text-bg-light border"><%= item %></span>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <% if (assignmentAttempts.length > 0) { %>
    <div class="resource-section">
      <h2 class="h5">Entregas</h2>
      <div class="list-group">
        <% assignmentAttempts.forEach((attempt) => { %>
          <a class="list-group-item list-group-item-action" href="/assignment-attempts/<%= encodeURIComponent(attempt.id) %>/result">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
              <span>
                <%= attempt.isPreview ? 'Prueba' : 'Entrega' %>
                <span class="badge <%= attempt.statusBadgeClass %> ms-1"><%= attempt.statusLabel %></span>
              </span>
              <span class="text-body-secondary"><%= attempt.relativeUpdatedAt %></span>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  <% } %>
</section>

<div
  class="modal fade"
  id="assignmentShareProfileModal"
  tabindex="-1"
  aria-labelledby="assignmentShareProfileModalLabel"
  aria-hidden="true"
  <%= assignmentShareMode === 'profile' ? 'data-auto-open-assignment-share-modal' : '' %>
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5" id="assignmentShareProfileModalLabel">Compartir con perfil</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <% if (shareTargetAssignmentProfiles.length > 0) { %>
          <form method="post" action="/assignments/<%= encodeURIComponent(selectedAssignment.id) %>/share/profile" class="d-grid gap-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div>
              <label class="form-label" for="shareTargetAssignmentProfileId">Perfil destino</label>
              <select class="form-select" id="shareTargetAssignmentProfileId" name="targetProfileId" required>
                <% shareTargetAssignmentProfiles.forEach((profile) => { %>
                  <option value="<%= profile.id %>"><%= profile.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="d-flex justify-content-end gap-2">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
              <button type="submit" class="btn btn-primary">Compartir ahora</button>
            </div>
          </form>
        <% } else { %>
          <p class="mb-0 text-body-secondary">No tienes otros perfiles disponibles para recibir esta tarea.</p>
        <% } %>
      </div>
      <% if (shareTargetAssignmentProfiles.length === 0) { %>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
        </div>
      <% } %>
    </div>
  </div>
</div>

<div
  class="modal fade"
  id="assignmentShareLinkModal"
  tabindex="-1"
  aria-labelledby="assignmentShareLinkModalLabel"
  aria-hidden="true"
  <%= assignmentShareMode === 'link' ? 'data-auto-open-assignment-share-modal' : '' %>
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5" id="assignmentShareLinkModalLabel">Enlace para compartir</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body d-grid gap-3">
        <label class="form-label" for="assignmentShareLink">Enlace</label>
        <input class="form-control" id="assignmentShareLink" value="<%= shareUrl %>" readonly data-assignment-share-link-field>
        <div class="d-flex flex-wrap gap-2">
          <button class="btn btn-outline-secondary" type="button" data-copy-assignment-share-link>
            <i class="bi bi-copy me-1" aria-hidden="true"></i>Copiar
          </button>
          <button class="btn btn-outline-secondary" type="button" data-native-share-assignment-link>
            <i class="bi bi-share me-1" aria-hidden="true"></i>Compartir
          </button>
        </div>
        <% if (assignmentShareQrDataUrl) { %>
          <div class="d-flex justify-content-center">
            <img
              class="assignment-share-qr"
              src="<%= assignmentShareQrDataUrl %>"
              alt="QR del enlace para compartir la tarea"
              width="180"
              height="180"
            >
          </div>
        <% } %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/app-shell-close', { pageScriptPartial: 'assignments-client-script' }) %>
