<%- include('partials/app-shell-open') %>

<section class="app-resource-view assignments-page">
  <div class="resource-page-header">
    <div>
      <p class="resource-eyebrow">Tareas</p>
      <h1>Nueva tarea</h1>
    </div>
    <a class="btn btn-outline-secondary" href="/resources">
      <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Volver
    </a>
  </div>

  <% if (generationError) { %>
    <div class="alert alert-danger" role="alert"><%= generationError %></div>
  <% } %>

  <div class="card resource-form-card">
    <div class="card-body">
      <form method="post" action="/assignments/generate" data-assignment-generate-form>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="mb-3">
          <label class="form-label" for="assignmentPrompt">Describe la tarea</label>
          <textarea
            class="form-control"
            id="assignmentPrompt"
            name="prompt"
            rows="10"
            required
            placeholder="Ejemplo: una tarea de 8 preguntas para practicar present perfect vs past simple con estudiantes B1..."
          ><%= generationPrompt || '' %></textarea>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <button class="btn btn-primary" type="submit" data-assignment-generate-submit>
            <i class="bi bi-stars me-1" aria-hidden="true"></i>Crear tarea
          </button>
          <a class="btn btn-outline-secondary" href="/resources">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</section>

<div class="modal fade" tabindex="-1" aria-hidden="true" data-assignment-pending-modal>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" aria-hidden="true"></div>
        <p class="mb-0">Creando la tarea...</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/app-shell-close', { pageScriptPartial: 'assignments-client-script' }) %>
