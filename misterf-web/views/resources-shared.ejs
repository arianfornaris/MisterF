<%- include('partials/app-shell-open') %>

<section class="app-resource-view resources-page">
  <div class="resource-page-header">
    <div>
      <p class="resource-page-kicker">Recurso compartido</p>
      <h1 class="resource-page-title"><%= sharedResource.title %></h1>
      <% if (quizTakeAction) { %>
        <p class="resource-page-copy">
          Puedes hacer este quiz ahora. Al evaluarlo te pediremos crear una cuenta o iniciar sesión para ver tu resultado.
        </p>
      <% } else { %>
        <p class="resource-page-copy">
          Para usar este recurso, agrégalo a tu perfil. Verás siempre la versión actual que mantiene su creador.
        </p>
      <% } %>
    </div>
  </div>

  <section class="resource-page-detail-shell">
    <div class="d-grid gap-4">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <span class="badge rounded-pill <%= sharedResource.badgeClass %>">
          <i class="bi <%= sharedResource.iconClass %> me-1" aria-hidden="true"></i>
          <%= sharedResource.label %>
        </span>
        <span class="badge text-bg-light border">Compartido</span>
      </div>

      <% if (sharedResource.description) { %>
        <div class="resource-markdown" data-render-markdown><%= sharedResource.description %></div>
      <% } %>

      <% if (quizTakeAction) { %>
        <form method="post" action="<%= quizTakeAction %>" class="d-flex flex-wrap justify-content-end gap-2 align-items-center">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <a class="btn btn-link" href="/resources">No ahora</a>
          <button class="btn btn-primary" type="submit">
            <i class="bi bi-play-fill me-1" aria-hidden="true"></i>Hacer el quiz
          </button>
        </form>
      <% } else if (startAction) { %>
        <div class="d-flex flex-wrap justify-content-end gap-2 align-items-center">
          <a class="btn btn-link" href="/resources">No ahora</a>
          <a class="btn btn-primary" href="<%= startAction %>">
            <i class="bi bi-play-fill me-1" aria-hidden="true"></i>Comenzar
          </a>
        </div>
      <% } else { %>
        <div class="d-flex flex-wrap justify-content-end gap-2">
          <a class="btn btn-secondary" href="/resources">No ahora</a>
          <% if (isAuthenticated && activeProfile) { %>
            <form method="post" action="/resources/shared/<%= encodeURIComponent(shareLink.id) %>/accept">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-primary" type="submit">Agregar a mis recursos</button>
            </form>
          <% } else { %>
            <a class="btn btn-secondary" href="/signup?returnTo=<%= encodeURIComponent(returnTo) %>">Crear cuenta</a>
            <a class="btn btn-primary" href="/login?returnTo=<%= encodeURIComponent(returnTo) %>">Iniciar sesión</a>
          <% } %>
        </div>
      <% } %>
    </div>
  </section>
</section>

<%- include('partials/app-shell-close', { pageScriptPartial: 'resources-client-script' }) %>
