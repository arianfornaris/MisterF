<%- include('partials/app-shell-open') %>

<section class="app-resource-view roleplays-page">
  <div class="resource-page-header resource-page-header-has-close">
    <div>
      <p class="resource-eyebrow">Roleplay en edición</p>
      <h1 class="resource-page-title"><%= draft.title %></h1>
      <p class="resource-page-copy">Ajusta el recurso manualmente o pídele a la IA que aplique cambios.</p>
    </div>
    <div class="resource-page-header-actions">
      <a
        class="resource-page-close-button"
        href="/roleplays/<%= encodeURIComponent(selectedRoleplay.id) %>"
        aria-label="Cerrar"
        title="Cerrar"
      >
        <i class="bi bi-x-lg" aria-hidden="true"></i>
      </a>
    </div>
  </div>

  <% if (authoringError) { %>
    <div class="alert alert-danger mt-3" role="alert"><%= authoringError %></div>
  <% } %>

  <ul class="nav nav-pills quiz-tabs" role="tablist">
    <li class="nav-item" role="presentation">
      <a
        class="nav-link <%= activeTab === 'general' ? 'active' : '' %>"
        href="/roleplays/<%= encodeURIComponent(selectedRoleplay.id) %>/edit?tab=general"
        role="tab"
        aria-selected="<%= activeTab === 'general' ? 'true' : 'false' %>"
      >
        <i class="bi bi-card-text me-1" aria-hidden="true"></i>General
      </a>
    </li>
    <li class="nav-item" role="presentation">
      <a
        class="nav-link <%= activeTab === 'chat' ? 'active' : '' %>"
        href="/roleplays/<%= encodeURIComponent(selectedRoleplay.id) %>/edit?tab=chat"
        role="tab"
        aria-selected="<%= activeTab === 'chat' ? 'true' : 'false' %>"
      >
        <i class="bi bi-chat-dots me-1" aria-hidden="true"></i>Chat IA
      </a>
    </li>
  </ul>

  <% if (activeTab === 'general') { %>
    <form class="card resource-form-card" method="post" action="/roleplays/<%= encodeURIComponent(selectedRoleplay.id) %>/edit">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="card-body">
        <h2 class="h5 mb-3">General</h2>
        <div class="mb-3">
          <label class="form-label" for="roleplayTitle">Título</label>
          <input class="form-control" id="roleplayTitle" name="title" maxlength="220" required value="<%= draft.title %>">
        </div>
        <div class="mb-3">
          <label class="form-label" for="roleplayDescription">Descripción</label>
          <div class="form-text mb-2">Resumen corto para reconocer este recurso en la biblioteca.</div>
          <textarea
            class="form-control"
            id="roleplayDescription"
            name="description"
            rows="5"
            maxlength="1500"
            data-markdown-editor
            data-markdown-editor-min-height="8rem"
          ><%= draft.description %></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label" for="roleplayScenario">Situación</label>
          <div class="form-text mb-2">Incluye el escenario, lo que sabe el estudiante y qué necesita conseguir durante la conversación.</div>
          <textarea
            class="form-control"
            id="roleplayScenario"
            name="scenario"
            rows="7"
            maxlength="2200"
            required
            data-markdown-editor
            data-markdown-editor-required="true"
            data-markdown-editor-error="roleplayScenarioError"
            data-markdown-editor-min-height="12rem"
          ><%= draft.scenario %></textarea>
          <div class="invalid-feedback" id="roleplayScenarioError" hidden>
            Escribe la situación del Roleplay.
          </div>
        </div>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label" for="roleplayLevel">Nivel</label>
            <input class="form-control" id="roleplayLevel" name="level" maxlength="120" value="<%= draft.level %>">
          </div>
          <div class="col-md-6">
            <label class="form-label" for="roleplayMaxLearnerTurns">Límite de turnos</label>
            <input class="form-control" id="roleplayMaxLearnerTurns" name="maxLearnerTurns" type="number" min="1" max="20" value="<%= draft.maxLearnerTurns || '' %>">
          </div>
        </div>
      </div>

      <div class="card-body border-top">
        <h2 class="h5 mb-3">Enfoque pedagógico</h2>
        <label class="form-label" for="roleplayPedagogicalFocus">Qué debe practicar y evaluar Mr. F</label>
        <div class="form-text mb-2">Ejemplo: practicar preguntas de cortesía, uso de “could/would”, vocabulario de reservas y corrección posterior de errores de orden de palabras.</div>
        <textarea
          class="form-control"
          id="roleplayPedagogicalFocus"
          name="pedagogicalFocus"
          rows="7"
          maxlength="5000"
          data-markdown-editor
          data-markdown-editor-min-height="12rem"
        ><%= draft.pedagogicalFocus %></textarea>
      </div>

      <div class="card-body border-top">
        <h2 class="h5 mb-3">Personajes</h2>
        <div class="row g-3">
          <div class="col-12">
            <div class="border rounded p-3">
              <h3 class="h6 mb-3">
                <i class="bi bi-person me-2" aria-hidden="true"></i>Papel del estudiante
              </h3>
              <div class="mb-3">
                <label class="form-label" for="learnerCharacterName">Nombre visible</label>
                <input class="form-control" id="learnerCharacterName" name="learnerCharacterName" maxlength="120" value="<%= learnerCharacter.name %>" required>
              </div>
              <label class="form-label" for="learnerCharacterDescription">Descripción</label>
              <textarea class="form-control" id="learnerCharacterDescription" name="learnerCharacterDescription" rows="4" maxlength="1200" required><%= learnerCharacter.description %></textarea>
            </div>
          </div>
          <div class="col-12">
            <div class="border rounded p-3">
              <h3 class="h6 mb-3">
                <i class="bi bi-person-video3 me-2" aria-hidden="true"></i>Personaje de la IA
              </h3>
              <div class="mb-3">
                <label class="form-label" for="aiCharacterName">Nombre visible</label>
                <input class="form-control" id="aiCharacterName" name="aiCharacterName" maxlength="120" value="<%= aiCharacter.name %>" required>
              </div>
              <label class="form-label" for="aiCharacterDescription">Descripción</label>
              <textarea class="form-control" id="aiCharacterDescription" name="aiCharacterDescription" rows="4" maxlength="1200" required><%= aiCharacter.description %></textarea>
            </div>
          </div>
        </div>
      </div>

      <div class="card-footer d-flex justify-content-end gap-2">
        <a class="btn btn-secondary" href="/roleplays/<%= encodeURIComponent(selectedRoleplay.id) %>">Cancelar</a>
        <button class="btn btn-primary" type="submit">Guardar cambios</button>
      </div>
    </form>
  <% } %>

  <% if (activeTab === 'chat') { %>
    <div class="quiz-chat-panel">
      <div class="quiz-chat-context">
        <div class="quiz-chat-context-icon" aria-hidden="true">
          <i class="bi bi-stars"></i>
        </div>
        <div>
          <h2 class="quiz-chat-context-title">Modificar el Roleplay con IA</h2>
          <p class="quiz-chat-context-copy mb-0">
            Usa este chat para pedir cambios concretos al Roleplay. Mister F actualizará la información general, la situación, el enfoque pedagógico o los personajes y te responderá qué modificó.
          </p>
        </div>
      </div>
      <div class="quiz-chat-history messages" aria-label="Historial del chat de autoría" data-authoring-chat-history>
        <% if (roleplayAuthoringMessages.length === 0) { %>
          <article class="message-row is-model quiz-chat-message-row">
            <div class="message-bubble quiz-chat-message-bubble">
              <p class="quiz-chat-message-content mb-0">Cuéntame qué quieres ajustar en este Roleplay.</p>
            </div>
          </article>
        <% } else { %>
          <% roleplayAuthoringMessages.forEach((message) => { %>
            <article class="message-row <%= message.role === 'user' ? 'is-user' : 'is-model' %> quiz-chat-message-row">
              <div class="message-bubble quiz-chat-message-bubble">
                <p class="quiz-chat-message-content mb-0"><%= message.content %></p>
              </div>
            </article>
          <% }) %>
        <% } %>
      </div>
      <form class="composer quiz-chat-composer" method="post" action="/roleplays/<%= encodeURIComponent(selectedRoleplay.id) %>/edit/revise" data-roleplay-pending-form>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="visually-hidden" for="roleplayRevisionMessage">Mensaje</label>
        <div class="composer-input-wrap">
          <textarea
            class="composer-input"
            id="roleplayRevisionMessage"
            name="message"
            rows="2"
            maxlength="4000"
            required
            placeholder="Describe los cambios que deseas aplicar"
          ></textarea>
        </div>
        <div class="composer-footer">
          <button
            class="btn btn-primary quiz-chat-submit-button"
            type="submit"
            data-roleplay-pending-submit
            data-loading-text="Aplicando..."
          >
            <i class="bi bi-stars me-1" aria-hidden="true"></i>Aplicar cambios
          </button>
        </div>
      </form>
    </div>
  <% } %>
</section>

<div class="modal fade" tabindex="-1" aria-hidden="true" data-roleplay-pending-modal data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" aria-hidden="true"></div>
        <p class="mb-0">Aplicando cambios...</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/app-shell-close', { pageScriptPartial: 'roleplays-client-script' }) %>
