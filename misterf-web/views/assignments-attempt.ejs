<%- include('partials/app-shell-open') %>

<section class="app-resource-view assignments-page">
  <div class="resource-page-header">
    <div>
      <p class="resource-eyebrow"><%= attempt.isPreview ? 'Preview' : 'Tarea' %></p>
      <h1><%= draft.title %></h1>
    </div>
  </div>

  <% if (attemptError) { %>
    <div class="alert alert-danger" role="alert"><%= attemptError %></div>
  <% } %>

  <form method="post" action="/assignment-attempts/<%= encodeURIComponent(attempt.id) %>/submit" data-assignment-submit-form>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% if (guestToken) { %>
      <input type="hidden" name="guestToken" value="<%= guestToken %>">
    <% } %>
    <div class="assignment-block-list">
      <% draft.blocks.forEach((block, index) => { %>
        <%- include('partials/assignment-item-card', { assignmentItemMode: 'attempt', block, csrfToken, draft, index, responseIndex: index, selectedSession: null }) %>
      <% }) %>
    </div>
    <div class="assignment-submit-bar">
      <button class="btn btn-primary" type="submit" data-assignment-submit-button>
        <i class="bi bi-check2-circle me-1" aria-hidden="true"></i>Enviar
      </button>
    </div>
  </form>
</section>

<div class="modal fade" tabindex="-1" aria-hidden="true" data-assignment-pending-modal>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" aria-hidden="true"></div>
        <p class="mb-0">Evaluando la tarea...</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/app-shell-close', { pageScriptPartial: 'assignments-client-script' }) %>
