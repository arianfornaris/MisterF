<!doctype html>
<html lang="es">
  <% const safeReturnTo = typeof returnTo === 'string' ? returnTo : '/'; %>
  <head>
    <%- include('partials/document-head', { includeBootstrapIcons: true }) %>
  </head>
  <body>
    <main class="container min-vh-100 d-flex align-items-center py-5">
      <section class="row justify-content-center w-100" aria-label="<%= title %>">
        <div class="col-12 col-sm-10 col-md-8 col-lg-5">
          <form
            class="card shadow-sm"
            method="post"
            action="<%= mode === 'login' ? '/login' : mode === 'signup' ? '/signup' : mode === 'forgot' ? '/forgot-password' : '/reset-password' %>"
            novalidate
          >
            <div class="card-body p-4 p-md-5">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="returnTo" value="<%= safeReturnTo %>">

              <div class="mb-4">
                <p class="text-uppercase text-body-secondary small fw-semibold mb-2">
                  <%= mode === 'login' ? 'Bienvenido' : mode === 'signup' ? 'Crea tu cuenta' : mode === 'forgot' ? 'Recuperación' : 'Seguridad' %>
                </p>
                <h1 class="h3 mb-2">
                  <%= mode === 'login' ? 'Iniciar sesión' : mode === 'signup' ? 'Empezar a practicar' : mode === 'forgot' ? 'Recuperar contraseña' : 'Nueva contraseña' %>
                </h1>
                <p class="text-body-secondary mb-0">
                  <% if (mode === 'login') { %>
                    Entra para continuar practicando con Mr. F.
                  <% } else if (mode === 'signup') { %>
                    Crea tu cuenta y empieza con tus créditos iniciales.
                  <% } else if (mode === 'forgot') { %>
                    Te enviaremos un código para restablecer tu contraseña.
                  <% } else { %>
                    Escribe el código recibido y define tu nueva contraseña.
                  <% } %>
                </p>
              </div>

              <% if (error) { %>
                <div class="alert alert-danger" role="alert"><%= error %></div>
              <% } %>

              <% if (mode === 'login' || mode === 'signup') { %>
                <div class="d-grid gap-3 mb-4">
                  <a class="btn btn-light border text-body" href="/auth/google?returnTo=<%= encodeURIComponent(safeReturnTo) %>">
                    <i class="bi bi-google me-2" aria-hidden="true"></i>
                    Continuar con Google
                  </a>
                  <div class="d-flex align-items-center gap-3 text-body-secondary small" aria-hidden="true">
                    <span class="border-top flex-grow-1"></span>
                    <span>o</span>
                    <span class="border-top flex-grow-1"></span>
                  </div>
                </div>
              <% } %>

              <div class="d-grid gap-3">
                <% if (mode === 'signup') { %>
                  <div>
                    <label class="form-label" for="fullName">Nombre completo</label>
                    <input
                      id="fullName"
                      class="form-control <%= fieldErrors.fullName ? 'is-invalid' : '' %>"
                      name="fullName"
                      type="text"
                      autocomplete="name"
                      value="<%= values.fullName %>"
                      required
                      autofocus
                    >
                    <% if (fieldErrors.fullName) { %>
                      <div class="invalid-feedback"><%= fieldErrors.fullName %></div>
                    <% } %>
                  </div>
                <% } %>

                <% if (mode !== 'reset') { %>
                  <div>
                    <label class="form-label" for="email">Correo</label>
                    <input
                      id="email"
                      class="form-control <%= fieldErrors.email ? 'is-invalid' : '' %>"
                      name="email"
                      type="email"
                      autocomplete="email"
                      value="<%= values.email %>"
                      required
                      <%= mode === 'login' || mode === 'forgot' ? 'autofocus' : '' %>
                    >
                    <% if (fieldErrors.email) { %>
                      <div class="invalid-feedback"><%= fieldErrors.email %></div>
                    <% } %>
                  </div>
                <% } %>

                <% if (mode === 'reset') { %>
                  <div>
                    <label class="form-label" for="email">Correo</label>
                    <input
                      id="email"
                      class="form-control <%= fieldErrors.email ? 'is-invalid' : '' %>"
                      name="email"
                      type="email"
                      autocomplete="email"
                      value="<%= values.email %>"
                      required
                      autofocus
                    >
                    <% if (fieldErrors.email) { %>
                      <div class="invalid-feedback"><%= fieldErrors.email %></div>
                    <% } %>
                  </div>

                  <div>
                    <label class="form-label" for="code">Código</label>
                    <input
                      id="code"
                      class="form-control <%= fieldErrors.code ? 'is-invalid' : '' %>"
                      name="code"
                      type="text"
                      autocomplete="one-time-code"
                      inputmode="text"
                      value="<%= values.code %>"
                      required
                    >
                    <% if (fieldErrors.code) { %>
                      <div class="invalid-feedback"><%= fieldErrors.code %></div>
                    <% } %>
                  </div>
                <% } %>

                <% if (mode !== 'forgot') { %>
                  <div>
                    <label class="form-label" for="password">Contraseña</label>
                    <input
                      id="password"
                      class="form-control <%= fieldErrors.password ? 'is-invalid' : '' %>"
                      name="password"
                      type="password"
                      autocomplete="<%= mode === 'login' ? 'current-password' : 'new-password' %>"
                      minlength="10"
                      required
                    >
                    <% if (fieldErrors.password) { %>
                      <div class="invalid-feedback"><%= fieldErrors.password %></div>
                    <% } %>
                    <% if (mode !== 'login') { %>
                      <div class="form-text">Usa al menos 10 caracteres.</div>
                    <% } %>
                  </div>
                <% } %>

                <% if (mode === 'signup') { %>
                  <div>
                    <label class="form-label" for="confirmPassword">Repite la contraseña</label>
                    <input
                      id="confirmPassword"
                      class="form-control <%= fieldErrors.confirmPassword ? 'is-invalid' : '' %>"
                      name="confirmPassword"
                      type="password"
                      autocomplete="new-password"
                      minlength="10"
                      required
                    >
                    <% if (fieldErrors.confirmPassword) { %>
                      <div class="invalid-feedback"><%= fieldErrors.confirmPassword %></div>
                    <% } %>
                  </div>
                <% } %>

                <button class="btn btn-primary" type="submit">
                  <%= mode === 'login' ? 'Entrar' : mode === 'signup' ? 'Crear cuenta' : mode === 'forgot' ? 'Enviar código' : 'Actualizar contraseña' %>
                </button>
              </div>

              <div class="mt-4 mb-0 text-body-secondary">
                <% if (mode === 'login') { %>
                  ¿No tienes cuenta?
                  <a href="/signup?returnTo=<%= encodeURIComponent(safeReturnTo) %>">Crea una</a>.
                  <a href="/forgot-password">Olvidé mi contraseña</a>.
                <% } else if (mode === 'signup') { %>
                  ¿Ya tienes cuenta?
                  <a href="/login?returnTo=<%= encodeURIComponent(safeReturnTo) %>">Inicia sesión</a>.
                <% } else { %>
                  <a href="/login">Volver a iniciar sesión</a>.
                <% } %>
              </div>
            </div>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>
