<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="stylesheet" href="/vendor/bootswatch/journal/bootstrap.min.css">
    <%- include('partials/app-stylesheet') %>
  </head>
  <body>
    <main class="app-shell">
      <section class="auth-sheet card" aria-label="<%= title %>">
        <form
          class="auth-form card-body"
          method="post"
          action="<%= mode === 'login' ? '/login' : mode === 'signup' ? '/signup' : mode === 'forgot' ? '/forgot-password' : '/reset-password' %>"
          novalidate
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="returnTo" value="<%= returnTo || '/' %>">

          <div class="auth-copy">
            <p class="auth-kicker">
              <%= mode === 'login' ? 'Bienvenido' : mode === 'signup' ? 'Crea tu cuenta' : mode === 'forgot' ? 'Recuperación' : 'Seguridad' %>
            </p>
            <h1>
              <%= mode === 'login' ? 'Iniciar sesión' : mode === 'signup' ? 'Empezar a practicar' : mode === 'forgot' ? 'Recuperar password' : 'Nuevo password' %>
            </h1>
          </div>

          <% if (error) { %>
            <div class="alert alert-danger auth-error" role="alert"><%= error %></div>
          <% } %>

          <% if (mode === 'login' || mode === 'signup') { %>
            <a class="btn btn-outline-secondary google-auth-button" href="/auth/google?returnTo=<%= encodeURIComponent(returnTo || '/') %>">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.3 0 6.3 1.1 8.6 3.1l6.4-6.4C35.1 2.6 29.8.5 24 .5 14.6.5 6.5 5.9 2.6 13.7l7.8 6.1C12.2 13.8 17.6 9.5 24 9.5Z"/>
                <path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-2.8-.4-4.1H24v8.2h13c-.3 2.1-1.7 5.3-4.9 7.5l7.6 5.9c4.4-4.1 6.8-10.1 6.8-17.5Z"/>
                <path fill="#FBBC05" d="M10.4 28.2c-.5-1.3-.8-2.7-.8-4.2s.3-2.9.8-4.2l-7.8-6.1C1 16.9.1 20.3.1 24s.9 7.1 2.5 10.3l7.8-6.1Z"/>
                <path fill="#34A853" d="M24 47.5c5.8 0 10.7-1.9 14.2-5.2l-7.6-5.9c-2 1.4-4.7 2.4-6.6 2.4-6.4 0-11.8-4.3-13.6-10.2l-7.8 6.1C6.5 42.1 14.6 47.5 24 47.5Z"/>
              </svg>
              Continuar con Google
            </a>

            <div class="auth-divider" aria-hidden="true"><span></span></div>
          <% } %>

          <% if (mode === 'signup') { %>
            <div class="auth-field mb-0">
              <label class="form-label" for="fullName">Nombre completo</label>
              <input
                id="fullName"
                class="form-control <%= fieldErrors.fullName ? 'is-invalid' : '' %>"
                name="fullName"
                type="text"
                autocomplete="name"
                value="<%= values.fullName %>"
                required
                autofocus
              >
              <% if (fieldErrors.fullName) { %>
                <div class="invalid-feedback"><%= fieldErrors.fullName %></div>
              <% } %>
            </div>
          <% } %>

          <% if (mode !== 'reset') { %>
            <div class="auth-field mb-0">
              <label class="form-label" for="email">Correo</label>
              <input
                id="email"
                class="form-control <%= fieldErrors.email ? 'is-invalid' : '' %>"
                name="email"
                type="email"
                autocomplete="email"
                value="<%= values.email %>"
                required
                <%= mode === 'login' || mode === 'forgot' ? 'autofocus' : '' %>
              >
              <% if (fieldErrors.email) { %>
                <div class="invalid-feedback"><%= fieldErrors.email %></div>
              <% } %>
            </div>
          <% } %>

          <% if (mode === 'reset') { %>
            <div class="auth-field mb-0">
              <label class="form-label" for="email">Correo</label>
              <input
                id="email"
                class="form-control <%= fieldErrors.email ? 'is-invalid' : '' %>"
                name="email"
                type="email"
                autocomplete="email"
                value="<%= values.email %>"
                required
                autofocus
              >
              <% if (fieldErrors.email) { %>
                <div class="invalid-feedback"><%= fieldErrors.email %></div>
              <% } %>
            </div>

            <div class="auth-field mb-0">
              <label class="form-label" for="code">Código</label>
              <input
                id="code"
                class="form-control <%= fieldErrors.code ? 'is-invalid' : '' %>"
                name="code"
                type="text"
                autocomplete="one-time-code"
                inputmode="text"
                value="<%= values.code %>"
                required
              >
              <% if (fieldErrors.code) { %>
                <div class="invalid-feedback"><%= fieldErrors.code %></div>
              <% } %>
            </div>
          <% } %>

          <% if (mode !== 'forgot') { %>
            <div class="auth-field mb-0">
              <label class="form-label" for="password">Password</label>
              <input
                id="password"
                class="form-control <%= fieldErrors.password ? 'is-invalid' : '' %>"
                name="password"
                type="password"
                autocomplete="<%= mode === 'login' ? 'current-password' : 'new-password' %>"
                minlength="10"
                required
                <%= mode === 'reset' ? 'autofocus' : '' %>
              >
              <% if (fieldErrors.password) { %>
                <div class="invalid-feedback"><%= fieldErrors.password %></div>
              <% } %>
            </div>
          <% } %>

          <button class="btn btn-dark auth-submit" type="submit">
            <%= mode === 'login' ? 'Entrar' : mode === 'signup' ? 'Crear cuenta' : mode === 'forgot' ? 'Enviar código' : 'Actualizar password' %>
          </button>

          <p class="auth-switch">
            <% if (mode === 'login') { %>
              ¿No tienes cuenta? <a href="/signup?returnTo=<%= encodeURIComponent(returnTo || '/') %>">Crea una</a>. <a href="/forgot-password">Olvidé mi password</a>.
            <% } else if (mode === 'signup') { %>
              ¿Ya tienes cuenta? <a href="/login?returnTo=<%= encodeURIComponent(returnTo || '/') %>">Inicia sesión</a>.
            <% } else { %>
              <a href="/login">Volver a iniciar sesión</a>.
            <% } %>
          </p>
        </form>
      </section>
    </main>
  </body>
</html>
