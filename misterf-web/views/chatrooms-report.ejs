<%- include('partials/app-shell-open') %>

<section class="practice-modules-view" aria-label="Análisis de conversación">
  <div class="practice-modules-header practice-modules-header-has-close">
    <div class="practice-modules-header-detail">
      <p class="practice-modules-kicker">Análisis de conversación</p>
      <h1 class="practice-modules-title"><%= selectedChatRoom.title %></h1>
      <p class="practice-modules-copy">
        Este análisis resume los patrones principales del chat y los convierte en focos concretos para seguir practicando.
      </p>
    </div>
    <div class="practice-modules-header-actions">
      <a
        class="practice-module-close-button"
        href="/chatrooms/<%= encodeURIComponent(selectedChatRoom.id) %>/history"
        title="Cerrar"
        aria-label="Cerrar"
      >
        <i class="bi bi-x-lg" aria-hidden="true"></i>
      </a>
    </div>
  </div>

  <div class="d-grid gap-4">
    <div class="card shadow-sm">
      <div class="card-body d-grid gap-3">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
          <div>
            <h2 class="h4 mb-1"><%= selectedChatRoomConversationReport.summaryTitle %></h2>
            <p class="mb-0 text-body-secondary"><%= selectedChatRoomConversationReport.summaryDescription %></p>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <form
              method="post"
              action="/chatroom-conversations/<%= encodeURIComponent(selectedChatRoomConversation.id) %>/report/practice-with-tutor"
            >
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-secondary" type="submit">Practicar con Mr. F</button>
            </form>
            <% if (selectedChatRoomConversationReport.practiceModuleId) { %>
              <a
                class="btn btn-outline-secondary"
                href="/practice-modules/<%= encodeURIComponent(selectedChatRoomConversationReport.practiceModuleId) %>"
              >
                Ver módulo creado
              </a>
            <% } else { %>
              <form
                method="post"
                action="/chatroom-conversations/<%= encodeURIComponent(selectedChatRoomConversation.id) %>/report/create-practice-module"
                onsubmit="return window.confirm('¿Quieres crear un módulo de práctica a partir de este análisis?');"
              >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-primary" type="submit">Crear módulo de práctica</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <% const slideCount = selectedChatRoomConversationReport.slides.length; %>
    <% const currentIndex = selectedChatRoomReportSlideIndex; %>
    <% const previousIndex = currentIndex > 0 ? currentIndex - 1 : 0; %>
    <% const nextIndex = currentIndex < slideCount - 1 ? currentIndex + 1 : slideCount - 1; %>

    <div
      class="card shadow-sm"
      data-report-root
      data-report-url="/chatroom-conversations/<%= encodeURIComponent(selectedChatRoomConversation.id) %>/report"
    >
      <div class="card-body d-grid gap-4">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
          <div>
            <p class="text-body-secondary small mb-1" data-report-slide-counter>Slide <%= currentIndex + 1 %> de <%= slideCount %></p>
            <h2 class="h3 mb-0" data-report-slide-title><%= selectedChatRoomReportSlide ? selectedChatRoomReportSlide.title : 'Análisis' %></h2>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <a
              class="btn btn-outline-secondary <%= currentIndex === 0 ? 'disabled' : '' %>"
              href="/chatroom-conversations/<%= encodeURIComponent(selectedChatRoomConversation.id) %>/report?slide=<%= previousIndex %>"
              aria-disabled="<%= currentIndex === 0 ? 'true' : 'false' %>"
              aria-label="Slide anterior"
              title="Slide anterior"
              data-report-prev
            >
              <i class="bi bi-arrow-left" aria-hidden="true"></i>
            </a>
            <a
              class="btn btn-outline-secondary <%= currentIndex >= slideCount - 1 ? 'disabled' : '' %>"
              href="/chatroom-conversations/<%= encodeURIComponent(selectedChatRoomConversation.id) %>/report?slide=<%= nextIndex %>"
              aria-disabled="<%= currentIndex >= slideCount - 1 ? 'true' : 'false' %>"
              aria-label="Slide siguiente"
              title="Slide siguiente"
              data-report-next
            >
              <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </div>

        <% if (selectedChatRoomReportSlide) { %>
          <div class="d-grid gap-4" data-report-slide-content>
            <div>
              <p class="mb-0" data-report-slide-description><%= selectedChatRoomReportSlide.evaluationDescription %></p>
            </div>

            <section class="sentence-evaluation card">
              <div class="sentence-evaluation-header card-header">
                <h3 class="sentence-evaluation-label h6 mb-0">Fragmentos observados</h3>
              </div>
              <div class="sentence-evaluation-body card-body d-grid gap-3">
                <div class="sentence-parts" data-report-sentence-parts>
                  <% selectedChatRoomReportSlide.messageEvaluation.parts.forEach((part) => { %>
                    <% if (part.status === 'correct') { %>
                      <span class="sentence-part is-correct"><%= part.text %></span>
                    <% } else { %>
                      <button
                        type="button"
                        class="sentence-part is-<%= part.status %>"
                        data-report-part-text="<%= part.text %>"
                        data-report-part-status="<%= part.status %>"
                        data-report-part-explanation="<%= part.explanation || 'Esta parte necesita un ajuste.' %>"
                      ><%= part.text %></button>
                    <% } %>
                  <% }) %>
                </div>

                <% const firstIssue = selectedChatRoomReportSlide.messageEvaluation.parts.find((part) => part.status !== 'correct'); %>
                <div
                  class="border rounded p-3"
                  data-report-explanation-panel
                  <% if (!firstIssue) { %>hidden<% } %>
                >
                  <div class="fw-semibold mb-1" data-report-explanation-title>
                    <% if (firstIssue) { %>
                      <%= firstIssue.status === 'error' ? 'Error' : 'Puede mejorar' %>: <span class="text-body-secondary"><%= firstIssue.text %></span>
                    <% } %>
                  </div>
                  <p class="mb-0 text-body-secondary" data-report-explanation-body>
                    <%= firstIssue?.explanation || '' %>
                  </p>
                </div>
              </div>
            </section>

            <% if (slideCount > 1) { %>
              <div class="d-flex flex-wrap justify-content-center gap-2" data-report-pagination>
                <% selectedChatRoomConversationReport.slides.forEach((slide, index) => { %>
                  <a
                    href="/chatroom-conversations/<%= encodeURIComponent(selectedChatRoomConversation.id) %>/report?slide=<%= index %>"
                    class="btn <%= index === currentIndex ? 'btn-primary' : 'btn-outline-secondary' %> btn-sm"
                    aria-label="Ir al hallazgo <%= index + 1 %>"
                    title="<%= slide.title %>"
                    data-report-jump="<%= index %>"
                  >
                    <%= index + 1 %>
                  </a>
                <% }) %>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('partials/app-shell-close', { pageScriptPartial: 'chatrooms-client-script' }) %>
