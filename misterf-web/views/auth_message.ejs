<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="stylesheet" href="/vendor/bootswatch/journal/bootstrap.min.css">
    <%- include('partials/app-stylesheet') %>
  </head>
  <body>
    <main class="app-shell">
      <section class="auth-sheet card" aria-label="<%= title %>">
        <div class="auth-form card-body">
          <div class="auth-copy">
            <p class="auth-kicker">Mister F</p>
            <h1><%= title %></h1>
          </div>

          <div class="alert alert-info auth-message" role="status"><%= body %></div>

          <% if (showResendVerification) { %>
            <form method="post" action="/resend-verification">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="returnTo" value="<%= returnTo || '/' %>">
              <button class="btn btn-dark auth-submit" type="submit">Reenviar verificación</button>
            </form>
          <% } %>

          <% if (showVerificationCodeForm) { %>
            <form class="auth-form" method="post" action="/verify-email">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="returnTo" value="<%= returnTo || '/' %>">
              <div class="auth-field mb-0">
                <label class="form-label" for="code">Código</label>
                <input
                  id="code"
                  class="form-control"
                  name="code"
                  type="text"
                  autocomplete="one-time-code"
                  inputmode="text"
                  required
                  autofocus
                >
              </div>
              <button class="btn btn-dark auth-submit" type="submit">Verificar correo</button>
            </form>
          <% } %>

          <% if (linkHref && linkText) { %>
            <p class="auth-switch"><a href="<%= linkHref %>"><%= linkText %></a></p>
          <% } else { %>
            <p class="auth-switch"><a href="<%= returnTo || '/' %>">Volver</a></p>
          <% } %>
        </div>
      </section>
    </main>
  </body>
</html>
