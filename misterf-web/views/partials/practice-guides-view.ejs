        <%
          const practiceGuideDraftValues = typeof practiceGuideFormValues === 'object' && practiceGuideFormValues
            ? practiceGuideFormValues
            : {};
          const practiceGuideCloseHref = practiceGuidePageMode === 'edit' && selectedPracticeGuide
            ? `/practice-guides/${encodeURIComponent(selectedPracticeGuide.id)}`
            : '/resources';
          const practiceGuideCurrentFolder = resourceCurrentFolder || null;
          const practiceGuideFolderOptions = Array.isArray(resourceFolderOptions) ? resourceFolderOptions : [];
          const practiceGuideFolderPath = Array.isArray(resourceFolderPath) ? resourceFolderPath : [];
          const showPracticeGuideMoveOption = practiceGuidePageMode === 'detail'
            && selectedPracticeGuide
            && canManagePracticeGuide
            && !selectedPracticeGuide.archivedAt
            && (practiceGuideCurrentFolder || practiceGuideFolderOptions.length > 0);
        %>
        <section
          class="app-resource-view practice-guides-page"
          aria-label="Guías de práctica"
        >
          <div class="resource-page-header resource-page-header-detail <%= practiceGuidePageMode === 'detail' ? '' : 'resource-page-header-has-close' %>">
            <div>
              <p class="resource-page-kicker">Guías de práctica</p>
              <h1 class="resource-page-title">
                <% if (practiceGuidePageMode === 'new') { %>
                  Nueva guía de práctica
                <% } else if (practiceGuidePageMode === 'edit') { %>
                  Editar guía de práctica
                <% } else if (practiceGuidePageMode === 'share') { %>
                  <%= selectedSharedPracticeGuide ? selectedSharedPracticeGuide.title : 'Guía de práctica compartida' %>
                <% } else { %>
                  <%= selectedPracticeGuide ? selectedPracticeGuide.title : 'Guía de práctica' %>
                <% } %>
              </h1>
              <% if (practiceGuidePageMode === 'detail' && selectedPracticeGuide) { %>
                <p class="resource-page-copy">
                  <a href="/resources">Recursos</a>
                  <% practiceGuideFolderPath.forEach((folder) => { %>
                    <span class="mx-1">/</span>
                    <a href="/resources/folders/<%= encodeURIComponent(folder.id) %>"><%= folder.title %></a>
                  <% }) %>
                  <span class="mx-1">/</span>
                  <span><%= selectedPracticeGuide.title %></span>
                </p>
              <% } else if (practiceGuidePageMode === 'share' && selectedSharedPracticeGuide) { %>
                <div class="resource-page-copy resource-markdown" data-render-markdown><%= selectedSharedPracticeGuide.description %></div>
              <% } else { %>
                <p class="resource-page-copy">
                  <% if (practiceGuidePageMode === 'new') { %>
                    Diseña una guía con un objetivo claro, una descripción útil y reglas precisas para el tutor.
                  <% } else if (practiceGuidePageMode === 'edit') { %>
                    Ajusta esta guía con calma. Los chats existentes conservarán su propia copia del contenido original.
                  <% } else if (practiceGuidePageMode === 'share') { %>
                    Te compartieron una guía de práctica.
                  <% } %>
                </p>
              <% } %>
            </div>

            <% if (practiceGuidePageMode !== 'detail') { %>
              <div class="resource-page-header-actions">
                <a
                  class="resource-page-close-button"
                  href="<%= practiceGuideCloseHref %>"
                  title="Cerrar"
                  aria-label="Cerrar"
                >
                  <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
              </div>
            <% } %>
          </div>

          <% if (practiceGuidePageMode === 'detail' && selectedPracticeGuide) { %>
            <section class="resource-page-detail-shell">
              <div class="d-grid gap-3">
                <div class="d-flex flex-wrap align-items-center gap-2">
                  <form method="post" action="/practice-guides/<%= encodeURIComponent(selectedPracticeGuide.id) %>/chats">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-primary" type="submit">
                      <i class="bi bi-play-fill me-1" aria-hidden="true"></i>
                      Probar
                    </button>
                  </form>

                  <% if (canManagePracticeGuide) { %>
                  <div class="dropdown">
                    <button
                      class="btn btn-secondary dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                    >
                      Opciones
                    </button>
                    <ul class="dropdown-menu">
                      <% if (!selectedPracticeGuide.archivedAt) { %>
                        <% if (showPracticeGuideMoveOption) { %>
                          <li>
                            <button
                              class="dropdown-item"
                              type="button"
                              data-bs-toggle="modal"
                              data-bs-target="#moveResourceModal"
                              data-resource-move-open
                              data-resource-id="<%= selectedPracticeGuide.id %>"
                              data-resource-title="<%= selectedPracticeGuide.title %>"
                              data-resource-type="practice_guide"
                              data-current-folder-id="<%= practiceGuideCurrentFolder ? practiceGuideCurrentFolder.id : '' %>"
                            >
                              <i class="bi bi-folder-symlink me-2" aria-hidden="true"></i>
                              Mover a carpeta
                            </button>
                          </li>
                        <% } %>
                        <li>
                          <button
                            class="dropdown-item"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#sharePracticeGuideProfileModal"
                          >
                            <i class="bi bi-person me-2" aria-hidden="true"></i>
                            Compartir con perfil
                          </button>
                        </li>
                        <li>
                          <button
                            class="dropdown-item"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#sharePracticeGuideLinkModal"
                          >
                            <i class="bi bi-share me-2" aria-hidden="true"></i>
                            Compartir
                          </button>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                          <a
                            class="dropdown-item"
                            href="/practice-guides/<%= encodeURIComponent(selectedPracticeGuide.id) %>/edit"
                          >
                            <i class="bi bi-pencil me-2" aria-hidden="true"></i>
                            Editar guía
                          </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                      <% } %>
                      <li>
                        <form
                          method="post"
                          action="/practice-guides/<%= encodeURIComponent(selectedPracticeGuide.id) %>/<%= selectedPracticeGuide.archivedAt ? 'restore' : 'archive' %>"
                          onsubmit="return window.confirm('<%= selectedPracticeGuide.archivedAt ? '¿Seguro que quieres restaurar esta guía?' : '¿Seguro que quieres archivar esta guía? Podrás recuperarla después desde Archivados.' %>');"
                        >
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <input type="hidden" name="returnTo" value="/practice-guides/<%= encodeURIComponent(selectedPracticeGuide.id) %>">
                          <button class="dropdown-item" type="submit">
                            <i class="bi <%= selectedPracticeGuide.archivedAt ? 'bi-arrow-counterclockwise' : 'bi-archive' %> me-2" aria-hidden="true"></i>
                            <%= selectedPracticeGuide.archivedAt ? 'Restaurar guía' : 'Archivar guía' %>
                          </button>
                        </form>
                      </li>
                    </ul>
                  </div>
                  <% } %>
                </div>

                <% if (selectedPracticeGuide.sharedVia || !canManagePracticeGuide) { %>
                  <div class="d-flex">
                    <% if (selectedPracticeGuideSharedFromProfileName) { %>
                      <span class="badge text-bg-light border practice-guide-shared-badge" role="status">
                        Compartida por <%= selectedPracticeGuideSharedFromProfileName %>
                      </span>
                    <% } else { %>
                      <span class="badge text-bg-light border practice-guide-shared-badge" role="status">
                        Compartida <%= selectedPracticeGuide.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                      </span>
                    <% } %>
                  </div>
                <% } %>

                <p class="resource-page-section-copy">Descripción</p>
                <div class="card">
                  <div class="card-body">
                    <div class="resource-markdown" data-render-markdown><%= selectedPracticeGuide.description %></div>
                  </div>
                </div>

                <p class="resource-page-section-copy">Instrucciones al tutor</p>
                <div class="card">
                  <div class="card-body">
                    <div class="resource-markdown" data-render-markdown><%= selectedPracticeGuide.tutorInstructions %></div>
                  </div>
                </div>

                <p class="resource-page-section-copy">Chats de esta guía</p>
                <% if (practiceGuideConversations.length > 0) { %>
                  <div class="practice-guide-chat-list list-group">
                    <% practiceGuideConversations.forEach((conversation) => { %>
                      <a
                        class="practice-guide-chat-item list-group-item list-group-item-action d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-1"
                        href="/c/<%= encodeURIComponent(conversation.id) %>"
                      >
                        <span class="practice-guide-chat-title"><%= conversation.title %></span>
                        <time class="practice-guide-chat-date" datetime="<%= conversation.updatedAt %>">
                          <%= conversation.updatedAt %>
                        </time>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="practice-guide-empty mb-0">Todavía no hay chats para esta guía.</p>
                <% } %>
              </div>
            </section>
          <% } else if (practiceGuidePageMode === 'new' || practiceGuidePageMode === 'edit') { %>
            <section class="resource-page-form-shell">
              <div class="resource-page-form-card card">
                <div class="card-body">
                  <% if (practiceGuidePageMode === 'new' || (practiceGuidePageMode === 'edit' && selectedPracticeGuide)) { %>
                    <div class="d-flex justify-content-end mb-4">
                      <% if (practiceGuidePageMode === 'new') { %>
                        <button
                          class="btn btn-secondary"
                          type="button"
                          data-bs-toggle="modal"
                          data-bs-target="#generatePracticeGuideModal"
                        >
                          <i class="bi bi-stars me-1" aria-hidden="true"></i>
                          Crear con IA
                        </button>
                      <% } else { %>
                        <button
                          class="btn btn-secondary"
                          type="button"
                          data-bs-toggle="modal"
                          data-bs-target="#revisePracticeGuideModal"
                        >
                          <i class="bi bi-stars me-1" aria-hidden="true"></i>
                          Editar con IA
                        </button>
                      <% } %>
                    </div>
                  <% } %>

                  <% if (practiceGuideRevisionSuccess) { %>
                    <div class="alert alert-success mb-4" role="status">
                      Actualicé la guía con IA. Revisa los cambios antes de probarla.
                    </div>
                  <% } %>

                  <% if (practiceGuideGenerationError) { %>
                    <div class="alert alert-warning mb-4" role="alert">
                      <strong>No pude generar la guía automáticamente.</strong>
                      <div><%= practiceGuideGenerationError %></div>
                    </div>
                  <% } %>

                  <form
                    class="practice-guide-form"
                    method="post"
                    action="<%= practiceGuidePageMode === 'edit' && selectedPracticeGuide ? `/practice-guides/${encodeURIComponent(selectedPracticeGuide.id)}` : '/practice-guides' %>"
                    autocomplete="off"
                  >
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <label class="form-label" for="practiceGuideTitle">
                      Título
                    </label>
                    <input
                      class="form-control"
                      id="practiceGuideTitle"
                      name="title"
                      maxlength="120"
                      value="<%= typeof practiceGuideDraftValues.title === 'string' ? practiceGuideDraftValues.title : (practiceGuidePageMode === 'edit' && selectedPracticeGuide ? selectedPracticeGuide.title : '') %>"
                      required
                    >

                    <label class="form-label" for="practiceGuideDescription">
                      Descripción
                    </label>
                    <textarea
                      class="form-control"
                      id="practiceGuideDescription"
                      name="description"
                      rows="4"
                      maxlength="500"
                      required
                      placeholder="Describe la práctica con Markdown sencillo."
                      data-markdown-editor
                      data-markdown-editor-required="true"
                      data-markdown-editor-error="practiceGuideDescriptionError"
                      data-markdown-editor-min-height="8rem"
                    ><%= typeof practiceGuideDraftValues.description === 'string' ? practiceGuideDraftValues.description : (practiceGuidePageMode === 'edit' && selectedPracticeGuide ? selectedPracticeGuide.description : '') %></textarea>
                    <div class="invalid-feedback" id="practiceGuideDescriptionError" hidden>
                      Escribe una descripción para la guía.
                    </div>

                    <div class="practice-guide-help-row">
                      <label class="form-label" for="practiceGuideTutorInstructions">
                        Instrucciones al tutor
                      </label>
                      <button
                        class="btn btn-link practice-guide-help-button"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#practiceGuideHelpModal"
                      >
                        <i class="bi bi-question-circle me-1" aria-hidden="true"></i>
                        Ayuda
                      </button>
                    </div>
                    <textarea
                      class="form-control"
                      id="practiceGuideTutorInstructions"
                      name="tutorInstructions"
                      rows="10"
                      maxlength="4000"
                      required
                      placeholder="Escribe las instrucciones del tutor con Markdown sencillo."
                      data-markdown-editor
                      data-markdown-editor-required="true"
                      data-markdown-editor-error="practiceGuideTutorInstructionsError"
                      data-markdown-editor-min-height="18rem"
                    ><%= typeof practiceGuideDraftValues.tutorInstructions === 'string' ? practiceGuideDraftValues.tutorInstructions : (practiceGuidePageMode === 'edit' && selectedPracticeGuide ? selectedPracticeGuide.tutorInstructions : '') %></textarea>
                    <div class="invalid-feedback" id="practiceGuideTutorInstructionsError" hidden>
                      Escribe las instrucciones del tutor.
                    </div>

                    <div class="practice-guide-form-actions">
                      <button type="submit" class="btn btn-primary">
                        <%= practiceGuidePageMode === 'edit' ? 'Guardar cambios' : 'Crear guía' %>
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </section>
          <% } else if (practiceGuidePageMode === 'share' && selectedSharedPracticeGuide && selectedPracticeGuideShareLink) { %>
            <section class="resource-page-form-shell">
              <div class="resource-page-form-card card">
                <div class="card-body">
                  <div class="d-grid gap-3">
                    <p class="mb-0 text-body-secondary">
                      <% if (activeProfile) { %>
                        Esta guía fue compartida contigo. Revísala y decide si quieres agregarla al perfil <strong><%= activeProfile.name %></strong>.
                      <% } else { %>
                        Esta guía fue compartida contigo. Puedes revisarla ahora mismo y, si te interesa, iniciar sesión o crear una cuenta para agregarla a tus recursos.
                      <% } %>
                    </p>

                    <div class="card">
                      <div class="card-body">
                        <p class="resource-page-section-copy mt-0">Descripción</p>
                        <div class="resource-markdown mb-3" data-render-markdown><%= selectedSharedPracticeGuide.description %></div>
                        <p class="resource-page-section-copy">Instrucciones al tutor</p>
                        <div class="resource-markdown" data-render-markdown><%= selectedSharedPracticeGuide.tutorInstructions %></div>
                      </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                      <a class="btn btn-secondary" href="<%= isAuthenticated ? '/resources' : '/' %>">No ahora</a>
                      <% if (isAuthenticated && activeProfile) { %>
                        <form method="post" action="/resources/shared/<%= encodeURIComponent(selectedPracticeGuideShareLink.id) %>/accept">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-primary" type="submit">Agregar a mis recursos</button>
                        </form>
                      <% } else { %>
                        <a class="btn btn-secondary" href="/signup?returnTo=<%= encodeURIComponent(`/resources/shared/${selectedPracticeGuideShareLink.id}`) %>">Crear cuenta</a>
                        <a class="btn btn-primary" href="/login?returnTo=<%= encodeURIComponent(`/resources/shared/${selectedPracticeGuideShareLink.id}`) %>">Iniciar sesión</a>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </section>
          <% } %>
        </section>

        <div
          class="modal fade"
          id="practiceGuideHelpModal"
          tabindex="-1"
          aria-labelledby="practiceGuideHelpModalLabel"
          aria-hidden="true"
        >
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h2 class="modal-title fs-5" id="practiceGuideHelpModalLabel">Instrucciones al tutor</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
              </div>
              <div class="modal-body">
                <p class="mb-2">
                  Describe el objetivo de práctica, el nivel esperado, los errores que quieres corregir y el tipo de ayuda que debe ofrecer Mr. F.
                </p>
                <p class="mb-0 text-body-secondary">
                  También puedes indicar si quieres que el tutor use ejemplos, preguntas de seguimiento, correcciones breves o práctica guiada.
                </p>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
              </div>
            </div>
          </div>
        </div>

        <% if (practiceGuidePageMode === 'new') { %>
          <div
            class="modal fade"
            id="generatePracticeGuideModal"
            tabindex="-1"
            aria-labelledby="generatePracticeGuideModalLabel"
            aria-hidden="true"
            <% if (practiceGuideGenerationModalAutoOpen) { %>data-auto-open-modal="true"<% } %>
          >
            <div class="modal-dialog modal-lg modal-dialog-centered">
              <div class="modal-content">
                <form method="post" action="/practice-guides/generate-draft" data-resource-generate-form>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="resourceLabel" value="guía de práctica">
                  <div class="modal-header">
                    <h2 class="modal-title fs-5" id="generatePracticeGuideModalLabel">Crear guía con IA</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                  </div>
                  <div class="modal-body d-grid gap-3">
                    <p class="mb-0 text-body-secondary">
                      Describe qué quieres practicar, para qué nivel y qué tipo de interacción debería guiar Mr. F.
                    </p>
                    <% if (practiceGuideGenerationError) { %>
                      <div class="alert alert-warning mb-0" role="alert">
                        <strong>No pude generar la guía automáticamente.</strong>
                        <div><%= practiceGuideGenerationError %></div>
                        <% if (practiceGuideGenerationCreditExhausted) { %>
                          <a class="btn btn-primary btn-sm mt-3" href="/credits?returnTo=<%= encodeURIComponent('/practice-guides/new') %>">Comprar créditos</a>
                        <% } %>
                      </div>
                    <% } %>
                    <label class="form-label mb-0" for="practiceGuideGenerationPrompt">Describe la guía que quieres crear</label>
                    <textarea
                      class="form-control"
                      id="practiceGuideGenerationPrompt"
                      name="prompt"
                      rows="6"
                      required
                    ><%= practiceGuideGenerationPrompt || '' %></textarea>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button
                      type="submit"
                      class="btn btn-primary"
                      data-resource-generate-submit
                      data-loading-text="Creando..."
                    >
                      Crear
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% } %>

        <% if (practiceGuidePageMode === 'edit' && selectedPracticeGuide) { %>
          <div
            class="modal fade"
            id="revisePracticeGuideModal"
            tabindex="-1"
            aria-labelledby="revisePracticeGuideModalLabel"
            aria-hidden="true"
            <% if (practiceGuideRevisionModalAutoOpen) { %>data-auto-open-modal="true"<% } %>
          >
            <div class="modal-dialog modal-lg modal-dialog-centered">
              <div class="modal-content">
                <form method="post" action="/practice-guides/<%= encodeURIComponent(selectedPracticeGuide.id) %>/revise" data-resource-generate-form>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <div class="modal-header">
                    <h2 class="modal-title fs-5" id="revisePracticeGuideModalLabel">Editar guía con IA</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                  </div>
                  <div class="modal-body d-grid gap-3">
                    <p class="mb-0 text-body-secondary">
                      Describe los cambios que quieres aplicar al título, la descripción o las instrucciones del tutor. La IA conservará lo que no pidas cambiar.
                    </p>
                    <% if (practiceGuideRevisionError) { %>
                      <div class="alert alert-warning mb-0" role="alert">
                        <strong>No pude editar la guía automáticamente.</strong>
                        <div><%= practiceGuideRevisionError %></div>
                        <% if (practiceGuideRevisionCreditExhausted) { %>
                          <a class="btn btn-primary btn-sm mt-3" href="/credits?returnTo=<%= encodeURIComponent(`/practice-guides/${selectedPracticeGuide.id}/edit`) %>">Comprar créditos</a>
                        <% } %>
                      </div>
                    <% } %>
                    <label class="form-label mb-0" for="practiceGuideRevisionPrompt">Cambios que deseas aplicar</label>
                    <textarea
                      class="form-control"
                      id="practiceGuideRevisionPrompt"
                      name="prompt"
                      rows="6"
                      required
                    ><%= practiceGuideRevisionPrompt || '' %></textarea>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button
                      type="submit"
                      class="btn btn-primary"
                      data-resource-generate-submit
                      data-loading-text="Actualizando..."
                    >
                      Aplicar cambios
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% } %>

        <% if (practiceGuidePageMode === 'new' || (practiceGuidePageMode === 'edit' && selectedPracticeGuide)) { %>
          <div
            class="modal fade"
            id="practiceGuideGenerationPendingModal"
            tabindex="-1"
            aria-labelledby="practiceGuideGenerationPendingModalLabel"
            aria-hidden="true"
            data-resource-pending-modal
            data-resource-pending-label="guía de práctica"
            data-bs-backdrop="static"
            data-bs-keyboard="false"
          >
            <div class="modal-dialog modal-dialog-centered modal-sm">
              <div class="modal-content">
                <div class="modal-body text-center py-4 d-grid gap-3">
                  <div
                    class="spinner-border text-primary mx-auto"
                    role="status"
                    aria-hidden="true"
                  ></div>
                  <div>
                    <h2 class="fs-6 mb-1" id="practiceGuideGenerationPendingModalLabel">
                      <%= practiceGuidePageMode === 'edit' ? 'Actualizando guía...' : 'Creando guía...' %>
                    </h2>
                    <p class="mb-0 text-body-secondary small">
                      Esto puede tardar unos segundos.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

        <% } %>

        <% if (practiceGuidePageMode === 'detail' && selectedPracticeGuide && canManagePracticeGuide) { %>
          <div
            class="modal fade"
            id="sharePracticeGuideProfileModal"
            tabindex="-1"
            aria-labelledby="sharePracticeGuideProfileModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeGuideProfileModalLabel">Compartir con perfil</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <% if (shareTargetPracticeGuideProfiles.length > 0) { %>
                    <form method="post" action="/practice-guides/<%= encodeURIComponent(selectedPracticeGuide.id) %>/share/profile" class="d-grid gap-3">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <div>
                        <label class="form-label" for="shareTargetProfileId">Perfil destino</label>
                        <select class="form-select" id="shareTargetProfileId" name="targetProfileId" required>
                          <% shareTargetPracticeGuideProfiles.forEach((profile) => { %>
                            <option value="<%= profile.id %>"><%= profile.name %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Compartir ahora</button>
                      </div>
                    </form>
                  <% } else { %>
                    <p class="mb-0 text-body-secondary">No tienes otros perfiles disponibles para recibir esta guía.</p>
                  <% } %>
                </div>
                <% if (shareTargetPracticeGuideProfiles.length === 0) { %>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="sharePracticeGuideLinkModal"
            tabindex="-1"
            aria-labelledby="sharePracticeGuideLinkModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeGuideLinkModalLabel">Enlace para compartir</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body d-grid gap-3">
                  <p class="mb-0 text-body-secondary">
                    Quienes usen este enlace verán siempre la versión actual de esta guía.
                  </p>
                  <div>
                    <label class="form-label" for="practiceGuideShareLinkField">Enlace</label>
                    <input
                      class="form-control"
                      id="practiceGuideShareLinkField"
                      type="text"
                      readonly
                      value="<%= practiceGuideShareUrl %>"
                      data-practiceGuide-share-link-field
                    >
                  </div>
                  <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-secondary" type="button" data-copy-practiceGuide-share-link>
                      <i class="bi bi-copy me-1" aria-hidden="true"></i>
                      Copiar
                    </button>
                    <button class="btn btn-outline-secondary" type="button" data-native-share-practiceGuide-link>
                      <i class="bi bi-share me-1" aria-hidden="true"></i>
                      Compartir
                    </button>
                  </div>
                  <% if (practiceGuideShareQrDataUrl) { %>
                    <div class="d-flex justify-content-center">
                      <img
                        class="practiceGuide-share-qr"
                        src="<%= practiceGuideShareQrDataUrl %>"
                        alt="QR del enlace para compartir la guía"
                        width="180"
                        height="180"
                      >
                    </div>
                  <% } %>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
                </div>
              </div>
            </div>
          </div>

          <%- include('resource-move-modal', {
            resourceMoveCurrentFolder: practiceGuideCurrentFolder,
            resourceMoveFolderOptions: practiceGuideFolderOptions,
          }) %>
        <% } %>
