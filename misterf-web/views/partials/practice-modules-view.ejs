                              <a class="dropdown-item" href="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>?share=profile">Compartir con perfil</a>
                              <a class="dropdown-item" href="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>?share=link">Obtener enlace</a>
                            </div>
                          </div>
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/favorite">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="favorite" value="<%= practiceModule.isFavorite ? '0' : '1' %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="<%= practiceModule.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>" aria-label="<%= practiceModule.isFavorite ? 'Quitar de favoritas' : 'Marcar como favorita' %>">
                              <i class="bi <%= practiceModule.isFavorite ? 'bi-star-fill' : 'bi-star' %>" aria-hidden="true"></i>
                            </button>
                          </form>
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/archive">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Archivar módulo de práctica" aria-label="Archivar módulo de práctica">
                              <i class="bi bi-archive" aria-hidden="true"></i>
                            </button>
                          </form>
                        </div>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>

              <% if (showArchivedPracticeModules && (archivedPracticeModuleCollections.length > 0 || archivedPracticeModules.length > 0)) { %>
                <div class="d-flex align-items-center justify-content-between mb-3 mt-4">
                  <h2 class="h5 mb-0">Archivados</h2>
                  <span class="badge text-bg-light border"><%= archivedPracticeModuleCollections.length + archivedPracticeModules.length %></span>
                </div>
                <div class="list-group shadow-sm">
                  <% archivedPracticeModuleCollections.forEach((collection) => { %>
                    <div class="list-group-item">
                      <div class="d-flex flex-column flex-sm-row align-items-sm-start justify-content-between gap-3">
                        <div class="min-w-0 d-grid gap-2">
                          <div class="d-flex align-items-center gap-2 flex-wrap">
                            <p class="practice-module-card-kicker mb-0">Colección</p>
                            <span class="badge text-bg-light border">Archivado</span>
                            <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">
                              <%= collection.moduleCount %> <%= collection.moduleCount === 1 ? 'módulo' : 'módulos' %>
                            </span>
                          </div>
                          <h2 class="h5 practice-module-card-title mb-0">
                            <a
                              class="practice-module-card-link text-decoration-none text-reset"
                              href="/practice-modules/collections/<%= encodeURIComponent(collection.id) %>"
                            >
                              <%= collection.title %>
                            </a>
                          </h2>
                          <p class="mb-0 text-body-secondary"><%= collection.description || 'Agrupa varios módulos de práctica bajo un mismo tema o propósito.' %></p>
                          <% if (collection.sourceProfileName) { %>
                            <p class="mb-0 text-body-secondary small">Compartida por <%= collection.sourceProfileName %></p>
                          <% } %>
                        </div>
                        <div class="practice-module-card-actions btn-group" role="group" aria-label="Acciones rápidas">
                          <form method="post" action="/practice-modules/collections/<%= encodeURIComponent(collection.id) %>/restore">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Restaurar colección" aria-label="Restaurar colección">
                              <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                            </button>
                          </form>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                  <% archivedPracticeModules.forEach((practiceModule) => { %>
                    <div class="list-group-item">
                      <div class="d-flex flex-column flex-sm-row align-items-sm-start justify-content-between gap-3">
                        <div class="min-w-0 d-grid gap-2">
                          <div class="d-flex align-items-center gap-2 flex-wrap">
                            <p class="practice-module-card-kicker mb-0">Módulo de práctica</p>
                            <span class="badge text-bg-light border">Archivado</span>
                            <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">
                              <%= practiceModule.conversationCount %> <%= practiceModule.conversationCount === 1 ? 'chat' : 'chats' %>
                            </span>
                          </div>
                          <h2 class="h5 practice-module-card-title mb-0">
                            <a
                              class="practice-module-card-link text-decoration-none text-reset"
                              href="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>"
                            >
                              <%= practiceModule.title %>
                            </a>
                          </h2>
                          <p class="mb-0 text-body-secondary"><%= practiceModule.description %></p>
                          <% if (practiceModule.sourceProfileName) { %>
                            <p class="mb-0 text-body-secondary small">Compartida por <%= practiceModule.sourceProfileName %></p>
                          <% } %>
                        </div>
                        <div class="practice-module-card-actions btn-group" role="group" aria-label="Acciones rápidas">
                          <form method="post" action="/practice-modules/<%= encodeURIComponent(practiceModule.id) %>/restore">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="returnTo" value="<%= currentPath %>">
                            <button class="btn btn-sm btn-link link-body-emphasis text-decoration-none p-0" type="submit" title="Restaurar módulo de práctica" aria-label="Restaurar módulo de práctica">
                              <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                            </button>
                          </form>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            <% } else { %>
              <div class="practice-module-empty-state alert alert-light border">
                <p>
                  <%= practiceModuleFilterQuery
                    ? 'No encontré módulos de práctica que coincidan con ese texto.'
                    : 'Todavía no hay módulos de práctica. Crea el primero y dale un marco propio al tutor.' %>
                </p>
              </div>
            <% } %>
          <% } %>

          <% if (practiceModulePageMode === 'list') { %>
            <div
              class="modal fade"
              id="generatePracticeModuleModal"
              tabindex="-1"
              aria-labelledby="generatePracticeModuleModalLabel"
              aria-hidden="true"
              <% if (practiceModuleGenerationModalAutoOpen) { %>data-auto-open-modal="true"<% } %>
            >
              <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                  <form method="post" action="/practice-modules/generate-draft">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="modal-header">
                      <h2 class="modal-title fs-5" id="generatePracticeModuleModalLabel">Crear módulo de práctica</h2>
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body d-grid gap-3">
                      <p class="mb-0 text-body-secondary">
                        Describe qué quieres practicar, para qué nivel y qué tipo de ejercicios te gustaría que Mr. F use. El módulo se creará automáticamente y después podrás revisar sus datos y editarlo si quieres.
                      </p>
                      <% if (practiceModuleGenerationError) { %>
                        <div class="alert alert-warning mb-0" role="alert">
                          <strong>No pude generar el módulo automáticamente.</strong>
                          <div><%= practiceModuleGenerationError %></div>
                        </div>
                      <% } %>
                      <div class="accordion" id="practiceModuleGenerationExamplesAccordion">
                        <div class="accordion-item">
                          <h3 class="accordion-header">
                            <button
                              class="accordion-button collapsed"
                              type="button"
                              data-bs-toggle="collapse"
                              data-bs-target="#practiceModuleGenerationExamples"
                              aria-expanded="false"
                              aria-controls="practiceModuleGenerationExamples"
                            >
                              Ejemplos útiles de qué puedes incluir
                            </button>
                          </h3>
                          <div
                            id="practiceModuleGenerationExamples"
                            class="accordion-collapse collapse"
                            data-bs-parent="#practiceModuleGenerationExamplesAccordion"
                          >
                            <div class="accordion-body">
                              <p class="mb-2">
                                Puedes mencionar el tema gramatical o comunicativo, el nivel aproximado, los errores que quieres trabajar, el contexto de uso y estilos de ejercicio como fill in the blank, multiple choice o producción guiada.
                              </p>
                              <p class="mb-0 text-body-secondary">
                                Ejemplo: un módulo intermedio para practicar preguntas en pasado y pasado simple vs pasado continuo, con ejercicios breves y corrección guiada.
                              </p>
                            </div>
                          </div>
                        </div>
                      </div>
                      <label class="form-label mb-0" for="practiceModuleGenerationPrompt">Describe el módulo que quieres crear</label>
                      <textarea
                        class="form-control"
                        id="practiceModuleGenerationPrompt"
                        name="prompt"
                        rows="6"
                        required
                      ><%= practiceModuleGenerationPrompt || '' %></textarea>
                    </div>
                    <div class="modal-footer">
                      <button type="submit" class="btn btn-dark">Crear</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          <% } %>
        </section>

        <% if (currentView === 'practiceModules' && practiceModulePageMode === 'detail' && selectedPracticeModule) { %>
          <div
            class="modal fade"
            id="sharePracticeModuleProfileModal"
            tabindex="-1"
            aria-labelledby="sharePracticeModuleProfileModalLabel"
            aria-hidden="true"
            <%= practiceModuleShareMode === 'profile' ? 'data-auto-open-share-modal' : '' %>
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeModuleProfileModalLabel">Compartir con perfil</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <% if (shareTargetPracticeModuleProfiles.length > 0) { %>
                    <form method="post" action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/share/profile" class="d-grid gap-3">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <div>
                        <label class="form-label" for="shareTargetProfileId">Perfil destino</label>
                        <select class="form-select" id="shareTargetProfileId" name="targetProfileId" required>
                          <% shareTargetPracticeModuleProfiles.forEach((profile) => { %>
                            <option value="<%= profile.id %>"><%= profile.name %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-dark">Compartir ahora</button>
                      </div>
                    </form>
                  <% } else { %>
                    <p class="mb-0 text-body-secondary">No tienes otros perfiles disponibles para recibir este módulo de práctica.</p>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="sharePracticeModuleLinkModal"
            tabindex="-1"
            aria-labelledby="sharePracticeModuleLinkModalLabel"
            aria-hidden="true"
            <%= practiceModuleShareMode === 'link' ? 'data-auto-open-share-modal' : '' %>
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeModuleLinkModalLabel">Enlace para compartir</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body d-grid gap-3">
                  <div>
                    <label class="form-label" for="practiceModuleShareLinkField">Enlace</label>
                    <input
                      class="form-control"
                      id="practiceModuleShareLinkField"
                      type="text"
                      readonly
                      value="<%= practiceModuleShareUrl %>"
                      data-practiceModule-share-link-field
                    >
                  </div>
                  <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-dark" type="button" data-copy-practiceModule-share-link>
                      <i class="bi bi-copy me-1" aria-hidden="true"></i>
                      Copiar
                    </button>
                    <button class="btn btn-outline-dark" type="button" data-native-share-practiceModule-link>
                      <i class="bi bi-share me-1" aria-hidden="true"></i>
                      Compartir
                    </button>
                  </div>
                  <% if (practiceModuleShareQrDataUrl) { %>
                    <div class="d-flex justify-content-center">
                      <img
                        class="practiceModule-share-qr"
                        src="<%= practiceModuleShareQrDataUrl %>"
                        alt="QR del enlace para compartir el módulo de práctica"
                        width="180"
                        height="180"
                      >
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <% if (currentView === 'practiceModules' && practiceModulePageMode === 'collectionDetail' && selectedPracticeModuleCollection) { %>
          <div
            class="modal fade"
            id="sharePracticeModuleCollectionProfileModal"
            tabindex="-1"
            aria-labelledby="sharePracticeModuleCollectionProfileModalLabel"
            aria-hidden="true"
            <%= practiceModuleShareMode === 'profile' ? 'data-auto-open-share-modal' : '' %>
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeModuleCollectionProfileModalLabel">Compartir colección con perfil</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <% if (shareTargetPracticeModuleCollectionProfiles.length > 0) { %>
                    <form method="post" action="/practice-modules/collections/<%= encodeURIComponent(selectedPracticeModuleCollection.id) %>/share/profile" class="d-grid gap-3">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <div>
                        <label class="form-label" for="shareTargetPracticeModuleCollectionProfileId">Perfil destino</label>
                        <select class="form-select" id="shareTargetPracticeModuleCollectionProfileId" name="targetProfileId" required>
                          <% shareTargetPracticeModuleCollectionProfiles.forEach((profile) => { %>
                            <option value="<%= profile.id %>"><%= profile.name %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-dark">Compartir ahora</button>
                      </div>
                    </form>
                  <% } else { %>
                    <p class="mb-0 text-body-secondary">No tienes otros perfiles disponibles para recibir esta colección.</p>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="sharePracticeModuleCollectionLinkModal"
            tabindex="-1"
            aria-labelledby="sharePracticeModuleCollectionLinkModalLabel"
            aria-hidden="true"
            <%= practiceModuleShareMode === 'link' ? 'data-auto-open-share-modal' : '' %>
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeModuleCollectionLinkModalLabel">Enlace para compartir colección</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body d-grid gap-3">
                  <div>
                    <label class="form-label" for="practiceModuleCollectionShareLinkField">Enlace</label>
                    <input
                      class="form-control"
                      id="practiceModuleCollectionShareLinkField"
                      type="text"
                      readonly
                      value="<%= practiceModuleCollectionShareUrl %>"
                      data-practiceModule-share-link-field
                    >
                  </div>
                  <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-dark" type="button" data-copy-practiceModule-share-link>
                      <i class="bi bi-copy me-1" aria-hidden="true"></i>
                      Copiar
                    </button>
                    <button class="btn btn-outline-dark" type="button" data-native-share-practiceModule-link>
                      <i class="bi bi-share me-1" aria-hidden="true"></i>
                      Compartir
                    </button>
                  </div>
                  <% if (practiceModuleCollectionShareQrDataUrl) { %>
                    <div class="d-flex justify-content-center">
                      <img
                        class="practiceModule-share-qr"
                        src="<%= practiceModuleCollectionShareQrDataUrl %>"
                        alt="QR del enlace para compartir la colección"
                        width="180"
                        height="180"
                      >
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% } %>
