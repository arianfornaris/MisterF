        <%
          const practiceModuleDraftValues = typeof practiceModuleFormValues === 'object' && practiceModuleFormValues
            ? practiceModuleFormValues
            : {};
          const practiceModuleCloseHref = practiceModulePageMode === 'edit' && selectedPracticeModule
            ? `/practice-modules/${encodeURIComponent(selectedPracticeModule.id)}`
            : '/resources';
        %>
        <section
          class="app-resource-view practice-modules-page"
          aria-label="Guías de práctica"
        >
          <div class="resource-page-header resource-page-header-detail resource-page-header-has-close">
            <div>
              <p class="resource-page-kicker">Guías de práctica</p>
              <h1 class="resource-page-title">
                <% if (practiceModulePageMode === 'new') { %>
                  Nueva guía de práctica
                <% } else if (practiceModulePageMode === 'edit') { %>
                  Editar guía de práctica
                <% } else if (practiceModulePageMode === 'share') { %>
                  <%= selectedSharedPracticeModule ? selectedSharedPracticeModule.title : 'Guía de práctica compartida' %>
                <% } else { %>
                  <%= selectedPracticeModule ? selectedPracticeModule.title : 'Guía de práctica' %>
                <% } %>
              </h1>
              <% if (practiceModulePageMode === 'share' && selectedSharedPracticeModule) { %>
                <div class="resource-page-copy resource-markdown" data-render-markdown><%= selectedSharedPracticeModule.description %></div>
              <% } else { %>
                <p class="resource-page-copy">
                  <% if (practiceModulePageMode === 'new') { %>
                    Diseña una guía con un objetivo claro, una descripción útil y reglas precisas para el tutor.
                  <% } else if (practiceModulePageMode === 'edit') { %>
                    Ajusta esta guía con calma. Los chats existentes conservarán su propia copia del contenido original.
                  <% } else if (practiceModulePageMode === 'share') { %>
                    Te compartieron una guía de práctica.
                  <% } else { %>
                    Revisa esta guía y sus chats antes de editarla, compartirla o volver a utilizarla.
                  <% } %>
                </p>
              <% } %>
            </div>

            <div class="resource-page-header-actions">
              <a
                class="resource-page-close-button"
                href="<%= practiceModuleCloseHref %>"
                title="Cerrar"
                aria-label="Cerrar"
              >
                <i class="bi bi-x-lg" aria-hidden="true"></i>
              </a>
            </div>
          </div>

          <% if (practiceModulePageMode === 'detail' && selectedPracticeModule) { %>
            <section class="resource-page-detail-shell">
              <div class="d-grid gap-3">
                <div class="d-flex flex-wrap align-items-center gap-2">
                  <form method="post" action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/chats">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-primary" type="submit">
                      <i class="bi bi-play-fill me-1" aria-hidden="true"></i>
                      Probar
                    </button>
                  </form>

                  <div class="dropdown">
                    <button
                      class="btn btn-secondary dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                    >
                      Opciones
                    </button>
                    <ul class="dropdown-menu">
                      <% if (!selectedPracticeModule.archivedAt) { %>
                        <li>
                          <button
                            class="dropdown-item"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#sharePracticeModuleProfileModal"
                          >
                            <i class="bi bi-person me-2" aria-hidden="true"></i>
                            Compartir con perfil
                          </button>
                        </li>
                        <li>
                          <button
                            class="dropdown-item"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#sharePracticeModuleLinkModal"
                          >
                            <i class="bi bi-link-45deg me-2" aria-hidden="true"></i>
                            Obtener enlace
                          </button>
                        </li>
                        <li>
                          <a
                            class="dropdown-item"
                            href="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/edit"
                          >
                            <i class="bi bi-pencil me-2" aria-hidden="true"></i>
                            Editar guía
                          </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                      <% } %>
                      <li>
                        <form
                          method="post"
                          action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/<%= selectedPracticeModule.archivedAt ? 'restore' : 'archive' %>"
                          onsubmit="return window.confirm('<%= selectedPracticeModule.archivedAt ? '¿Seguro que quieres restaurar esta guía?' : '¿Seguro que quieres archivar esta guía? Podrás recuperarla después desde Archivados.' %>');"
                        >
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <input type="hidden" name="returnTo" value="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>">
                          <button class="dropdown-item" type="submit">
                            <i class="bi <%= selectedPracticeModule.archivedAt ? 'bi-arrow-counterclockwise' : 'bi-archive' %> me-2" aria-hidden="true"></i>
                            <%= selectedPracticeModule.archivedAt ? 'Restaurar guía' : 'Archivar guía' %>
                          </button>
                        </form>
                      </li>
                    </ul>
                  </div>
                </div>

                <% if (selectedPracticeModule.sharedVia) { %>
                  <div class="d-flex">
                    <% if (selectedPracticeModuleSharedFromProfileName) { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida por <%= selectedPracticeModuleSharedFromProfileName %>
                      </span>
                    <% } else { %>
                      <span class="badge text-bg-light border practice-module-shared-badge" role="status">
                        Compartida <%= selectedPracticeModule.sharedVia === 'link' ? 'por enlace' : 'desde otro perfil' %>
                      </span>
                    <% } %>
                  </div>
                <% } %>

                <p class="resource-page-section-copy">Descripción</p>
                <div class="card">
                  <div class="card-body">
                    <div class="resource-markdown" data-render-markdown><%= selectedPracticeModule.description %></div>
                  </div>
                </div>

                <p class="resource-page-section-copy">Instrucciones al tutor</p>
                <div class="card">
                  <div class="card-body">
                    <div class="resource-markdown" data-render-markdown><%= selectedPracticeModule.tutorInstructions %></div>
                  </div>
                </div>

                <p class="resource-page-section-copy">Chats de esta guía</p>
                <% if (practiceModuleConversations.length > 0) { %>
                  <div class="practice-module-chat-list list-group">
                    <% practiceModuleConversations.forEach((conversation) => { %>
                      <a
                        class="practice-module-chat-item list-group-item list-group-item-action d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-1"
                        href="/c/<%= encodeURIComponent(conversation.id) %>"
                      >
                        <span class="practice-module-chat-title"><%= conversation.title %></span>
                        <time class="practice-module-chat-date" datetime="<%= conversation.updatedAt %>">
                          <%= conversation.updatedAt %>
                        </time>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="practice-module-empty mb-0">Todavía no hay chats para esta guía.</p>
                <% } %>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'new' || practiceModulePageMode === 'edit') { %>
            <section class="resource-page-form-shell">
              <div class="resource-page-form-card card">
                <div class="card-body">
                  <% if (practiceModulePageMode === 'new' || (practiceModulePageMode === 'edit' && selectedPracticeModule)) { %>
                    <div class="d-flex justify-content-end mb-4">
                      <% if (practiceModulePageMode === 'new') { %>
                        <button
                          class="btn btn-secondary"
                          type="button"
                          data-bs-toggle="modal"
                          data-bs-target="#generatePracticeModuleModal"
                        >
                          <i class="bi bi-stars me-1" aria-hidden="true"></i>
                          Crear con IA
                        </button>
                      <% } else { %>
                        <button
                          class="btn btn-secondary"
                          type="button"
                          data-bs-toggle="modal"
                          data-bs-target="#revisePracticeModuleModal"
                        >
                          <i class="bi bi-stars me-1" aria-hidden="true"></i>
                          Editar con IA
                        </button>
                      <% } %>
                    </div>
                  <% } %>

                  <% if (practiceModuleRevisionSuccess) { %>
                    <div class="alert alert-success mb-4" role="status">
                      Actualicé la guía con IA. Revisa los cambios antes de probarla.
                    </div>
                  <% } %>

                  <% if (practiceModuleGenerationError) { %>
                    <div class="alert alert-warning mb-4" role="alert">
                      <strong>No pude generar la guía automáticamente.</strong>
                      <div><%= practiceModuleGenerationError %></div>
                    </div>
                  <% } %>

                  <form
                    class="practice-module-form"
                    method="post"
                    action="<%= practiceModulePageMode === 'edit' && selectedPracticeModule ? `/practice-modules/${encodeURIComponent(selectedPracticeModule.id)}` : '/practice-modules' %>"
                    autocomplete="off"
                  >
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <label class="form-label" for="practiceModuleTitle">
                      Título
                    </label>
                    <input
                      class="form-control"
                      id="practiceModuleTitle"
                      name="title"
                      maxlength="120"
                      value="<%= typeof practiceModuleDraftValues.title === 'string' ? practiceModuleDraftValues.title : (practiceModulePageMode === 'edit' && selectedPracticeModule ? selectedPracticeModule.title : '') %>"
                      required
                    >

                    <label class="form-label" for="practiceModuleDescription">
                      Descripción
                    </label>
                    <textarea
                      class="form-control"
                      id="practiceModuleDescription"
                      name="description"
                      rows="4"
                      maxlength="500"
                      required
                      placeholder="Describe la práctica con Markdown sencillo."
                      data-markdown-editor
                      data-markdown-editor-required="true"
                      data-markdown-editor-error="practiceModuleDescriptionError"
                      data-markdown-editor-min-height="8rem"
                    ><%= typeof practiceModuleDraftValues.description === 'string' ? practiceModuleDraftValues.description : (practiceModulePageMode === 'edit' && selectedPracticeModule ? selectedPracticeModule.description : '') %></textarea>
                    <div class="invalid-feedback" id="practiceModuleDescriptionError" hidden>
                      Escribe una descripción para la guía.
                    </div>

                    <div class="practice-module-help-row">
                      <label class="form-label" for="practiceModuleTutorInstructions">
                        Instrucciones al tutor
                      </label>
                      <button
                        class="btn btn-link practice-module-help-button"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#practiceModuleHelpModal"
                      >
                        <i class="bi bi-question-circle me-1" aria-hidden="true"></i>
                        Ayuda
                      </button>
                    </div>
                    <textarea
                      class="form-control"
                      id="practiceModuleTutorInstructions"
                      name="tutorInstructions"
                      rows="10"
                      maxlength="4000"
                      required
                      placeholder="Escribe las instrucciones del tutor con Markdown sencillo."
                      data-markdown-editor
                      data-markdown-editor-required="true"
                      data-markdown-editor-error="practiceModuleTutorInstructionsError"
                      data-markdown-editor-min-height="18rem"
                    ><%= typeof practiceModuleDraftValues.tutorInstructions === 'string' ? practiceModuleDraftValues.tutorInstructions : (practiceModulePageMode === 'edit' && selectedPracticeModule ? selectedPracticeModule.tutorInstructions : '') %></textarea>
                    <div class="invalid-feedback" id="practiceModuleTutorInstructionsError" hidden>
                      Escribe las instrucciones del tutor.
                    </div>

                    <div class="practice-module-form-actions">
                      <button type="submit" class="btn btn-primary">
                        <%= practiceModulePageMode === 'edit' ? 'Guardar cambios' : 'Crear guía' %>
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </section>
          <% } else if (practiceModulePageMode === 'share' && selectedSharedPracticeModule && selectedPracticeModuleShareLink) { %>
            <section class="resource-page-form-shell">
              <div class="resource-page-form-card card">
                <div class="card-body">
                  <div class="d-grid gap-3">
                    <p class="mb-0 text-body-secondary">
                      <% if (activeProfile) { %>
                        Esta guía fue compartida contigo. Revísala y decide si quieres importarla al perfil <strong><%= activeProfile.name %></strong>.
                      <% } else { %>
                        Esta guía fue compartida contigo. Puedes revisarla ahora mismo y, si te interesa, iniciar sesión o crear una cuenta para importarla.
                      <% } %>
                    </p>

                    <div class="card">
                      <div class="card-body">
                        <p class="resource-page-section-copy mt-0">Descripción</p>
                        <div class="resource-markdown mb-3" data-render-markdown><%= selectedSharedPracticeModule.description %></div>
                        <p class="resource-page-section-copy">Instrucciones al tutor</p>
                        <div class="resource-markdown" data-render-markdown><%= selectedSharedPracticeModule.tutorInstructions %></div>
                      </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                      <a class="btn btn-secondary" href="<%= isAuthenticated ? '/resources' : '/' %>">No ahora</a>
                      <% if (isAuthenticated && activeProfile) { %>
                        <form method="post" action="/practice-modules/shared/<%= encodeURIComponent(selectedPracticeModuleShareLink.id) %>/accept">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-primary" type="submit">Importar guía</button>
                        </form>
                      <% } else { %>
                        <a class="btn btn-secondary" href="/signup?returnTo=<%= encodeURIComponent(`/practice-modules/shared/${selectedPracticeModuleShareLink.id}`) %>">Crear cuenta</a>
                        <a class="btn btn-primary" href="/login?returnTo=<%= encodeURIComponent(`/practice-modules/shared/${selectedPracticeModuleShareLink.id}`) %>">Iniciar sesión</a>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </section>
          <% } %>
        </section>

        <div
          class="modal fade"
          id="practiceModuleHelpModal"
          tabindex="-1"
          aria-labelledby="practiceModuleHelpModalLabel"
          aria-hidden="true"
        >
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h2 class="modal-title fs-5" id="practiceModuleHelpModalLabel">Instrucciones al tutor</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
              </div>
              <div class="modal-body">
                <p class="mb-2">
                  Describe el objetivo de práctica, el nivel esperado, los errores que quieres corregir y el tipo de ayuda que debe ofrecer Mr. F.
                </p>
                <p class="mb-0 text-body-secondary">
                  También puedes indicar si quieres que el tutor use ejemplos, preguntas de seguimiento, correcciones breves o práctica guiada.
                </p>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
              </div>
            </div>
          </div>
        </div>

        <% if (practiceModulePageMode === 'new') { %>
          <div
            class="modal fade"
            id="generatePracticeModuleModal"
            tabindex="-1"
            aria-labelledby="generatePracticeModuleModalLabel"
            aria-hidden="true"
            <% if (practiceModuleGenerationModalAutoOpen) { %>data-auto-open-modal="true"<% } %>
          >
            <div class="modal-dialog modal-lg modal-dialog-centered">
              <div class="modal-content">
                <form method="post" action="/practice-modules/generate-draft" data-resource-generate-form>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="resourceLabel" value="guía de práctica">
                  <div class="modal-header">
                    <h2 class="modal-title fs-5" id="generatePracticeModuleModalLabel">Crear guía con IA</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                  </div>
                  <div class="modal-body d-grid gap-3">
                    <p class="mb-0 text-body-secondary">
                      Describe qué quieres practicar, para qué nivel y qué tipo de interacción debería guiar Mr. F.
                    </p>
                    <% if (practiceModuleGenerationError) { %>
                      <div class="alert alert-warning mb-0" role="alert">
                        <strong>No pude generar la guía automáticamente.</strong>
                        <div><%= practiceModuleGenerationError %></div>
                        <% if (practiceModuleGenerationCreditExhausted) { %>
                          <a class="btn btn-primary btn-sm mt-3" href="/credits?returnTo=<%= encodeURIComponent('/practice-modules/new') %>">Comprar créditos</a>
                        <% } %>
                      </div>
                    <% } %>
                    <label class="form-label mb-0" for="practiceModuleGenerationPrompt">Describe la guía que quieres crear</label>
                    <textarea
                      class="form-control"
                      id="practiceModuleGenerationPrompt"
                      name="prompt"
                      rows="6"
                      required
                    ><%= practiceModuleGenerationPrompt || '' %></textarea>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button
                      type="submit"
                      class="btn btn-primary"
                      data-resource-generate-submit
                      data-loading-text="Creando..."
                    >
                      Crear
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% } %>

        <% if (practiceModulePageMode === 'edit' && selectedPracticeModule) { %>
          <div
            class="modal fade"
            id="revisePracticeModuleModal"
            tabindex="-1"
            aria-labelledby="revisePracticeModuleModalLabel"
            aria-hidden="true"
            <% if (practiceModuleRevisionModalAutoOpen) { %>data-auto-open-modal="true"<% } %>
          >
            <div class="modal-dialog modal-lg modal-dialog-centered">
              <div class="modal-content">
                <form method="post" action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/revise" data-resource-generate-form>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <div class="modal-header">
                    <h2 class="modal-title fs-5" id="revisePracticeModuleModalLabel">Editar guía con IA</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                  </div>
                  <div class="modal-body d-grid gap-3">
                    <p class="mb-0 text-body-secondary">
                      Describe los cambios que quieres aplicar al título, la descripción o las instrucciones del tutor. La IA conservará lo que no pidas cambiar.
                    </p>
                    <% if (practiceModuleRevisionError) { %>
                      <div class="alert alert-warning mb-0" role="alert">
                        <strong>No pude editar la guía automáticamente.</strong>
                        <div><%= practiceModuleRevisionError %></div>
                        <% if (practiceModuleRevisionCreditExhausted) { %>
                          <a class="btn btn-primary btn-sm mt-3" href="/credits?returnTo=<%= encodeURIComponent(`/practice-modules/${selectedPracticeModule.id}/edit`) %>">Comprar créditos</a>
                        <% } %>
                      </div>
                    <% } %>
                    <label class="form-label mb-0" for="practiceModuleRevisionPrompt">Cambios que deseas aplicar</label>
                    <textarea
                      class="form-control"
                      id="practiceModuleRevisionPrompt"
                      name="prompt"
                      rows="6"
                      required
                    ><%= practiceModuleRevisionPrompt || '' %></textarea>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button
                      type="submit"
                      class="btn btn-primary"
                      data-resource-generate-submit
                      data-loading-text="Actualizando..."
                    >
                      Aplicar cambios
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% } %>

        <% if (practiceModulePageMode === 'new' || (practiceModulePageMode === 'edit' && selectedPracticeModule)) { %>
          <div
            class="modal fade"
            id="practiceModuleGenerationPendingModal"
            tabindex="-1"
            aria-labelledby="practiceModuleGenerationPendingModalLabel"
            aria-hidden="true"
            data-resource-pending-modal
            data-resource-pending-label="guía de práctica"
            data-bs-backdrop="static"
            data-bs-keyboard="false"
          >
            <div class="modal-dialog modal-dialog-centered modal-sm">
              <div class="modal-content">
                <div class="modal-body text-center py-4 d-grid gap-3">
                  <div
                    class="spinner-border text-primary mx-auto"
                    role="status"
                    aria-hidden="true"
                  ></div>
                  <div>
                    <h2 class="fs-6 mb-1" id="practiceModuleGenerationPendingModalLabel">
                      <%= practiceModulePageMode === 'edit' ? 'Actualizando guía...' : 'Creando guía...' %>
                    </h2>
                    <p class="mb-0 text-body-secondary small">
                      Esto puede tardar unos segundos.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <% if (practiceModulePageMode === 'detail' && selectedPracticeModule) { %>
          <div
            class="modal fade"
            id="sharePracticeModuleProfileModal"
            tabindex="-1"
            aria-labelledby="sharePracticeModuleProfileModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeModuleProfileModalLabel">Compartir con perfil</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                  <% if (shareTargetPracticeModuleProfiles.length > 0) { %>
                    <form method="post" action="/practice-modules/<%= encodeURIComponent(selectedPracticeModule.id) %>/share/profile" class="d-grid gap-3">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <div>
                        <label class="form-label" for="shareTargetProfileId">Perfil destino</label>
                        <select class="form-select" id="shareTargetProfileId" name="targetProfileId" required>
                          <% shareTargetPracticeModuleProfiles.forEach((profile) => { %>
                            <option value="<%= profile.id %>"><%= profile.name %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Compartir ahora</button>
                      </div>
                    </form>
                  <% } else { %>
                    <p class="mb-0 text-body-secondary">No tienes otros perfiles disponibles para recibir esta guía.</p>
                  <% } %>
                </div>
                <% if (shareTargetPracticeModuleProfiles.length === 0) { %>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <div
            class="modal fade"
            id="sharePracticeModuleLinkModal"
            tabindex="-1"
            aria-labelledby="sharePracticeModuleLinkModalLabel"
            aria-hidden="true"
          >
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title fs-5" id="sharePracticeModuleLinkModalLabel">Enlace para compartir</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body d-grid gap-3">
                  <div>
                    <label class="form-label" for="practiceModuleShareLinkField">Enlace</label>
                    <input
                      class="form-control"
                      id="practiceModuleShareLinkField"
                      type="text"
                      readonly
                      value="<%= practiceModuleShareUrl %>"
                      data-practiceModule-share-link-field
                    >
                  </div>
                  <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-secondary" type="button" data-copy-practiceModule-share-link>
                      <i class="bi bi-copy me-1" aria-hidden="true"></i>
                      Copiar
                    </button>
                    <button class="btn btn-outline-secondary" type="button" data-native-share-practiceModule-link>
                      <i class="bi bi-share me-1" aria-hidden="true"></i>
                      Compartir
                    </button>
                  </div>
                  <% if (practiceModuleShareQrDataUrl) { %>
                    <div class="d-flex justify-content-center">
                      <img
                        class="practiceModule-share-qr"
                        src="<%= practiceModuleShareQrDataUrl %>"
                        alt="QR del enlace para compartir la guía"
                        width="180"
                        height="180"
                      >
                    </div>
                  <% } %>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
                </div>
              </div>
            </div>
          </div>
        <% } %>
