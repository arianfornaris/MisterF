        <section class="chat-layout <%= currentView === 'chat' ? '' : 'd-none' %>" aria-label="Chat con Mister F">
          <div
            class="messages"
            id="chatPane"
            tabindex="0"
          >
            <section class="practice-module-start-panel d-none" data-practice-module-start-panel>
              <p class="practiceModule-start-kicker">Módulo de práctica</p>
              <h2 class="practiceModule-start-title" data-practiceModule-start-title></h2>
              <p class="practiceModule-start-description" data-practiceModule-start-description></p>
              <p class="practice-module-start-status text-body-secondary d-none" data-practice-module-start-status>
                Comenzando el módulo de práctica...
              </p>
              <button class="btn btn-primary" type="button" data-practiceModule-start-button>
                Comenzar
              </button>
            </section>
            <div id="messages" aria-live="polite"></div>
          </div>

          <form id="chatForm" class="composer" autocomplete="off">
            <label class="visually-hidden" for="messageInput">Escribe tu mensaje</label>
            <div class="composer-input-wrap">
              <textarea
                id="messageInput"
                class="composer-input"
                rows="1"
                maxlength="1200"
                placeholder="Escribe tu mensaje"
                autocomplete="off"
                autocapitalize="none"
                autocorrect="off"
                spellcheck="false"
                autofocus
              ></textarea>
            </div>
            <div class="composer-footer">
              <button
                class="btn btn-primary send-button"
                type="submit"
                title="Enviar"
                aria-label="Enviar"
                data-send-button
              >
                <i class="bi bi-send" aria-hidden="true"></i>
              </button>
            </div>
            <div
              class="composer-status small text-body-secondary d-none"
              data-tool-status
              aria-live="polite"
            ></div>
          </form>
        </section>
      </div>
    </main>
