        <section class="chat-layout <%= currentView === 'chat' ? '' : 'd-none' %>" aria-label="Chat con Mister F">
          <div
            class="messages"
            id="chatPane"
            tabindex="0"
          >
            <section class="practice-module-start-panel d-none" data-practice-module-start-panel>
              <p class="practiceModule-start-kicker">Módulo de práctica</p>
              <h2 class="practiceModule-start-title" data-practiceModule-start-title></h2>
              <p class="practiceModule-start-description" data-practiceModule-start-description></p>
              <p class="practice-module-start-status text-body-secondary d-none" data-practice-module-start-status>
                Comenzando el módulo de práctica...
              </p>
              <button class="btn btn-primary" type="button" data-practiceModule-start-button>
                Comenzar
              </button>
            </section>
            <div id="messages" aria-live="polite"></div>
          </div>

          <form id="chatForm" class="composer" autocomplete="off">
            <label class="visually-hidden" for="messageInput">Escribe tu mensaje</label>
            <span class="composer-prompt" aria-hidden="true">&gt;</span>
            <div class="composer-input-wrap">
              <textarea
                id="messageInput"
                class="composer-input"
                rows="1"
                maxlength="1200"
                placeholder="Escribe tu mensaje"
                autocomplete="off"
                autocapitalize="none"
                autocorrect="off"
                spellcheck="false"
                autofocus
              ></textarea>
            </div>
            <div class="composer-footer">
              <div
                class="llm-context-meter"
                data-llm-context-meter
                role="progressbar"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
                aria-valuetext="0 por ciento del contexto usado"
                title="Uso del contexto del modelo"
                aria-label="Uso del contexto del modelo"
              >
                <svg
                  class="llm-context-meter-ring"
                  viewBox="0 0 40 40"
                  aria-hidden="true"
                >
                  <circle
                    class="llm-context-meter-track"
                    cx="20"
                    cy="20"
                    r="16"
                  ></circle>
                  <circle
                    class="llm-context-meter-progress"
                    cx="20"
                    cy="20"
                    r="16"
                    data-llm-context-circle
                  ></circle>
                </svg>
              </div>

              <div class="dropdown composer-model-dropdown">
                <button
                  id="modelTierSelect"
                  class="btn btn-link composer-model-button dropdown-toggle"
                  type="button"
                  data-model-tier-button
                  data-model-tier="regular"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  aria-label="Seleccionar modelo"
                >
                  <span data-model-tier-label>Regular</span>
                </button>
                <div class="dropdown-menu dropdown-menu-end composer-model-menu">
                  <button class="dropdown-item" type="button" data-model-tier-option="regular">
                    <span>Intelig. regular · muy rápido · costo 1x</span>
                  </button>
                  <button class="dropdown-item" type="button" data-model-tier-option="advanced">
                    <span>Intelig. avanzada · rápido · costo 2x</span>
                  </button>
                  <button class="dropdown-item" type="button" data-model-tier-option="max">
                    <span>Intelig. máxima · lento · costo 8x</span>
                  </button>
                </div>
              </div>

              <button
                class="btn btn-primary send-button"
                type="submit"
                title="Enviar"
                aria-label="Enviar"
                data-send-button
              >
                <i class="bi bi-send" aria-hidden="true"></i>
              </button>
            </div>
            <div
              class="composer-status small text-body-secondary d-none"
              data-tool-status
              aria-live="polite"
            ></div>
          </form>
        </section>
      </div>
    </main>
