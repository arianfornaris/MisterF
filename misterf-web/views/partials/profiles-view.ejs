        <section
          class="practice-modules-view <%= currentView === 'profiles' ? '' : 'd-none' %>"
          aria-label="Perfiles"
        >
          <div class="practice-modules-header <%= profilePageMode !== 'list' ? 'practice-modules-header-has-close' : '' %>">
            <div>
              <p class="practice-modules-kicker">Perfiles</p>
              <h1 class="practice-modules-title">
                <% if (profilePageMode === 'new') { %>
                  Nuevo perfil
                <% } else if (profilePageMode === 'edit') { %>
                  Editar perfil
                <% } else { %>
                  Cambiar perfil
                <% } %>
              </h1>
              <p class="practice-modules-copy">
                <% if (profilePageMode === 'new') { %>
                  Crea un perfil separado para organizar conversaciones y módulos de práctica sin mezclarlas con las demás.
                <% } else if (profilePageMode === 'edit' && selectedProfile) { %>
                  Ajusta el nombre y la descripción de este perfil.
                <% } else { %>
                  Cada perfil mantiene separadas sus conversaciones y módulos de práctica.
                <% } %>
              </p>
            </div>

            <% if (hasSession) { %>
              <div class="practice-modules-header-actions">
                <% if (profilePageMode === 'list') { %>
                  <a class="btn btn-dark" href="/profiles/new">
                    Crear perfil
                  </a>
                <% } else { %>
                  <a
                    class="btn-close practice-module-close-button"
                    href="/profiles"
                    title="Cerrar"
                    aria-label="Cerrar"
                  ></a>
                <% } %>
              </div>
            <% } %>
          </div>

          <% if (profilePageMode === 'new' || profilePageMode === 'edit') { %>
            <section class="practice-module-form-shell">
              <div class="practice-module-form-card card shadow-sm">
                <div class="card-body">
                <form
                  class="practice-module-form"
                  method="post"
                  action="<%= profilePageMode === 'edit' && selectedProfile ? `/profiles/${encodeURIComponent(selectedProfile.id)}` : '/profiles' %>"
                  autocomplete="off"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="returnTo" value="/profiles">

                  <label class="form-label" for="profileName">Nombre</label>
                  <input
                    class="form-control"
                    id="profileName"
                    name="name"
                    maxlength="120"
                    value="<%= profilePageMode === 'edit' && selectedProfile ? selectedProfile.name : '' %>"
                    required
                  >

                  <label class="form-label" for="profileDescription">Descripción</label>
                  <textarea
                    class="form-control"
                    id="profileDescription"
                    name="description"
                    rows="4"
                    maxlength="500"
                  ><%= profilePageMode === 'edit' && selectedProfile ? selectedProfile.description : '' %></textarea>

                  <div class="practice-module-form-actions">
                    <button type="submit" class="btn btn-dark">
                      <%= profilePageMode === 'edit' ? 'Guardar cambios' : 'Crear perfil' %>
                    </button>
                  </div>
                </form>
                </div>
              </div>
            </section>
          <% } else if (profiles && profiles.length > 0) { %>
            <div class="profiles-list">
              <% profiles.forEach((profile) => { %>
                <article class="practice-module-card profile-card card shadow-sm <%= activeProfile && activeProfile.id === profile.id ? 'is-active' : '' %>">
                  <div class="card-body d-grid gap-2">
                    <div class="practice-module-card-meta">
                      <p class="practice-module-card-kicker">Perfil</p>
                      <% if (activeProfile && activeProfile.id === profile.id) { %>
                        <span class="badge rounded-pill text-bg-light border practice-module-chat-count-badge">Activo</span>
                      <% } %>
                    </div>
                    <h2 class="h4"><%= profile.name %></h2>
                    <p class="mb-0 text-body-secondary"><%= profile.description || 'Sin descripción.' %></p>
                    <div class="profile-card-actions">
                      <% if (activeProfile && activeProfile.id === profile.id) { %>
                        <a class="btn btn-outline-dark" href="/profiles/<%= encodeURIComponent(profile.id) %>/edit">
                          Editar perfil
                        </a>
                      <% } else { %>
                        <form method="post" action="/profiles/switch">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <input type="hidden" name="profileId" value="<%= profile.id %>">
                          <input type="hidden" name="returnTo" value="/profiles">
                          <button class="btn btn-dark" type="submit">Usar este perfil</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="practice-module-empty-state alert alert-light border">
              <p>Todavía no hay perfiles. Crea el primero para separar tu práctica en distintos contextos.</p>
            </div>
          <% } %>
        </section>
