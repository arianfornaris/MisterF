{
  "name": "misterf-web",
  "version": "1.0.0",
  "description": "Mister F web tutor for practicing English sentence writing.",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "tsx watch src/server/server.ts",
    "dev:client": "vite build --watch",
    "build": "npm run build:server && npm run build:client",
    "build:server": "rm -rf dist && tsc",
    "build:client": "node scripts/build-client.mjs",
    "start": "node dist/server/server.js",
    "typecheck": "tsc --noEmit",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs --update-env",
    "pm2:restart": "npm run build && pm2 restart ecosystem.config.cjs --update-env",
    "pm2:start:prod": "pm2 start ecosystem.config.cjs --env production --update-env",
    "pm2:restart:prod": "pm2 restart ecosystem.config.cjs --env production --update-env",
    "pm2:status": "pm2 status",
    "pm2:stop": "pm2 stop misterf-web",
    "pm2:delete": "pm2 delete misterf-web",
    "pm2:logs": "pm2 logs misterf-web"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "ai": "^6.0.168",
    "better-sqlite3": "^12.9.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootswatch": "^5.3.8",
    "dompurify": "^3.4.0",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "marked": "^18.0.1",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
