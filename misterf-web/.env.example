# Server
HOST=127.0.0.1
PORT=5005
APP_BASE_URL=http://localhost:5005
APP_SESSION_SECRET=replace-with-at-least-32-random-characters
DATABASE_PATH=./data/misterf.sqlite

# LLM provider
LLM_MODEL=
LLM_MODEL_REGULAR=google/gemini-3.1-flash-lite
LLM_MODEL_ADVANCED=google/gemini-3-flash-preview
LLM_MODEL_MAX=google/gemini-3.1-pro-preview
LLM_CONTEXT_WINDOW=1048576

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MANAGEMENT_API_KEY=
OPENROUTER_KEY_ENCRYPTION_SECRET=
OPENROUTER_REASONING_EFFORT=medium
OPENROUTER_USER_KEY_LIMIT_USD=0.10
OPENROUTER_USER_KEY_LIMIT_RESET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CREDITS_200_PRICE_ID=

# Email
